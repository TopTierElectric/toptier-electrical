---
import TTELayout from '~/layouts/TTELayout.astro';

const jsonLd = [
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Generator Installation',
    description:
      'Backup power systems sized and installed safely with clear scope, clean workmanship, and verified operation in West Michigan.',
    provider: { '@id': 'https://toptier-electrical.com/#localbusiness' },
    areaServed: [
      { '@type': 'City', name: 'Holland, MI' },
      { '@type': 'City', name: 'Grand Rapids, MI' },
      { '@type': 'City', name: 'Byron Center, MI' },
      { '@type': 'City', name: 'Zeeland, MI' },
      { '@type': 'City', name: 'Saugatuck, MI' },
      { '@type': 'City', name: 'Douglas, MI' },
      { '@type': 'City', name: 'Hudsonville, MI' },
      { '@type': 'City', name: 'Jamestown, MI' },
      { '@type': 'City', name: 'Allegan, MI' },
      { '@type': 'City', name: 'Ada, MI' },
    ],
    serviceType: 'Generator Installation',
    url: 'https://toptier-electrical.com/generators',
  }),
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How a West Michigan home generator install works',
    description:
      'Our four-step process for installing a standby generator with a transfer switch: walkthrough, plan, execute, and verify.',
    step: [
      {
        '@type': 'HowToStep',
        position: 1,
        name: 'Walkthrough',
        text: 'Define outage priorities, site constraints, and which circuits matter most when the power is out.',
      },
      {
        '@type': 'HowToStep',
        position: 2,
        name: 'Plan',
        text: 'Choose the right generator size and transfer switch layout for your loads and lot.',
      },
      {
        '@type': 'HowToStep',
        position: 3,
        name: 'Execute',
        text: 'Install the generator, transfer switch, and feeder runs cleanly, safely, and to code.',
      },
      {
        '@type': 'HowToStep',
        position: 4,
        name: 'Verify',
        text: 'Test the transfer under load, confirm labeling, and walk you through how to operate it.',
      },
    ],
  }),
];
---

<TTELayout
  title="Generator Installation | West Michigan Electrician"
  description="Backup power systems sized and installed safely with clear scope, clean workmanship, and verified operation."
  canonical="https://toptier-electrical.com/generators"
  jsonLd={jsonLd}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/services">Services</a></li>
        <li aria-current="page">Generator Sales &amp; Installation</li>
      </ol>
    </nav>
    <section class="hero">
      <div class="hero-content">
        <h1>Generator Sales &amp; Installation</h1>
        <p>Backup power that's sized correctly, installed safely, and easy to live with.</p>
        <a
          href="/booking"
          class="btn btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking">Get a Clear Estimate</a
        >
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#128274; Workmanship Guarantee</span>
          <span class="badge">Owner-Operated</span>
          <span class="badge">Clean, Respectful Jobsite Habits</span>
        </div>
      </div>
    </div>
    <section class="service-detail">
      <div class="container">
        <p>
          Backup power should feel calm and predictable. The key is sizing and planning the system around what you
          actually need to run during an outage—then installing it cleanly and safely.
        </p>
        <div class="proof-chips">
          <span>Load planning included</span>
          <span>Transfer switch expertise</span>
          <span>Inspection-ready install</span>
        </div>
        <h2>What We Help You Decide</h2>
        <ul>
          <li>Essential-circuits backup vs broader coverage</li>
          <li>Where the generator and transfer equipment should go</li>
          <li>How to keep the install tidy and serviceable long-term</li>
        </ul>
        <h2>What You Can Expect</h2>
        <ul>
          <li>Walkthrough + load planning (what stays on, what stays off)</li>
          <li>Clear scope and clean installation approach</li>
          <li>Code-compliant transfer equipment and labeling</li>
          <li>Final verification and a simple handoff walkthrough</li>
        </ul>
        <h2>Pricing Factors</h2>
        <ul>
          <li>Generator size and fuel source</li>
          <li>Transfer switch type and circuit coverage</li>
          <li>Site access and conduit routing distance</li>
          <li>Permit and inspection requirements</li>
        </ul>
        <h2>How We Work</h2>
        <ol>
          <li>Walkthrough — Define outage priorities and site constraints.</li>
          <li>Plan — Choose the right system and layout.</li>
          <li>Execute — Install cleanly, safely, and to code.</li>
          <li>Verify — Test operation and confirm labeling and function.</li>
        </ol>
        <h2>Generator Installation FAQs</h2>
        <div class="faq-grid">
          <div class="faq-item">
            <h3>How do I choose the right generator size?</h3>
            <p>We calculate load priorities and recommend a size based on what you want powered during an outage.</p>
          </div>
          <div class="faq-item">
            <h3>Do I need a transfer switch?</h3>
            <p>Yes. Transfer equipment is required for safe, code-compliant backup power operation.</p>
          </div>
          <div class="faq-item">
            <h3>Do you handle permits?</h3>
            <p>Yes. We coordinate permit and inspection steps required for the electrical portion.</p>
          </div>
          <div class="faq-item">
            <h3>Will the generator run automatically?</h3>
            <p>With the right setup, standby systems can start automatically when utility power drops.</p>
          </div>
          <div class="faq-item">
            <h3>Can I keep my current panel?</h3>
            <p>Often yes, but we verify panel condition and capacity during the walkthrough.</p>
          </div>
          <div class="faq-item">
            <h3>How long does installation take?</h3>
            <p>
              Timeline depends on scope, permitting, and equipment lead time. We provide a clear schedule before work
              begins.
            </p>
          </div>
        </div>
        <h2>Next Step</h2>
        <p>Request a walkthrough to discuss generator options and get a clear quote without pressure.</p>
      </div>
    </section>
    <section class="cta-section">
      <h2>Plan for Reliable Backup Power</h2>
      <p>
        Call us at <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to discuss generator options.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
