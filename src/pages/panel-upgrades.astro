---
import TTELayout from '~/layouts/TTELayout.astro';

const jsonLd = [
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Electrician',
    name: 'Top Tier Electrical',
    url: 'https://toptier-electrical.com',
    telephone: '+16163347159',
    address: {
      '@type': 'PostalAddress',
      addressRegion: 'MI',
      addressCountry: 'US',
    },
    areaServed: 'West Michigan',
    hasMap: 'https://toptier-electrical.com/service-areas',
  }),
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Electrical Panel Upgrades',
    description: '200-amp panel upgrades for homes in West Michigan. Licensed, code-compliant installations.',
    provider: { '@id': 'https://toptier-electrical.com/#localbusiness' },
    areaServed: [
      { '@type': 'City', name: 'Holland, MI' },
      { '@type': 'City', name: 'Grand Rapids, MI' },
      { '@type': 'City', name: 'Byron Center, MI' },
      { '@type': 'City', name: 'Zeeland, MI' },
      { '@type': 'City', name: 'Saugatuck, MI' },
      { '@type': 'City', name: 'Douglas, MI' },
      { '@type': 'City', name: 'Hudsonville, MI' },
      { '@type': 'City', name: 'Jamestown, MI' },
      { '@type': 'City', name: 'Allegan, MI' },
      { '@type': 'City', name: 'Ada, MI' },
    ],
    serviceType: 'Electrical Panel Upgrade',
    url: 'https://toptier-electrical.com/panel-upgrades',
  }),
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Will my power be off during a panel upgrade?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Usually, yes—there is typically a planned outage window while the panel work is completed.',
        },
      },
      {
        '@type': 'Question',
        name: 'Do I need a full service upgrade?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Not always. We verify capacity and recommend the simplest code-compliant option that fits your goals.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can you make room for future projects?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes—planning for EV charging, generator readiness, and remodel loads is part of a good upgrade.',
        },
      },
      {
        '@type': 'Question',
        name: 'Will you label every circuit?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. Clear labeling helps you and future service calls understand what each breaker controls.',
        },
      },
    ],
  }),
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How a West Michigan electrical panel upgrade works',
    description:
      'Our four-step process for replacing a residential electrical panel: walkthrough, plan, execute, and verify.',
    step: [
      {
        '@type': 'HowToStep',
        position: 1,
        name: 'Walkthrough',
        text: 'We review your current loads and what you are adding so capacity and layout are clear before any work starts.',
      },
      {
        '@type': 'HowToStep',
        position: 2,
        name: 'Plan',
        text: 'Define a clear scope, load approach, and sequencing so the install runs without surprises.',
      },
      {
        '@type': 'HowToStep',
        position: 3,
        name: 'Execute',
        text: 'Replace the panel with tidy workmanship, organized circuit routing, and a professional finish.',
      },
      {
        '@type': 'HowToStep',
        position: 4,
        name: 'Verify',
        text: 'Function check every circuit, label clearly, and walk you through the finished panel at handoff.',
      },
    ],
  }),
];
---

<TTELayout
  title="Electrical Panel Upgrades in West Michigan | Top Tier Electrical"
  description="Clean, code-compliant electrical panel upgrades and service upgrades in West Michigan. Clear scope, tidy installs, and reliable long-term results."
  canonical="https://toptier-electrical.com/panel-upgrades"
  jsonLd={jsonLd}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/services">Services</a></li>
        <li aria-current="page">Panel Upgrades</li>
      </ol>
    </nav>
    <section class="hero">
      <div class="hero-content">
        <h1>Electrical Panel Upgrades &amp; Service Upgrades</h1>
        <p>Clean, code-compliant electrical panel work with clear scope and tidy installs.</p>
        <a
          href="/booking"
          class="btn btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking">Get a Clear Estimate</a
        >
      </div>
    </section>
    <section class="container">
      <section class="card mt-4">
        <h2 class="mt-0">Explore by Audience</h2>
        <p class="muted m-0">
          <a href="/residential-electrician-allegan-mi">Residential electrician hub</a> •
          <a href="/commercial-electrician-allegan-mi">Commercial electrician hub</a>
        </p>
      </section>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#128274; Workmanship Guarantee</span>
          <span class="badge">Owner-Operated</span>
          <span class="badge">Clean, Respectful Jobsite Habits</span>
        </div>
      </div>
    </div>
    <section class="service-detail">
      <div class="container">
        <p>
          A clean, code-compliant electrical panel is the foundation of a reliable home. If your system is out of space,
          showing wear, or struggling with modern loads, a panel upgrade is often the most practical next step.
        </p>
        <div class="proof-chips">
          <span>Permit-ready installs</span>
          <span>Labelled breaker layout</span>
          <span>Inspection walkthrough</span>
        </div>
        <h2>When a Panel Upgrade Makes Sense</h2>
        <ul>
          <li>Breakers trip during normal use, or lights flicker under load</li>
          <li>You're out of breaker spaces (or planning EV charging, HVAC upgrades, a hot tub, or an addition)</li>
          <li>The panel shows corrosion, heat damage, or loose/unsafe conditions</li>
          <li>You want a modern, clearly labeled layout that's easy to live with long-term</li>
        </ul>
        <h2>What's Included (So the Scope Is Clear)</h2>
        <ul>
          <li>Walkthrough of current loads + your future plans</li>
          <li>Panel assessment (capacity, condition, circuit layout)</li>
          <li>Permit/inspection coordination when required</li>
          <li>Clean panel replacement and circuit organization</li>
          <li>Clear labeling so circuits make sense later</li>
          <li>Final verification and walkthrough at handoff</li>
        </ul>
        <h2>Pricing Factors</h2>
        <ul>
          <li>Existing panel condition and amperage size</li>
          <li>Service mast updates or meter base changes</li>
          <li>Need for load calculations and future capacity</li>
          <li>Permit and utility coordination requirements</li>
        </ul>
        <h2>How We Work</h2>
        <ol>
          <li>Walkthrough — We review what you have and what you're adding.</li>
          <li>Plan — Clear scope, load approach, and sequencing.</li>
          <li>Execute — Tidy workmanship, organized routing, professional finish.</li>
          <li>Verify — Function check, labeling, and a clean handoff.</li>
        </ol>
        <h2>FAQ</h2>
        <p>
          <strong>Will my power be off?</strong><br />Usually, yes—there is typically a planned outage window while the
          panel work is completed.
        </p>
        <p>
          <strong>Do I need a full service upgrade?</strong><br />Not always. We verify capacity and recommend the
          simplest code-compliant option that fits your goals.
        </p>
        <p>
          <strong>Can you make room for future projects?</strong><br />Yes—planning for EV charging, generator
          readiness, and remodel loads is part of a good upgrade.
        </p>
        <p>
          <strong>Will you label every circuit?</strong><br />Yes. Clear labeling helps you and future service calls
          understand what each breaker controls.
        </p>
        <h2>Next Step</h2>
        <p>
          If you want a West Michigan electrician who plans first and finishes clean, schedule a walkthrough. You'll get
          a clear scope and a quote you can trust—without pressure.
        </p>
      </div>
    </section>
    <section class="container section-pad">
      <h2>Related reading</h2>
      <ul>
        <li><a href="/blog/blog-panel-upgrade-signs">5 signs you need an electrical panel upgrade</a></li>
        <li><a href="/blog/when-to-upgrade-electrical-panel">When should you upgrade your electrical panel?</a></li>
        <li><a href="/blog/electrical-panel-upgrade-cost">How much does an electrical panel upgrade cost?</a></li>
        <li><a href="/blog/200-amp-vs-400-amp-service">200-amp vs 400-amp electrical service compared</a></li>
        <li>
          <a href="/blog/do-i-need-a-panel-upgrade-for-an-ev-charger">Do I need a panel upgrade for an EV charger?</a>
        </li>
      </ul>
    </section>
    <section class="container section-pad">
      <h2>Electrical Panel Upgrades by City</h2>
      <p>Find local electrical service for electrical panel upgrades in your West Michigan city:</p>
      <ul>
        <li><a href="/panel-upgrades-holland-mi">Electrical Panel Upgrades in Holland, MI</a></li>
        <li><a href="/panel-upgrades-grand-rapids-mi">Electrical Panel Upgrades in Grand Rapids, MI</a></li>
        <li><a href="/panel-upgrades-zeeland-mi">Electrical Panel Upgrades in Zeeland, MI</a></li>
        <li><a href="/panel-upgrades-hudsonville-mi">Electrical Panel Upgrades in Hudsonville, MI</a></li>
        <li><a href="/panel-upgrades-ada-mi">Electrical Panel Upgrades in Ada, MI</a></li>
      </ul>
      <p>
        <a href="/service-areas">View all service areas</a>
      </p>
    </section>
    <section class="cta-section">
      <h2>Ready for an Upgrade?</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to confirm scope and scheduling.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
