---
import TTELayout from '~/layouts/TTELayout.astro';

const projectImages = [
  {
    src: 'SteelTech Conduit Room',
    alt: 'Industrial conduit routing in shop addition mechanical room for Steeltech',
    caption:
      'Conduit routing organized in the mechanical room — clean runs, supported correctly, ready for inspection.',
  },
  {
    src: 'Switch Gear',
    alt: 'Commercial switchgear installation for Steeltech shop addition',
    caption: 'Switchgear installation feeding the new addition.',
  },
  {
    src: 'Control Cabinet',
    alt: 'Commercial control cabinet built for dust collection system',
    caption: 'Control cabinet built for the dust collection system and addition equipment.',
  },
  {
    src: 'Conduit Piping',
    alt: 'Conduit piping installation in industrial shop addition',
    caption: 'Conduit runs through the addition — straight, supported, and labeled.',
  },
  {
    src: 'Dust Collector System',
    alt: 'Industrial dust collector system wired and integrated',
    caption: 'Dust collector system wired in and integrated with the shop layout.',
  },
  {
    src: 'Dust Collector motor',
    alt: 'Dust collector motor wiring and disconnect',
    caption: 'Dust collector motor wired with appropriate protection and disconnect.',
  },
  {
    src: 'Blower Motor',
    alt: 'Blower motor wiring for industrial dust collection',
    caption: 'Blower motor for the dust collection system.',
  },
  {
    src: 'Motor Control',
    alt: 'Motor control panel for shop addition equipment',
    caption: 'Motor control for shop equipment.',
  },
  {
    src: 'Field Controls',
    alt: 'Field controls installation for industrial dust collection system',
    caption: 'Field controls integrated with the rest of the system.',
  },
  {
    src: 'Control Work',
    alt: 'Control wiring for industrial fabrication shop addition',
    caption: 'Control wiring for the addition.',
  },
];

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Projects', item: 'https://toptier-electrical.com/projects' },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Steeltech Shop Addition With Dust Collection',
      item: 'https://toptier-electrical.com/projects/steeltech-shop-addition-dust-collection',
    },
  ],
});
---

<TTELayout
  title="Steeltech 80×120 Shop Addition With Dust Collection — Grand Rapids, MI"
  description="9,600 sq ft fabrication shop addition in Grand Rapids, MI. 1200A 480V three-phase, switchgear, control cabinet, conduit, motor controls, dust collection."
  canonical="https://toptier-electrical.com/projects/steeltech-shop-addition-dust-collection"
  ogImage="https://toptier-electrical.com/images/og/projects/steeltech-shop-addition-dust-collection.png"
  jsonLd={[breadcrumbLd]}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/projects">Projects</a></li>
        <li aria-current="page">Steeltech Shop Addition</li>
      </ol>
    </nav>
    <section class="hero">
      <div class="hero-content">
        <h1>Steeltech 80×120 Shop Addition With Donaldson Torit Dust Collection</h1>
        <p>
          Grand Rapids, MI · 2025. A 9,600 sq ft fabrication shop addition wired from the ground up — 1200A 480V
          three-phase branch circuit, switchgear, control cabinet, motor controls, conduit routing, and a large
          Donaldson Torit industrial dust collection system.
        </p>
        <a
          href="/booking"
          class="btn btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking"
        >
          Get a Clear Estimate
        </a>
      </div>
    </section>

    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127970; Commercial Experience</span>
          <span class="badge">Clean, Respectful Jobsite Habits</span>
        </div>
      </div>
    </div>

    <section class="container section-pad">
      <h2>Project Snapshot</h2>
      <ul>
        <li><strong>Client:</strong> Steeltech (steel fabrication)</li>
        <li><strong>Location:</strong> Grand Rapids, MI</li>
        <li><strong>Year:</strong> 2025</li>
        <li><strong>Addition size:</strong> 80×120 (9,600 sq ft)</li>
        <li><strong>Service:</strong> 1200A branch circuit, 480V three-phase</li>
        <li><strong>Dust collection:</strong> Donaldson Torit industrial system (large)</li>
        <li>
          <strong>Systems delivered:</strong> Switchgear, control cabinet, motor controls, conduit, field controls, dust
          collector blower &amp; motor, lighting and general-purpose feeders
        </li>
      </ul>

      <h2>What the Customer Needed</h2>
      <p>
        Steeltech was expanding their Grand Rapids fabrication shop with a new 80×120 addition and a large Donaldson
        Torit dust collection system. The electrical package had to support the addition's 480V three-phase loads, tie a
        1200A branch circuit into the new space, integrate the dust collector controls with the operation, pass
        inspection, and stay coordinated with the other trades on the jobsite.
      </p>

      <h2>Existing Conditions and Field Constraints</h2>
      <p>
        New construction means a lot of moving parts at once. The schedule had to coordinate with structural,
        mechanical, process equipment, and dust-collection installers. The Donaldson Torit unit drove specific motor,
        blower, and control requirements that needed to be planned before conduit was routed. 480V three-phase
        distribution at 1200A puts real demands on layout, supports, and clearances — all of which had to be solved
        alongside the other trades' rough-ins.
      </p>

      <h2>Work Performed</h2>
      <ul>
        <li>1200A 480V three-phase branch circuit feeding the addition</li>
        <li>Switchgear installation and distribution</li>
        <li>Control cabinet built and wired for the Donaldson Torit dust collection system and shop equipment</li>
        <li>Motor and blower wiring for the dust collector with appropriate protection and disconnects</li>
        <li>Field controls integrated for daily operation and service access</li>
        <li>Conduit routing organized for clean runs, proper supports, and labeled circuits</li>
        <li>Lighting and general-purpose feeders for the 80×120 space</li>
        <li>Permit, inspection, and on-site coordination across multiple trades</li>
      </ul>

      <h2>Final Result</h2>
      <p>
        A code-compliant electrical package for the new 80×120 addition. The Donaldson Torit dust collection system runs
        as designed, the control layout is organized for daily operation and future service, and the install passed
        inspection. Photos below were taken on the jobsite during and after installation.
      </p>

      <h2>Photos From the Jobsite</h2>
      <div class="gallery-grid">
        {
          projectImages.map((img) => (
            <figure>
              <img
                src={`/images/gallery-thumbs/${encodeURIComponent(img.src)}-480.webp`}
                srcset={`/images/gallery-thumbs/${encodeURIComponent(img.src)}-480.webp 480w, /images/gallery-thumbs/${encodeURIComponent(img.src)}-800.webp 800w`}
                sizes="(max-width: 600px) 95vw, (max-width: 1024px) 50vw, 33vw"
                alt={img.alt}
                width="800"
                height="600"
                loading="lazy"
                decoding="async"
              />
              <figcaption>{img.caption}</figcaption>
            </figure>
          ))
        }
      </div>

      <h2>Related Services</h2>
      <ul>
        <li><a href="/commercial">Commercial electrical services</a></li>
        <li><a href="/dedicated-circuits">Dedicated circuits for industrial loads</a></li>
        <li><a href="/electrical-design-consultation">Electrical design consultation</a></li>
        <li><a href="/commercial-electrical-maintenance">Commercial electrical maintenance</a></li>
        <li><a href="/code-corrections">Code corrections</a></li>
      </ul>
    </section>

    <section class="cta-section">
      <h2>Planning a Shop Buildout, Addition, or Industrial Install?</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to discuss scope.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking"
      >
        Get a Clear Estimate
      </a>
    </section>
  </main>
</TTELayout>
