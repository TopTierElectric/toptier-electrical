---
import TTELayout from '~/layouts/TTELayout.astro';
import GalleryThumb from '~/components/GalleryThumb.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Projects', item: 'https://toptier-electrical.com/projects' },
  ],
});

const projects = [
  {
    href: '/projects/steeltech-shop-addition-dust-collection',
    title: 'Steeltech 80×120 Shop Addition With Donaldson Torit Dust Collection — Grand Rapids, MI (2025)',
    summary:
      'A 9,600 sq ft fabrication shop addition in Grand Rapids. 1200A 480V three-phase branch circuit, switchgear, control cabinet, conduit, motor controls, and a large Donaldson Torit industrial dust collection system.',
    image: 'SteelTech Conduit Room',
    alt: 'Industrial conduit routing in commercial shop addition for Steeltech',
    services: ['Commercial', 'Switchgear', 'Motor Controls', 'Conduit'],
  },
  {
    href: '/projects/ada-mi-custom-home-and-horse-barn',
    title: 'Ada Custom Home and Horse Barn — 400A Service',
    summary:
      'Custom home and matching custom horse barn in Ada, MI on a single 400A service. Decorative lighting in the home, code-compliant stall lighting and barn power, and a clean finish across both buildings.',
    image: 'Light Fixture',
    alt: 'Custom home decorative lighting in Ada, MI',
    services: ['Residential', 'Custom Home', 'Lighting', 'Service Upgrade'],
  },
];
---

<TTELayout
  title="Recent Electrical Projects | Top Tier Electrical"
  description="Real electrical projects completed across West Michigan—commercial buildouts, panel upgrades, dust collection systems, lighting, EV chargers, and more."
  canonical="https://toptier-electrical.com/projects"
  ogImage="https://toptier-electrical.com/images/og/pages/projects.png"
  jsonLd={[breadcrumbLd]}
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Recent Electrical Projects</h1>
        <p>
          Real work in West Michigan. Each project page includes the actual conditions, scope, and finish, with photos
          from the jobsite.
        </p>
        <a
          href="/booking"
          class="btn btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking"
        >
          Get a Clear Estimate
        </a>
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127968; Owner-Operated</span>
        </div>
      </div>
    </div>
    <section class="container section-pad">
      <h2>Featured Projects</h2>
      <div class="service-cards">
        {
          projects.map((project) => (
            <a class="service-card" href={project.href}>
              <GalleryThumb
                name={project.image}
                alt={project.alt}
                sizes="(max-width: 600px) 95vw, 50vw"
                width={800}
                height={600}
                style="border-radius: 8px; margin-bottom: 1rem;"
              />
              <h3>{project.title}</h3>
              <p>{project.summary}</p>
              <p class="muted m-0">{project.services.join(' · ')}</p>
            </a>
          ))
        }
      </div>
      <p class="text-center mt-6">
        <a href="/gallery" class="btn btn-ghost">Browse Full Gallery</a>
      </p>
    </section>
    <section class="cta-section">
      <h2>Have a Similar Project?</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to discuss scope.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking"
      >
        Get a Clear Estimate
      </a>
    </section>
  </main>
</TTELayout>
