---
import TTELayout from '~/layouts/TTELayout.astro';
import GalleryThumb from '~/components/GalleryThumb.astro';

const projectImages = [
  {
    src: 'Light Fixture',
    alt: 'Custom light fixture installation in Ada, MI custom home',
    caption: 'House — custom light fixture installation in the main living space.',
  },
  {
    src: 'Horse Barn',
    alt: 'Custom horse barn electrical installation in Ada, MI',
    caption: 'Barn — electrical package for the custom horse barn.',
  },
  {
    src: 'Horse Stall Lighting',
    alt: 'Horse stall lighting in custom barn in Ada, MI',
    caption: 'Barn — stall lighting laid out for daily use and animal welfare.',
  },
];

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Projects', item: 'https://www.toptier-electrical.com/projects' },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Ada Custom Home and Horse Barn — 400A Service',
      item: 'https://www.toptier-electrical.com/projects/ada-mi-custom-home-and-horse-barn',
    },
  ],
});
---

<TTELayout
  title="Ada Custom Home & Horse Barn — 400A Service | Top Tier Electrical"
  description="Custom home and horse barn in Ada, MI on a single 400A service. Decorative lighting, code-compliant stall lighting and barn power, clean finish."
  canonical="https://www.toptier-electrical.com/projects/ada-mi-custom-home-and-horse-barn"
  ogImage="https://www.toptier-electrical.com/images/og/projects/ada-mi-custom-home-and-horse-barn.png"
  jsonLd={[breadcrumbLd]}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/projects">Projects</a></li>
        <li aria-current="page">Ada Custom Home and Horse Barn</li>
      </ol>
    </nav>
    <section class="hero">
      <div class="hero-content">
        <h1>Ada Custom Home and Horse Barn — 400A Service</h1>
        <p>
          Ada, MI. A custom home and matching horse barn on the same property, wired with 400A service. Decorative
          lighting in the house, dedicated barn power and stall lighting, and a clean finish across both buildings.
        </p>
        <a
          href="/booking"
          class="btn btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking"
        >
          Get a Clear Estimate
        </a>
      </div>
    </section>

    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127968; Custom Home Experience</span>
          <span class="badge">Clean, Respectful Jobsite Habits</span>
        </div>
      </div>
    </div>

    <section class="container section-pad">
      <h2>Project Snapshot</h2>
      <ul>
        <li><strong>Location:</strong> Ada, MI</li>
        <li><strong>Scope:</strong> Custom home + custom horse barn on the same property</li>
        <li><strong>Service:</strong> 400A</li>
        <li>
          <strong>Systems delivered:</strong> Service distribution, decorative lighting in the home, barn power, horse stall
          lighting, exterior and outbuilding feeders
        </li>
      </ul>

      <h2>What the Customer Needed</h2>
      <p>
        A beautiful custom home paired with a custom horse barn — both wired to a high standard. The house needed
        finished, decorative lighting that matched the architecture. The barn needed practical, code-compliant power and
        lighting that holds up in a working environment with animals, water, and dust around. 400A service was sized to
        support the whole property cleanly, with room for future loads.
      </p>

      <h2>Existing Conditions and Field Constraints</h2>
      <p>
        Custom builds bring real coordination demands: framing schedule, finish trades, mechanical rough-in, and a
        client who's planning long-term. The barn portion adds its own requirements — fixtures rated for damp/dusty
        environments, properly placed receptacles, GFCI/AFCI protection where it matters, and switching that makes sense
        for daily use around horses. The two buildings had to integrate under the same 400A service while keeping the
        panels organized for future maintenance.
      </p>

      <h2>Work Performed</h2>
      <ul>
        <li>400A service installation feeding both the home and the barn</li>
        <li>House: decorative lighting, dimming, and clean finish work</li>
        <li>House: branch circuits, switching, and receptacles for the custom layout</li>
        <li>Barn: dedicated panel and feeder, properly sized for barn loads and future expansion</li>
        <li>Barn: stall lighting designed for daily use and animal welfare</li>
        <li>Barn: receptacles and circuits placed for practical use, with appropriate protection</li>
        <li>Exterior fixtures and pathway/utility lighting between buildings</li>
        <li>Permit and inspection coordination for both buildings</li>
      </ul>

      <h2>Final Result</h2>
      <p>
        A custom home with finished, intentional lighting and a horse barn that's properly powered for the way the owner
        actually uses it. Both buildings on a single 400A service, with panel layouts organized for clean long-term
        operation. Photos below were taken on-site after installation.
      </p>

      <h2>Photos From the Jobsite</h2>
      <div class="gallery-grid">
        {
          projectImages.map((img) => (
            <figure>
              <GalleryThumb
                name={img.src}
                alt={img.alt}
                sizes="(max-width: 600px) 95vw, (max-width: 1024px) 50vw, 33vw"
                width={800}
                height={600}
              />
              <figcaption>{img.caption}</figcaption>
            </figure>
          ))
        }
      </div>

      <h2>Related Services</h2>
      <ul>
        <li><a href="/residential">Residential electrical services</a></li>
        <li><a href="/lighting">Lighting installation</a></li>
        <li><a href="/panel-upgrades">Panel and service upgrades</a></li>
        <li><a href="/dedicated-circuits">Dedicated circuits</a></li>
        <li><a href="/electrical-design-consultation">Electrical design consultation</a></li>
      </ul>
    </section>

    <section class="cta-section">
      <h2>Planning a Custom Home, Barn, or Outbuilding?</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to discuss scope.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking"
      >
        Get a Clear Estimate
      </a>
    </section>
  </main>
</TTELayout>
