---
import TTELayout from '~/layouts/TTELayout.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://toptier-electrical.com/services' },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Energy Consulting',
      item: 'https://toptier-electrical.com/energy-consulting',
    },
  ],
});
---

<TTELayout
  title="Energy Consulting | West Michigan Electrician"
  description="Calm, professional energy consulting to prioritize upgrades, clarify scope, and help you make confident decisions without pressure."
  canonical="https://toptier-electrical.com/energy-consulting"
  jsonLd={[breadcrumbLd]}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/services">Services</a></li>
        <li aria-current="page">Energy Consulting</li>
      </ol>
    </nav>
    <section class="hero">
      <div class="hero-content">
        <h1>Energy Consulting</h1>
        <p>Calm, professional guidance when you want clarity before you spend.</p>
        <a
          href="/booking"
          class="btn btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking">Schedule a Consultation</a
        >
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#128274; Workmanship Guarantee</span>
          <span class="badge">Owner-Operated</span>
          <span class="badge">Clean, Respectful Jobsite Habits</span>
        </div>
      </div>
    </div>
    <section class="service-detail">
      <div class="container">
        <p>
          Sometimes the best value is clarity. Energy consulting is for homeowners and builders who want a calm,
          professional assessment before making decisions.
        </p>
        <div class="proof-chips">
          <span>Priority-based planning</span>
          <span>Clear scope guidance</span>
          <span>Future-ready recommendations</span>
        </div>
        <h2>What You Get</h2>
        <ul>
          <li>A walkthrough focused on your priorities (comfort, cost control, future readiness)</li>
          <li>A shortlist of improvements with tradeoffs</li>
          <li>Clear sequencing (what to do now vs later)</li>
          <li>A scope you can act on—without guesswork</li>
        </ul>
        <h2>Pricing Factors</h2>
        <ul>
          <li>Size of the home or facility</li>
          <li>Number of systems to evaluate</li>
          <li>Depth of load planning required</li>
          <li>Documentation or reporting needs</li>
        </ul>
        <h2>How We Work</h2>
        <ol>
          <li>Walkthrough — Gather goals, constraints, and future plans.</li>
          <li>Plan — Provide practical options and priorities.</li>
          <li>Execute — If you choose to move forward, work is completed cleanly and code-compliantly.</li>
          <li>Verify — Confirm results and document what was done.</li>
        </ol>
        <h2>Energy Consulting FAQs</h2>
        <div class="faq-grid">
          <div class="faq-item">
            <h3>When should I book consulting first?</h3>
            <p>Before remodels, EV upgrades, or major equipment changes when you need a clear electrical plan.</p>
          </div>
          <div class="faq-item">
            <h3>What deliverables do I receive?</h3>
            <p>You get practical recommendations, sequencing guidance, and a scoped roadmap for next steps.</p>
          </div>
          <div class="faq-item">
            <h3>Can consulting reduce project change orders?</h3>
            <p>Yes. Planning upfront helps uncover constraints early and reduces costly mid-project changes.</p>
          </div>
          <div class="faq-item">
            <h3>Do you consult for both homes and light commercial projects?</h3>
            <p>Yes. We support residential and light commercial projects throughout West Michigan.</p>
          </div>
        </div>
        <h2>Next Step</h2>
        <p>If you want a plan you can trust—without pressure—schedule an energy consultation.</p>
      </div>
    </section>
    <section class="cta-section">
      <h2>Ready for Clarity?</h2>
      <p>
        Call us at <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to schedule a consultation.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Schedule a Consultation</a
      >
    </section>
  </main>
</TTELayout>
