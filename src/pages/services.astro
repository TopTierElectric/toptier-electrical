---
import TTELayout from '~/layouts/TTELayout.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://toptier-electrical.com/services' },
  ],
});
---

<TTELayout
  title="Electrical Services in West Michigan | Top Tier Electrical"
  description="Licensed electrician in West Michigan: panel upgrades, EV chargers, repairs, lighting, and generators with clear scope and clean installs."
  canonical="https://toptier-electrical.com/services"
  ogImage="https://toptier-electrical.com/images/og/pages/services.png"
  jsonLd={[breadcrumbLd]}
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Electrical Services</h1>
        <p>Complete residential and light commercial electrical services in West Michigan.</p>
        <a
          href="/booking"
          class="btn btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking">Get a Clear Estimate</a
        >
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#128274; Workmanship Guarantee</span>
          <span class="badge">Owner-Operated</span>
        </div>
      </div>
    </div>
    <section class="container section-pad">
      <h2>Services Overview</h2>
      <div class="service-cards">
        <a href="/panel-upgrades" class="service-card">
          <h3>Panel Upgrades &amp; Service Upgrades</h3>
          <p>Clean, code-compliant panel replacements and service corrections for modern electrical demands.</p>
        </a>
        <a href="/ev-chargers" class="service-card">
          <h3>EV Charger Installation</h3>
          <p>Level 2 EV charger installation with capacity checks and permit coordination.</p>
        </a>
        <a href="/lighting" class="service-card">
          <h3>Lighting &amp; Fixtures</h3>
          <p>Indoor and outdoor lighting with dimmers, smart controls, and premium finish work.</p>
        </a>
        <a href="/electrical-repairs" class="service-card">
          <h3>Electrical Repairs &amp; Troubleshooting</h3>
          <p>Systematic diagnosis and reliable repair of electrical faults.</p>
        </a>
        <a href="/generators" class="service-card">
          <h3>Generator Installation</h3>
          <p>Backup power systems sized correctly and installed safely with transfer switch expertise.</p>
        </a>
        <a href="/energy-solutions" class="service-card">
          <h3>Energy Solutions</h3>
          <p>Practical energy upgrades—LED, controls, and load planning for efficiency.</p>
        </a>
        <a href="/energy-consulting" class="service-card">
          <h3>Energy Consulting</h3>
          <p>Professional guidance before major upgrades with no-pressure scope clarity.</p>
        </a>
        <a href="/emergency" class="service-card">
          <h3>Emergency Electrical Services</h3>
          <p>Urgent electrical response with safe next-step guidance when you need help now.</p>
        </a>
      </div>
    </section>
    <section class="container section-pad-bottom">
      <h2>Residential vs. Commercial</h2>
      <div class="service-cards">
        <a href="/residential" class="service-card">
          <h3>Residential Services</h3>
          <p>Panel upgrades, EV chargers, lighting, and repairs for West Michigan homes.</p>
        </a>
        <a href="/commercial" class="service-card">
          <h3>Commercial Services</h3>
          <p>Service corrections, LED retrofits, and commercial electrical for businesses.</p>
        </a>
      </div>
    </section>
    <section class="cta-section">
      <h2>Confirm Your Project Scope</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to discuss your project.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
