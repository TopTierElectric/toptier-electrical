---
import SiteRewriteLayout from '~/layouts/SiteRewriteLayout.astro';
---

<SiteRewriteLayout
  title="Electrical Services | Top Tier Electrical"
  description="Explore Top Tier Electrical services including panel upgrades, EV chargers, repairs, and lighting."
  canonical="https://codex-task-title-n560vp.toptier-electrical.pages.dev/services"
>
  <main class="container" role="main">
    <section aria-labelledby="services-heading">
      <h1 id="services-heading">Electrical Services</h1>
      <p class="content">Residential and light commercial electrical services across West Michigan.</p>
      <div class="card-grid" role="list">
        <article class="card" role="listitem">
          <h3>Panel Upgrades</h3><p>Panel replacements and capacity upgrades.</p>
        </article>
        <article class="card" role="listitem">
          <h3>EV Charger Installation</h3><p>Level 2 EV charging with dedicated circuits.</p>
        </article>
        <article class="card" role="listitem">
          <h3>Lighting &amp; Fixtures</h3><p>Interior and exterior fixture installation.</p>
        </article>
        <article class="card" role="listitem">
          <h3>Troubleshooting &amp; Repairs</h3><p>Diagnostics and repair of common electrical issues.</p>
        </article>
        <article class="card" role="listitem">
          <h3>Generator Readiness</h3><p>Transfer switch planning and backup power setup.</p>
        </article>
        <article class="card" role="listitem">
          <h3>Code Corrections</h3><p>Safety-first corrections to improve reliability and compliance.</p>
        </article>
      </div>
    </section>
  </main>
</SiteRewriteLayout>
