---
import TTELayout from '~/layouts/TTELayout.astro';
import { glossary, glossaryBySlug } from '~/data/glossary';

export const prerender = true;

export async function getStaticPaths() {
  return glossary.map((entry) => ({ params: { term: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const canonical = `https://www.toptier-electrical.com/glossary/${entry.slug}`;
const ogImage = 'https://www.toptier-electrical.com/images/og/pages/gallery.png';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Glossary', item: 'https://www.toptier-electrical.com/glossary' },
    { '@type': 'ListItem', position: 3, name: entry.term, item: canonical },
  ],
});

const definedTermLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  '@id': `${canonical}#term`,
  name: entry.term,
  alternateName: entry.abbreviation,
  description: entry.shortDef,
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    '@id': 'https://www.toptier-electrical.com/glossary#set',
    name: 'Top Tier Electrical Glossary',
  },
  url: canonical,
});

const speakableLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonical}#speakable`,
  speakable: { '@type': 'SpeakableSpecification', cssSelector: ['h1', '.short-def'] },
  url: canonical,
});

const relatedPostsData = (entry.relatedPosts ?? []).map((slug) => ({
  href: `/blog/${slug}`,
  // crude humanization for the anchor — real titles live in MDX frontmatter
  title: slug.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()),
}));
const relatedTermsData = (entry.relatedTerms ?? [])
  .map((slug) => glossaryBySlug[slug])
  .filter(Boolean);

const paragraphs = entry.body.split(/\n\n+/);
---

<TTELayout
  title={`${entry.term} | Top Tier Electrical Glossary`}
  description={entry.shortDef.slice(0, 158)}
  canonical={canonical}
  ogType="article"
  ogImage={ogImage}
  jsonLd={[breadcrumbLd, definedTermLd, speakableLd]}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/glossary">Glossary</a></li>
        <li aria-current="page">{entry.term}</li>
      </ol>
    </nav>
    <section class="hero">
      <div class="hero-content">
        <h1>{entry.term}</h1>
        <p class="short-def">{entry.shortDef}</p>
      </div>
    </section>
    <article class="container section-pad" style="max-width: 760px;">
      {paragraphs.map((p) => <p set:html={p.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')} />)}

      {
        relatedTermsData.length > 0 && (
          <section class="section-pad">
            <h2>Related Terms</h2>
            <ul>
              {relatedTermsData.map((t) => (
                <li>
                  <a href={`/glossary/${t.slug}`}>{t.term}</a> — {t.shortDef}
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        relatedPostsData.length > 0 && (
          <section class="section-pad">
            <h2>Deeper Reading</h2>
            <ul>
              {relatedPostsData.map((p) => (
                <li>
                  <a href={p.href}>{p.title}</a>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        entry.relatedServices && entry.relatedServices.length > 0 && (
          <section class="section-pad">
            <h2>Related Services</h2>
            <ul>
              {entry.relatedServices.map((s) => (
                <li>
                  <a href={s.href}>{s.label}</a>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </article>
    <section class="cta-section">
      <h2>Have a Question About {entry.term}?</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        >.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
