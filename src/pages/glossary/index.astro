---
import TTELayout from '~/layouts/TTELayout.astro';
import { glossary } from '~/data/glossary';

const canonical = 'https://www.toptier-electrical.com/glossary';
const ogImage = 'https://www.toptier-electrical.com/images/og/pages/gallery.png';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Glossary', item: canonical },
  ],
});

const termSetLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  '@id': `${canonical}#set`,
  name: 'Top Tier Electrical Glossary',
  description: 'Definitions of electrical terms, codes, and concepts referenced across the Top Tier Electrical site.',
  url: canonical,
  hasDefinedTerm: glossary.map((e) => ({
    '@type': 'DefinedTerm',
    '@id': `${canonical}/${e.slug}#term`,
    name: e.term,
    url: `${canonical}/${e.slug}`,
  })),
});
---

<TTELayout
  title="Electrical Glossary | Top Tier Electrical"
  description="Definitions of electrical terms, NEC code sections, and concepts referenced across the Top Tier Electrical site."
  canonical={canonical}
  ogImage={ogImage}
  jsonLd={[breadcrumbLd, termSetLd]}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li aria-current="page">Glossary</li>
      </ol>
    </nav>
    <section class="hero">
      <div class="hero-content">
        <h1>Electrical Glossary</h1>
        <p>
          Short, plain-English definitions of the electrical terms, NEC code sections, and concepts we reference across
          the site.
        </p>
      </div>
    </section>
    <section class="container section-pad" style="max-width: 860px;">
      <ul style="list-style: none; padding: 0;">
        {
          glossary.map((entry) => (
            <li style="margin-bottom: 1.5rem;">
              <h2 style="margin-bottom: 0.25rem;">
                <a href={`/glossary/${entry.slug}`}>{entry.term}</a>
              </h2>
              <p style="margin: 0;">{entry.shortDef}</p>
            </li>
          ))
        }
      </ul>
    </section>
    <section class="cta-section">
      <h2>Have a Question?</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        >.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
