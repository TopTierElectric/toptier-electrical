---
import SiteRewriteLayout from '~/layouts/SiteRewriteLayout.astro';
---

<SiteRewriteLayout
  title="Contact | Top Tier Electrical"
  description="Contact Top Tier Electrical by phone, email, or form for electrical service in West Michigan."
  canonical="https://codex-task-title-n560vp.toptier-electrical.pages.dev/contact"
>
  <main class="container" role="main">
    <section class="two-column" aria-labelledby="contact-heading">
      <div>
        <h1 id="contact-heading">Contact</h1>
        <p><a href="tel:+16163347159">(616) 334‑7159</a></p>
        <p><a href="mailto:info@toptier-electrical.com">info@toptier-electrical.com</a></p>
      </div>
      <form name="contact" method="post" action="/thank-you">
        <div><label for="name">Name</label><input id="name" name="name" required /></div>
        <div><label for="email">Email</label><input id="email" name="email" type="email" required /></div>
        <div><label for="phone">Phone</label><input id="phone" name="phone" type="tel" /></div>
        <div><label for="message">Message</label><textarea id="message" name="message" required></textarea></div>
        <button class="btn-primary" type="submit">Send Message</button>
      </form>
    </section>
  </main>
</SiteRewriteLayout>
