---
import TTELayout from '~/layouts/TTELayout.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://toptier-electrical.com/contact' },
  ],
});

const contactPageLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Top Tier Electrical',
  url: 'https://toptier-electrical.com/contact',
  mainEntity: {
    '@type': 'Electrician',
    '@id': 'https://toptier-electrical.com/#localbusiness',
    name: 'Top Tier Electrical',
    telephone: '+1-616-334-7159',
    email: 'info@toptier-electrical.com',
    areaServed: 'West Michigan',
  },
});
---

<TTELayout
  title="Contact a West Michigan Electrician | Call, Text, or Book Online"
  description="Contact Top Tier Electrical in West Michigan. Call, text, or request scheduling for panel, lighting, EV charger, and repair projects."
  canonical="https://toptier-electrical.com/contact"
  ogImage="https://toptier-electrical.com/images/og/pages/contact.png"
  jsonLd={[breadcrumbLd, contactPageLd]}
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Contact Us</h1>
        <p>We're here to help with all your electrical needs—get in touch today.</p>
        <a
          href="/booking"
          class="btn btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking">Get a Clear Estimate</a
        >
      </div>
    </section>
    <section class="trust-strip">
      <div class="container">
        <div class="trust-items">
          <div class="trust-item"><span class="trust-icon">&#9733;</span><span>Licensed &amp; Insured</span></div>
          <div class="trust-item"><span class="trust-icon">&#10003;</span><span>Clear scope before work</span></div>
          <div class="trust-item"><span class="trust-icon">&#9201;</span><span>Clean, careful installations</span></div>
          <div class="trust-item"><span class="trust-icon">&#9733;</span><span>Local West Michigan team</span></div>
        </div>
      </div>
    </section>
    <section class="contact-page">
      <div class="container">
        <h2>Get in Touch</h2>
        <div class="contact-grid">
          <div class="contact-info">
            <h3>Contact Details</h3>
            <p><strong>Phone:</strong> <a href="tel:+16163347159">(616) 334-7159</a></p>
            <p><strong>Text:</strong> <a href="sms:+16163347159">(616) 334-7159</a></p>
            <p><strong>Email:</strong> <a href="mailto:info@toptier-electrical.com">info@toptier-electrical.com</a></p>
            <p>
              <strong>Service Area:</strong> Holland, Grand Rapids, Byron Center, Zeeland, Saugatuck, Douglas, Hudsonville,
              Jamestown, Allegan
            </p>
            <p><strong>Hours:</strong> Mon–Fri 8am–6pm · Sat 9am–1pm</p>
            <p><strong>Response time:</strong> within 1 business day.</p>
            <p><a href="/gallery" class="btn btn-secondary">View Our Work</a></p>
          </div>
          <div class="contact-form">
            <h3>Send a Message</h3>
            <p>
              If you'd like to pick a specific date and time, please use our <a href="/booking">online booking form</a>.
            </p>
            <form name="contact" method="POST" action="/api/contact" novalidate data-enhanced-form>
              <input type="hidden" name="form_name" value="Contact form" />
              <input
                class="form-honeypot"
                type="text"
                name="_gotcha"
                aria-label="Leave this field blank"
                tabindex="-1"
                autocomplete="off"
              />
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required autocomplete="name" />
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required autocomplete="email" />
              <label for="phone">Phone</label>
              <input type="tel" id="phone" name="phone" required autocomplete="tel" />
              <label for="service-type">Service Type</label>
              <select id="service-type" name="service_type" required autocomplete="off">
                <option value="" disabled selected>Select a service</option>
                <option value="Panel Upgrade">Panel Upgrade</option>
                <option value="EV Charger Installation">EV Charger Installation</option>
                <option value="Lighting & Fixtures">Lighting & Fixtures</option>
                <option value="Electrical Repairs">Electrical Repairs</option>
                <option value="Generator Installation">Generator Installation</option>
                <option value="Other">Other</option>
              </select>
              <label for="city">City</label>
              <input type="text" id="city" name="city" required autocomplete="address-level2" />
              <label for="message">Message</label>
              <textarea id="message" name="message" required autocomplete="off"></textarea>
              <label class="checkbox-row" for="contact-permission">
                <input type="checkbox" id="contact-permission" name="contact_permission" required />
                I give permission to be contacted about this request.
              </label>
              <button type="submit" data-cta="contact-request-quote" data-submit-label="Request a Quote"
                >Request a Quote</button
              >
              <p class="form-status" data-form-status aria-live="polite"></p>
              <p class="form-fallback">
                If the form does not load, call (616) 334-7159 or email info@toptier-electrical.com.
              </p>
            </form>
          </div>
        </div>
      </div>
      <div class="map">
        <iframe
          title="Service area map"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3023.8522097766887!2d-86.10893358459578!3d42.7875!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8819d2a2879d1543%3A0x3a5e2b1a811d873d!2sHolland%2C%20MI%2049423%2C%20USA!5e0!3m2!1sen!2sus!4v1692300000000!5m2!1sen!2sus"
          width="100%"
          height="450"
          class="border-0"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </section>
    <section class="cta-section">
      <h2>Need Service?</h2>
      <p>
        Call us at <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > and we'll confirm next steps.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
