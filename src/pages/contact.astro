---
import TTELayout from '~/layouts/TTELayout.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    {'@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://toptier-electrical.com/'},
    {'@type': 'ListItem', 'position': 2, 'name': 'Contact', 'item': 'https://toptier-electrical.com/contact'},
  ],
});
---

<TTELayout
  title="Contact Top Tier Electrical | West Michigan Electrician"
  description="Call or email Top Tier Electrical for service in West Michigan. Share project details or request scheduling to confirm next steps."
  canonical="https://toptier-electrical.com/contact"
  jsonLd={[breadcrumbLd]}
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Contact Us</h1>
        <p>We're here to help with all your electrical needs—get in touch today.</p>
        <a href="/booking" class="btn-primary">Request Scheduling</a>
      </div>
    </section>
    <section class="trust-strip">
      <div class="container">
        <div class="trust-items">
          <div class="trust-item"><span class="trust-icon">&#9733;</span><span>Licensed &amp; Insured</span></div>
          <div class="trust-item"><span class="trust-icon">&#10003;</span><span>Clear scope before work</span></div>
          <div class="trust-item"><span class="trust-icon">&#9201;</span><span>Clean, careful installations</span></div>
          <div class="trust-item"><span class="trust-icon">&#9733;</span><span>Local West Michigan team</span></div>
        </div>
      </div>
    </section>
    <section class="contact-page">
      <div class="container">
        <h2>Get in Touch</h2>
        <div class="contact-grid">
          <div class="contact-info">
            <h3>Contact Details</h3>
            <p><strong>Phone:</strong> <a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a></p>
            <p><strong>Text:</strong> <a href="sms:+16163347159">(616)&nbsp;334&#8209;7159</a></p>
            <p><strong>Email:</strong> <a href="mailto:info@toptier-electrical.com">info@toptier-electrical.com</a></p>
            <p>
              <strong>Service Area:</strong> Holland, Grand Rapids, Byron Center, Zeeland, Saugatuck, Douglas, Hudsonville,
              Jamestown, Allegan
            </p>
            <p><strong>Hours:</strong> Mon–Fri 8am–6pm · Sat 9am–1pm</p>
            <p><strong>Response time:</strong> within 1 business day.</p>
            <p><a href="/gallery" class="btn-secondary">View Our Work</a></p>
          </div>
          <div class="contact-form">
            <h3>Send a Message</h3>
            <p>
              If you'd like to pick a specific date and time, please use our <a href="/booking">online booking form</a>.
            </p>
            <form id="contact-form" name="contact" method="POST" action="https://formspree.io/f/mkovbvgj" novalidate>
              <div id="contact-status" role="status" aria-live="polite" class="form-status" hidden></div>
              <input type="hidden" name="_subject" value="New contact request from Top Tier Electrical" />
              <input type="hidden" name="_next" value="https://toptier-electrical.com/thank-you" />
              <input type="hidden" name="form_name" value="Contact form" />
              <input
                class="form-honeypot"
                type="text"
                name="_gotcha"
                aria-label="Leave this field blank"
                tabindex="-1"
                autocomplete="off"
                aria-hidden="true"
              />
              <label for="name">Name <span aria-hidden="true">*</span></label>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                aria-required="true"
                aria-describedby="name-error"
              />
              <span id="name-error" class="form-field-error" role="alert" hidden>Please enter your name.</span>
              <label for="email">Email <span aria-hidden="true">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                aria-required="true"
                aria-describedby="email-error"
              />
              <span id="email-error" class="form-field-error" role="alert" hidden
                >Please enter a valid email address.</span
              >
              <label for="phone">Phone <span aria-hidden="true">*</span></label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                autocomplete="tel"
                aria-required="true"
                aria-describedby="phone-error"
              />
              <span id="phone-error" class="form-field-error" role="alert" hidden
                >Please enter your phone number.</span
              >
              <label for="message">Message <span aria-hidden="true">*</span></label>
              <textarea
                id="message"
                name="message"
                required
                autocomplete="off"
                aria-required="true"
                aria-describedby="message-error"></textarea>
              <span id="message-error" class="form-field-error" role="alert" hidden>Please enter a message.</span>
              <button type="submit" id="contact-submit" data-cta="contact-request-quote">Request a Quote</button>
            </form>
            <style>
              .form-status {
                padding: 0.75rem 1rem;
                border-radius: 6px;
                margin-bottom: 1rem;
                font-weight: 500;
              }
              .form-status.success {
                background: #dcfce7;
                color: #15803d;
                border: 1px solid #86efac;
              }
              .form-status.error {
                background: #fee2e2;
                color: #b91c1c;
                border: 1px solid #fca5a5;
              }
              .form-field-error {
                color: #b91c1c;
                font-size: 0.875rem;
                display: block;
                margin-top: -0.5rem;
                margin-bottom: 0.5rem;
              }
              button[disabled] {
                opacity: 0.6;
                cursor: not-allowed;
              }
            </style>
            <script is:inline>
              (function () {
                var form = document.getElementById('contact-form');
                var submitBtn = document.getElementById('contact-submit');
                var statusEl = document.getElementById('contact-status');
                if (!form) return;

                function showFieldError(inputId, show) {
                  var errEl = document.getElementById(inputId + '-error');
                  if (!errEl) return;
                  errEl.hidden = !show;
                  var input = document.getElementById(inputId);
                  if (input) input.setAttribute('aria-invalid', show ? 'true' : 'false');
                }

                function validateField(input) {
                  return input.checkValidity();
                }

                var fields = ['name', 'email', 'phone', 'message'];
                fields.forEach(function (id) {
                  var el = document.getElementById(id);
                  if (!el) return;
                  el.addEventListener('blur', function () {
                    showFieldError(id, !validateField(el));
                  });
                  el.addEventListener('input', function () {
                    if (el.getAttribute('aria-invalid') === 'true') {
                      showFieldError(id, !validateField(el));
                    }
                  });
                });

                form.addEventListener('submit', function (e) {
                  var valid = true;
                  fields.forEach(function (id) {
                    var el = document.getElementById(id);
                    if (!el) return;
                    var fieldValid = validateField(el);
                    showFieldError(id, !fieldValid);
                    if (!fieldValid) valid = false;
                  });

                  if (!valid) {
                    e.preventDefault();
                    statusEl.textContent = 'Please fix the errors above before submitting.';
                    statusEl.className = 'form-status error';
                    statusEl.hidden = false;
                    var firstErr = form.querySelector('[aria-invalid="true"]');
                    if (firstErr) firstErr.focus();
                    return;
                  }

                  submitBtn.disabled = true;
                  submitBtn.textContent = 'Sending…';
                  statusEl.hidden = true;
                });
              })();
            </script>
          </div>
        </div>
      </div>
      <div class="map">
        <iframe
          title="Service area map"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3023.8522097766887!2d-86.10893358459578!3d42.7875!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8819d2a2879d1543%3A0x3a5e2b1a811d873d!2sHolland%2C%20MI%2049423%2C%20USA!5e0!3m2!1sen!2sus!4v1692300000000!5m2!1sen!2sus"
          width="100%"
          height="450"
          style="border: 0"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </section>
    <section class="cta-section">
      <h2>Need Service?</h2>
      <p>
        Call us at <a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a> or email <a
          href="mailto:info@toptier-electrical.com">info@toptier-electrical.com</a
        > and we'll confirm next steps.
      </p>
      <a href="/booking" class="btn-primary">Request Scheduling</a>
    </section>
  </main>
</TTELayout>
