---
import TTELayout from '~/layouts/TTELayout.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    {'@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://toptier-electrical.com/'},
    {'@type': 'ListItem', 'position': 2, 'name': 'Request Scheduling', 'item': 'https://toptier-electrical.com/booking'},
  ],
});
---

<TTELayout
  title="Book Electrical Service | Top Tier Electrical"
  description="Schedule electrical service in West Michigan. Choose a service, preferred date, and time, and we'll confirm the scope and next steps."
  canonical="https://toptier-electrical.com/booking"
  jsonLd={[breadcrumbLd]}
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Schedule Your Service</h1>
        <p>Submit a request—I'll confirm scope and timing within 1 business day.</p>
        <a href="tel:+16163347159" class="btn-secondary">Or Call Now</a>
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">&#128295; Code-aware workmanship</span>
          <span class="badge">&#128274; Clean, careful installations</span>
          <span class="badge">&#127968; Local West Michigan team</span>
        </div>
      </div>
    </div>
    <section class="contact-page">
      <div class="container">
        <h2>Book an Appointment</h2>
        <div class="contact-grid">
          <div class="contact-info">
            <h3>What Happens Next</h3>
            <ol class="next-steps">
              <li>We review your details and confirm the best time.</li>
              <li>You receive a clear scope and scheduling options.</li>
              <li>We arrive on schedule and walk you through the completed work.</li>
            </ol>
            <p class="response-note"><strong>Response time:</strong> within 1 business day.</p>
            <p>If you're unsure which service you need or have questions about booking, call or text us anytime.</p>
            <p><strong>Phone:</strong> <a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a></p>
            <p><strong>Text:</strong> <a href="sms:+16163347159">(616)&nbsp;334&#8209;7159</a></p>
            <p><strong>Email:</strong> <a href="mailto:info@toptier-electrical.com">info@toptier-electrical.com</a></p>
          </div>
          <div class="contact-form">
            <h3>Service Booking Form</h3>
            <form
              id="booking-form"
              name="booking"
              method="POST"
              action="https://formspree.io/f/mkovbvgj"
              novalidate
            >
              <div id="booking-status" role="status" aria-live="polite" class="form-status" hidden></div>
              <input type="hidden" name="_subject" value="New booking request from Top Tier Electrical" />
              <input type="hidden" name="_next" value="https://toptier-electrical.com/thank-you" />
              <input type="hidden" name="form_name" value="Booking form" />
              <input
                class="form-honeypot"
                type="text"
                name="_gotcha"
                aria-label="Leave this field blank"
                tabindex="-1"
                autocomplete="off"
                aria-hidden="true"
              />
              <label for="book-name">Name <span aria-hidden="true">*</span></label>
              <input
                type="text"
                id="book-name"
                name="name"
                required
                autocomplete="name"
                aria-required="true"
                aria-describedby="book-name-error"
              />
              <span id="book-name-error" class="form-field-error" role="alert" hidden>Please enter your name.</span>
              <label for="book-email">Email <span aria-hidden="true">*</span></label>
              <input
                type="email"
                id="book-email"
                name="email"
                required
                autocomplete="email"
                aria-required="true"
                aria-describedby="book-email-error"
              />
              <span id="book-email-error" class="form-field-error" role="alert" hidden
                >Please enter a valid email address.</span
              >
              <label for="book-phone">Phone <span aria-hidden="true">*</span></label>
              <input
                type="tel"
                id="book-phone"
                name="phone"
                required
                autocomplete="tel"
                aria-required="true"
                aria-describedby="book-phone-error"
              />
              <span id="book-phone-error" class="form-field-error" role="alert" hidden
                >Please enter your phone number.</span
              >
              <label for="book-service">Service <span aria-hidden="true">*</span></label>
              <select
                id="book-service"
                name="service"
                required
                aria-required="true"
                aria-describedby="book-service-error"
              >
                <option value="" disabled selected>Select a service</option>
                <option value="Panel Upgrade">Panel Upgrade</option>
                <option value="EV Charger Installation">EV Charger Installation</option>
                <option value="Lighting & Fixtures">Lighting &amp; Fixtures</option>
                <option value="Electrical Repairs & Troubleshooting">Electrical Repairs &amp; Troubleshooting</option>
                <option value="Generator Installation">Generator Installation</option>
                <option value="Energy Solutions">Energy Solutions</option>
                <option value="Energy Consulting">Energy Consulting</option>
                <option value="Emergency Service">Emergency Service</option>
              </select>
              <span id="book-service-error" class="form-field-error" role="alert" hidden>Please select a service.</span>
              <label for="book-date">Preferred Date <span aria-hidden="true">*</span></label>
              <input
                type="date"
                id="book-date"
                name="date"
                required
                autocomplete="off"
                aria-required="true"
                aria-describedby="book-date-error"
              />
              <span id="book-date-error" class="form-field-error" role="alert" hidden>Please select a preferred date.</span>
              <label for="book-time">Preferred Time <span aria-hidden="true">*</span></label>
              <input
                type="time"
                id="book-time"
                name="time"
                required
                autocomplete="off"
                aria-required="true"
                aria-describedby="book-time-error"
              />
              <span id="book-time-error" class="form-field-error" role="alert" hidden>Please select a preferred time.</span>
              <label for="book-notes">Additional Notes</label>
              <textarea id="book-notes" name="notes" placeholder="Describe your project or any special requirements"
              ></textarea>
              <button type="submit" id="booking-submit" data-cta="booking-schedule-service">Request Scheduling</button>
              <p class="form-confirmation">
                After submitting, we'll confirm details and send next steps by phone or email.
              </p>
            </form>
            <style>
              .form-status {
                padding: 0.75rem 1rem;
                border-radius: 6px;
                margin-bottom: 1rem;
                font-weight: 500;
              }
              .form-status.success {
                background: #dcfce7;
                color: #15803d;
                border: 1px solid #86efac;
              }
              .form-status.error {
                background: #fee2e2;
                color: #b91c1c;
                border: 1px solid #fca5a5;
              }
              .form-field-error {
                color: #b91c1c;
                font-size: 0.875rem;
                display: block;
                margin-top: -0.5rem;
                margin-bottom: 0.5rem;
              }
              button[disabled] {
                opacity: 0.6;
                cursor: not-allowed;
              }
            </style>
            <script is:inline>
              (function () {
                var form = document.getElementById('booking-form');
                var submitBtn = document.getElementById('booking-submit');
                var statusEl = document.getElementById('booking-status');
                if (!form) return;

                function showFieldError(inputId, show) {
                  var errEl = document.getElementById(inputId + '-error');
                  if (!errEl) return;
                  errEl.hidden = !show;
                  var input = document.getElementById(inputId);
                  if (input) input.setAttribute('aria-invalid', show ? 'true' : 'false');
                }

                function validateField(input) {
                  return input.checkValidity();
                }

                var fields = ['book-name', 'book-email', 'book-phone', 'book-service', 'book-date', 'book-time'];
                fields.forEach(function (id) {
                  var el = document.getElementById(id);
                  if (!el) return;
                  el.addEventListener('blur', function () {
                    showFieldError(id, !validateField(el));
                  });
                  el.addEventListener('input', function () {
                    if (el.getAttribute('aria-invalid') === 'true') {
                      showFieldError(id, !validateField(el));
                    }
                  });
                });

                form.addEventListener('submit', function (e) {
                  var valid = true;
                  fields.forEach(function (id) {
                    var el = document.getElementById(id);
                    if (!el) return;
                    var fieldValid = validateField(el);
                    showFieldError(id, !fieldValid);
                    if (!fieldValid) valid = false;
                  });

                  if (!valid) {
                    e.preventDefault();
                    statusEl.textContent = 'Please fix the errors above before submitting.';
                    statusEl.className = 'form-status error';
                    statusEl.hidden = false;
                    var firstErr = form.querySelector('[aria-invalid="true"]');
                    if (firstErr) firstErr.focus();
                    return;
                  }

                  submitBtn.disabled = true;
                  submitBtn.textContent = 'Sending…';
                  statusEl.hidden = true;
                });
              })();
            </script>
          </div>
        </div>
      </div>
    </section>
    <section class="cta-section">
      <h2>Need Help Right Away?</h2>
      <p>
        For urgent electrical issues, call <a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a> to confirm next steps.
      </p>
      <a href="tel:+16163347159" class="btn-primary">Call Now</a>
    </section>
  </main>
</TTELayout>
