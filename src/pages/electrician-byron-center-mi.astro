---
import LocationServicePage from '~/components/pages/LocationServicePage.astro';
import GalleryThumb from '~/components/GalleryThumb.astro';
---

<LocationServicePage city="Byron Center" slug="electrician-byron-center-mi">
  <section class="container section-pad-tight">
    <h2>Recent Work in Byron Center</h2>
    <div class="proof-grid">
      <figure class="proof-card">
        <GalleryThumb
          name="Meter Socket Bank"
          alt="Byron Center, MI 4-meter multi-unit residential meter socket bank installation"
          sizes="(max-width: 600px) 95vw, 50vw"
          width={400}
          height={300}
        />
        <figcaption>Byron Center — 4-meter multi-unit service.</figcaption>
      </figure>
    </div>
  </section>
</LocationServicePage>
