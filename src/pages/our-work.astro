---
import SiteRewriteLayout from '~/layouts/SiteRewriteLayout.astro';

const images = [
  ['Residential Panel.webp', 'Residential panel upgrade with labeled circuits'],
  ['Control Cabinet.webp', 'Commercial control cabinet installation'],
  ['Panel Work.webp', 'Panel work detail with clean routing'],
  ['Exterior Light Fixtures.webp', 'Exterior light fixture installation'],
  ['Motor Control.webp', 'Motor control installation'],
  ['Transformer.webp', 'Transformer installation with organized conduit'],
];
---

<SiteRewriteLayout
  title="Our Work | Top Tier Electrical"
  description="View recent Top Tier Electrical project work across residential and light commercial installs in West Michigan."
  canonical="https://codex-task-title-n560vp.toptier-electrical.pages.dev/our-work"
>
  <main class="container" role="main">
    <section aria-labelledby="work-heading">
      <h1 id="work-heading">Our Work</h1>
      <div class="gallery-grid">
        {
          images.map(([name, alt]) => (
            <figure>
              <div class="img-card">
                <picture>
                  <source
                    type="image/webp"
                    srcset={`/images/gallery/${name} 400w, /images/gallery/${name} 800w`}
                    sizes="(max-width:600px) 100vw, (max-width:900px) 50vw, 400px"
                  />
                  <img
                    src={`/images/gallery/${name}`}
                    srcset={`/images/gallery/${name} 400w, /images/gallery/${name} 800w`}
                    sizes="(max-width:600px) 100vw, (max-width:900px) 50vw, 400px"
                    width="1200"
                    height="800"
                    alt={alt}
                    loading="lazy"
                    decoding="async"
                  />
                </picture>
              </div>
              <figcaption>{alt}</figcaption>
            </figure>
          ))
        }
      </div>
    </section>
  </main>
</SiteRewriteLayout>
