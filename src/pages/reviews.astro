    <style>
      .ct-testimonials {
        --ct-max: 1100px;
        --ct-gap: 16px;
        --ct-radius: 12px;
        --ct-border: rgba(0, 0, 0, 0.12);
        --ct-muted: rgba(0, 0, 0, 0.7);
        --ct-bg: #ffffff;
        padding: 28px 16px;
      }
      .ct-testimonials__inner {
        max-width: var(--ct-max);
        margin: 0 auto;
      }
      .ct-testimonials__header {
        margin-bottom: 14px;
      }
      .ct-testimonials__title {
        margin: 0 0 6px 0;
        font-size: 24px;
        line-height: 1.2;
      }
      .ct-testimonials__subtitle {
        margin: 0;
        color: var(--ct-muted);
        line-height: 1.4;
      }
      .ct-testimonials__grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: var(--ct-gap);
        margin-top: 16px;
      }
      .ct-review {
        margin: 0;
        background: var(--ct-bg);
        border: 1px solid var(--ct-border);
        border-radius: var(--ct-radius);
        padding: 16px;
      }
      .ct-review__top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 10px;
      }
      .ct-review__stars {
        letter-spacing: 1px;
        font-size: 16px;
        line-height: 1;
        white-space: nowrap;
      }
      .ct-review__chips {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        justify-content: flex-end;
      }
      .ct-chip {
        font-size: 12px;
        line-height: 1;
        padding: 6px 8px;
        border-radius: 999px;
        border: 1px solid var(--ct-border);
        color: var(--ct-muted);
        white-space: nowrap;
      }
      .ct-review__quote {
        margin: 0 0 12px 0;
        line-height: 1.5;
      }
      .ct-review__byline {
        margin: 0;
        color: var(--ct-muted);
        font-size: 14px;
        line-height: 1.3;
      }
      .ct-review__meta {
        opacity: 0.85;
      }
    </style>
    <section class="cta-section">
      <h2>Ready to Work with a Trusted Electrician?</h2>
      <p>
        Call <a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a> or <a href="/booking">request scheduling</a> to confirm
        scope and next steps.
      </p>
      <a href="/booking" class="btn-primary">Request Scheduling</a>
    </section>
  </main>
</TTELayout>
