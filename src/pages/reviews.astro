---
import TTELayout from '~/layouts/TTELayout.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Reviews', item: 'https://toptier-electrical.com/reviews' },
  ],
});

const aggregateRatingLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://toptier-electrical.com/#electrician',
  name: 'Top Tier Electrical',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5.0',
    reviewCount: '10',
    bestRating: '5',
  },
  review: [
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Colten DeHaan' },
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      reviewBody:
        'Carl was great to work with! Super detailed and thoughtful of how to future proof thing to avoid problems.',
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Kayley Maguire' },
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      reviewBody:
        'We cannot recommend Carl enough! After speaking with 2 electricians before him that fell through, we were nervous. We are very happy we chose Top Tier Electrical.',
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Ryan Prichard' },
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      reviewBody:
        "Carl and I have been working together for years. We send him multiple residential and commercial jobs. He's even held to the highest standards by general contractors.",
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Erik Bagroski' },
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      reviewBody: 'After other electricians failed to show up and over quoted the job, Carl made it happen!',
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Tom Farrell' },
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      reviewBody: 'Carl is one of the best there is! Easy to deal with, great product and service!',
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Bill Sheldon' },
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      reviewBody:
        "Carl wasn't the lowest bid I got but am very happy with his work and attention to details. It's always better to pay more once for a problem free experience than going for the cheapest option with difficulties!",
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Christopher Keeler' },
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      reviewBody:
        'Really nice young man!! I am a contractor and I use him on all of my projects. I know I can count on Carl to communicate and deliver quality work and clean up.',
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Thomas Farrell' },
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      reviewBody:
        'My son built a 5000sf new build in New Buffalo 2 story and Carl was lead Electrician electrical contractor on this.',
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'TJ Smith' },
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      reviewBody:
        'Carl has many years of experience while working in the field for others, recently passing the masters electrical board.',
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Lee Anderson' },
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      reviewBody: 'Did an excellent job. Affordable, complete, timely.',
    },
  ],
});
---

<TTELayout
  title="Customer Reviews | Top Tier Electrical West Michigan"
  description="Read verified customer reviews for Top Tier Electrical. See what West Michigan homeowners and businesses say about our licensed electrician services."
  canonical="https://toptier-electrical.com/reviews"
  jsonLd={[breadcrumbLd, aggregateRatingLd]}
>
  <main>
    <section class="container py-12 px-4">
      <h1>Customer Reviews</h1>
      <p>
        Verified Google Business reviews from recent clients across West Michigan. We focus on clear scope, clean
        workmanship, and dependable communication.
      </p>
      <p>
        <a
          href="https://g.page/r/CbQ3-X7fMvZ0EAE/review"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary"
          aria-label="Leave a review for Top Tier Electrical on Google"
