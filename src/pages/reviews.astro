---
import TTELayout from '~/layouts/TTELayout.astro';
import siteData from '~/data/site.json';

// All 19 verified Google reviews as of 2026-05. When new reviews land,
// add a new entry at the top and bump site.json's googleReviewCount.
// Dates approximated from the relative timestamps shown on the GBP at
// time of capture; if exact ISO dates are available later, swap them in.
type Review = {
  author: string;
  authorMeta?: string; // e.g. "Local Guide", count of other reviews
  date: string; // ISO yyyy-mm-dd
  body: string;
  service?: string;
  priceChip?: string;
  amountChip?: string;
  isLocalGuide?: boolean;
  ownerReply?: string;
};

const reviews: Review[] = [
  {
    author: 'Shubhamdeep Singh',
    date: '2026-04-04',
    body: "I've used Carl at multiple locations, commercial and residential, and every time he does a thoughtful, expedited and trustful service, no matter the job! If you're looking for someone that goes above and beyond in each project he participates in, Carl is the guy! What makes him valuable for me, is the insight and additional ideas he expresses while sharing his opinion and thinking outside the box of potential things any project may run into in the future. He will listen to what you have planned and really envision it himself to provide you with a better gameplan. 5 stars, everytime.",
    service: 'Remodeling',
  },
  {
    author: 'Mar D',
    date: '2026-04-04',
    body: '',
  },
  {
    author: 'Brian Vlietstra',
    date: '2026-03-28',
    body: 'We hired Top Tier to do some electrical updates for us. Carl is reasonable on his pricing and does top notch work. He is very honest, trustworthy, reliable and friendly. We highly recommend them and will be using them for future projects for sure. Five Stars.',
    service: 'Electrical panel replacement or upgrading',
    priceChip: 'Reasonable price',
  },
  {
    author: 'Barb Ocobock',
    date: '2026-03-28',
    body: 'If you need a great electrician, Carl is the best. Very honest trustworthy and knows his stuff.',
  },
  {
    author: 'Vicki Nystrom',
    date: '2026-03-14',
    body: 'We lost power for the first time at our cottage during a major wind/ice/snow storm. Although we had a generator, we had never used it before. Carl walked us through shopping at Home Depot to get the necessary part to connect it and through the process of installing it - all over the phone! So knowledgeable and patient! Saved our pipes and us from freezing!',
    service: 'Electrical power restoration, Electrical outlet & switch installation',
    priceChip: 'Great price',
    amountChip: '$1–200',
  },
  {
    author: 'Curt Meyer',
    date: '2026-03-07',
    body: 'Carl is a good communicator and arrived on time and kept me updated on his arrival. His work was very professional and he solved the issues in a short period of time.',
    service: 'General alarm installation, Remodeling',
    priceChip: 'Reasonable price',
    amountChip: '$200–400',
  },
  {
    author: 'Lupita Cervantes',
    date: '2026-02-21',
    body: 'We used Top Tier on our first rental home. Carl was quick to get the work done before we rented out the home. We also a few months later used his services a second time — we had a small fire on our rental due to an old fan that failed due to age. He was out the same day of our loss and installed a new one for us. He was actually the only electrician of various I called to go out and check it the same day. I recommend his company.',
    ownerReply: "Thank you! I'll always make it out same day if possible!",
  },
  {
    author: 'Kraig Koroleski',
    date: '2026-02-21',
    body: 'Carl wired a new construction house for me — all went great, lots of good advice for first time home builders. Best advice is to walk through the build before starting to wire it and make sure you are good with the function of all the switches and outlets. How will you be using the space, how will you decorate, how far do you want to walk for switches, etc. Nice work, great dude, money well spent.',
    service: 'Installation',
    amountChip: '$2,000+',
    ownerReply:
      "Thanks Kraig! I know we went back and forth placements, and in the end I'm glad everything went above and beyond expectations!",
  },
  {
    author: 'Colten DeHaan',
    authorMeta: 'Colten DeHaan Fishing',
    date: '2026-02-14',
    body: 'Carl was great to work with! Super detailed and thoughtful of how to future proof things to avoid problems.',
    service:
      'Electrical wiring installation, Electrical outlet & switch relocation, Electrical panel repair, Electrical fixture installation',
    priceChip: 'Great price',
    amountChip: '$2,000+',
    ownerReply: "Thanks Colten! Can't wait to try out your golf simulator!",
  },
  {
    author: 'Kayley Maguire',
    date: '2026-02-14',
    body: 'We cannot recommend Carl enough! After speaking with 2 electricians before him that fell through, we were nervous. We needed an electric panel upgrade and he came over right away to give us a quote and worked with us on a date and what was needed to apply for permits. He kept us updated the entire time and was very upfront about everything. As long as he is in business we will continue to choose him for our electrical needs. Such a nice gentleman to work with — he also made sure our power was turned back on same day after dealing with the electric company instead of making us wait until Monday (this was on a Friday). Pricing was very fair and communication was excellent.',
    service: 'Electrical panel replacement or upgrading',
    priceChip: 'Great price',
    amountChip: '$2,000+',
    ownerReply:
      "Thanks Kayley! I cannot believe how many others didn't bother helping as it was a major concern you had! I hope all is well!",
  },
  {
    author: 'Ryan Prichard',
    date: '2026-02-14',
    body: "Carl and I have been working together for years. We send him multiple residential and commercial jobs. He's even helped to renovate the electrical on multiple of my rental properties. From generators to lighting and more, he's helped service my very many odds and ends. He's been an easy staple for me to refer to my family and friends. Needless to say we highly recommend him!",
    isLocalGuide: true,
    ownerReply: "Thanks Ryan! I'm beyond happy to help!",
  },
  {
    author: 'Erik Bagroski',
    date: '2026-02-14',
    body: 'After other electricians failed to show up and over-quoted the job, Carl made it happen! Easy to communicate with, fair priced, and quick to schedule. Will use again.',
    ownerReply:
      "Thank you Erik! I still haven't forgot that bottle I owe! I'll be in Holland next week and will make sure to drop it off!",
  },
  {
    author: 'Tom Farrell',
    date: '2026-02-14',
    body: 'Carl is one of the best there is! Easy to deal with, great product and service!',
    ownerReply: 'Thanks Tommy! Looking forward to your next one!',
  },
  {
    author: 'Bill Sheldon',
    date: '2026-02-14',
    body: "Carl wasn't the lowest bid I got but I am very happy with his work and attention to details. It's always better to pay more once for a problem-free experience than going for the cheapest option with difficulties!",
    ownerReply: 'Thanks Bill!',
  },
  {
    author: 'Christopher Keeler',
    date: '2026-02-14',
    body: 'Really nice young man! I am a contractor and I use him on all of my projects. I know I can count on Carl to communicate and deliver quality work and clean up.',
    ownerReply: 'Thanks Chris! Looking forward to working again soon!',
  },
  {
    author: 'Thomas Farrell',
    date: '2026-02-14',
    body: "My son built a 5,000 sq ft new build in New Buffalo — 2 story — and Carl was lead electrical contractor on this. We've had 5 new builds and 2 remodels. We know the process but this is by far the best we ever felt with. He was very engaged, very friendly. I stayed focused on construction, my son was focused on business. You can't find a better person more focused, more in line with your desires on your build. All I can say is the best — and he won't nickel and dime you for every thought! You will not be disappointed.",
    isLocalGuide: true,
    ownerReply:
      "Tom, I cannot thank you enough. I'm so glad I could see your vision and help it come out as you planned!",
  },
  {
    author: 'Dalton Potgeter',
    date: '2026-02-14',
    body: '',
  },
  {
    author: 'TJ Smith',
    date: '2026-02-14',
    body: 'Carl has many years of experience while working in the field for others, recently passing the masters electrical board test and started his own company. He stands behind his work, which on my horse ranch is critical not only for dependability but safety measures in these seven barns. He is a hard worker, giving good advice, options and prompt service. Carl has gone above service calls to the point of searching for the right motor to replace an unreliable motor on my hay elevator. Whatever the problem, it was a thing of the past when he shows up.',
    ownerReply: "Thank you TJ, you are beyond kind. I'm so glad to help you with anything you have come up!",
  },
  {
    author: 'Lee Anderson',
    date: '2026-02-14',
    body: 'Did an excellent job. Affordable, complete, timely.',
    isLocalGuide: true,
    ownerReply: 'Thanks Lee! It was so nice to connect and really get to know you! Happy flying!',
  },
];

const businessUrl = siteData.site.origin;
const businessRef = { '@id': `${businessUrl}/#localbusiness` };

// Filter to reviews with body text for schema — Google requires
// reviewBody to be present and non-empty for the Review snippet.
const schemaReviews = reviews.filter((r) => r.body && r.body.trim().length > 0);

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${businessUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Reviews', item: `${businessUrl}/reviews` },
  ],
});

// AggregateRating duplicated on this page so the rich result is
// eligible to render with stars + count when /reviews itself appears
// in SERPs (not just the homepage).
const aggregateRatingLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Electrician',
  '@id': `${businessUrl}/#localbusiness`,
  name: siteData.business.name,
  url: businessUrl,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: siteData.seo.googleReviewAverage.toFixed(1),
    reviewCount: String(siteData.seo.googleReviewCount),
    bestRating: '5',
    worstRating: '1',
  },
  review: schemaReviews.map((r) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: r.author },
    datePublished: r.date,
    reviewBody: r.body,
    reviewRating: {
      '@type': 'Rating',
      ratingValue: '5',
      bestRating: '5',
      worstRating: '1',
    },
    itemReviewed: businessRef,
  })),
});
---

<TTELayout
  title="Customer Reviews | Top Tier Electrical West Michigan"
  description="19 verified 5-star Google reviews from Holland, Grand Rapids & West Michigan homeowners. Panel upgrades, EV chargers, generators, electrical repairs."
  canonical="https://www.toptier-electrical.com/reviews"
  ogImage="https://www.toptier-electrical.com/images/og/pages/reviews.png"
  jsonLd={[breadcrumbLd, aggregateRatingLd]}
>
  <main>
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li aria-current="page">Reviews</li>
      </ol>
    </nav>
    <section class="container section-pad-tight">
      <h1>Customer Reviews</h1>
      <div class="reviews-summary" aria-label="Overall rating summary">
        <div class="reviews-summary__stars" aria-hidden="true">★★★★★</div>
        <p class="reviews-summary__line">
          <strong>{siteData.seo.googleReviewAverage.toFixed(1)} of 5</strong> from <strong
            >{siteData.seo.googleReviewCount}</strong
          >
          verified Google reviews · <a
            href={siteData.seo.googleBusinessProfileUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-ga-event="external_link_click"
            data-ga-label="reviews-page__gbp">view on Google</a
          >
        </p>
      </div>
      <p>
        Every review below is verified through Carl's Google Business Profile. We focus on clear scope, clean
        workmanship, and dependable communication across Holland, Grand Rapids, Hudsonville, Allegan, and the broader
        West Michigan area.
      </p>
    </section>
    <section class="ct-testimonials" aria-label="Customer reviews">
      <div class="ct-testimonials__inner">
        <div class="ct-testimonials__grid">
          {
            reviews.map((r) => (
              <figure class="ct-review">
                <div class="ct-review__top">
                  <div class="ct-review__stars" aria-label="5 out of 5 stars">
                    ★★★★★
                  </div>
                  {(r.priceChip || r.amountChip || r.isLocalGuide) && (
                    <div class="ct-review__chips">
                      {r.isLocalGuide && <span class="ct-chip">Local Guide</span>}
                      {r.priceChip && <span class="ct-chip">{r.priceChip}</span>}
                      {r.amountChip && <span class="ct-chip">{r.amountChip}</span>}
                    </div>
                  )}
                </div>
                {r.body && <blockquote class="ct-review__quote">{r.body}</blockquote>}
                <figcaption class="ct-review__byline">
                  <span class="ct-review__author">— {r.author}</span>
                  {r.authorMeta && <span class="ct-review__meta"> ({r.authorMeta})</span>}
                  <time class="ct-review__date" datetime={r.date}>
                    {new Date(r.date).toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  {r.service && <span class="ct-review__service">Service: {r.service}</span>}
                </figcaption>
                {r.ownerReply && (
                  <div class="ct-review__reply">
                    <strong>Top Tier Electrical (owner reply):</strong> {r.ownerReply}
                  </div>
                )}
              </figure>
            ))
          }
        </div>
      </div>
    </section>
    <style>
      .reviews-summary {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        margin: 12px 0 20px;
      }
      .reviews-summary__stars {
        font-size: 22px;
        letter-spacing: 2px;
        color: #d4a017;
      }
      .reviews-summary__line {
        margin: 0;
        font-size: 16px;
      }
      .ct-testimonials {
        --ct-max: 1100px;
        --ct-gap: 18px;
        --ct-radius: 12px;
        --ct-border: rgba(0, 0, 0, 0.12);
        --ct-muted: rgba(0, 0, 0, 0.7);
        --ct-bg: #ffffff;
        padding: 16px 16px 48px;
      }
      .ct-testimonials__inner {
        max-width: var(--ct-max);
        margin: 0 auto;
      }
      .ct-testimonials__grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: var(--ct-gap);
      }
      .ct-review {
        margin: 0;
        background: var(--ct-bg);
        border: 1px solid var(--ct-border);
        border-radius: var(--ct-radius);
        padding: 18px;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .ct-review__top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
      }
      .ct-review__stars {
        letter-spacing: 1px;
        font-size: 16px;
        line-height: 1;
        white-space: nowrap;
        color: #d4a017;
      }
      .ct-review__chips {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        justify-content: flex-end;
      }
      .ct-chip {
        font-size: 12px;
        line-height: 1;
        padding: 6px 8px;
        border-radius: 999px;
        border: 1px solid var(--ct-border);
        color: var(--ct-muted);
        white-space: nowrap;
      }
      .ct-review__quote {
        margin: 0;
        line-height: 1.55;
        font-style: normal;
      }
      .ct-review__byline {
        margin: 0;
        color: var(--ct-muted);
        font-size: 14px;
        line-height: 1.5;
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .ct-review__author {
        color: rgba(0, 0, 0, 0.85);
        font-weight: 600;
      }
      .ct-review__meta {
        opacity: 0.85;
      }
      .ct-review__date {
        font-size: 13px;
        opacity: 0.75;
      }
      .ct-review__service {
        font-size: 13px;
        opacity: 0.85;
      }
      .ct-review__reply {
        font-size: 14px;
        line-height: 1.5;
        background: rgba(0, 0, 0, 0.04);
        border-left: 3px solid var(--ct-muted);
        padding: 10px 12px;
        border-radius: 4px;
        margin-top: 4px;
      }
    </style>
    <section class="cta-section">
      <h2>Ready to Work with a Trusted Electrician?</h2>
      <p>
        Call <a href="tel:+16163347159" data-ga-event="phone_click" data-ga-label="reviews-page__cta">(616) 334-7159</a>
        or <a href="/booking">request scheduling</a> to confirm scope and next steps. We respond to most West Michigan inquiries
        within one business day.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="reviews-page__cta_bottom"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
