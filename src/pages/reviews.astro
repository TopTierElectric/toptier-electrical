---
import TTELayout from '~/layouts/TTELayout.astro';
import siteData from '~/data/site.json';

// Curated selection of verified Google reviews. The aggregate count
// (36 as of 2026-07) lives in site.json's googleReviewCount and drives
// the AggregateRating; the list below is a representative subset. When
// new reviews land, add a new entry at the top and bump the count.
// Dates approximated from the relative timestamps shown on the GBP at
// time of capture; if exact ISO dates are available later, swap them in.
type Review = {
  author: string;
  authorMeta?: string; // e.g. "Local Guide", count of other reviews
  date: string; // ISO yyyy-mm-dd
  body: string;
  service?: string;
  priceChip?: string;
  amountChip?: string;
  isLocalGuide?: boolean;
  ownerReply?: string;
};

