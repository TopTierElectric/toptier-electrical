---
import TTELayout from '~/layouts/TTELayout.astro';
---

<TTELayout
  title="Commercial Electrical Maintenance | Top Tier Electrical"
  description="Commercial electrical maintenance services in West Michigan. Panel inspections, code corrections, and reliability upgrades for businesses."
  canonical="https://toptier-electrical.com/commercial-electrical-maintenance"
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Commercial Electrical Maintenance</h1>
        <p>Keep your business running safely with reliable electrical maintenance in West Michigan.</p>
        <a href="/booking" class="btn-primary">Request Scheduling</a>
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127970; Commercial Experience</span>
        </div>
      </div>
    </div>
    <section class="container" style="padding: 3rem 1rem;">
      <h2>Commercial Electrical Maintenance Services</h2>
      <p>
        Regular maintenance prevents unexpected failures and keeps your facility operating safely and efficiently. We
        provide commercial electrical maintenance for businesses throughout West Michigan.
      </p>
      <h3>Maintenance Services Include</h3>
      <ul>
        <li>Panel and distribution equipment inspections</li>
        <li>Code corrections and safety improvements</li>
        <li>Circuit testing and load verification</li>
        <li>Connection tightening and preventive repair</li>
        <li>Lighting system maintenance</li>
        <li>Generator and backup power testing</li>
      </ul>
      <h3>Why Regular Maintenance Matters</h3>
      <p>
        Proactive electrical maintenance reduces emergency repair costs, prevents operational downtime, and ensures your
        facility passes inspections without surprises.
      </p>
    </section>
    <section class="cta-section">
      <h2>Schedule Commercial Maintenance</h2>
      <p>
        Call <a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a> or email <a
          href="mailto:info@toptier-electrical.com">info@toptier-electrical.com</a
        > to confirm scope and scheduling.
      </p>
      <a href="/booking" class="btn-primary">Request Scheduling</a>
    </section>
  </main>
</TTELayout>
