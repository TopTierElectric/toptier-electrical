---
import TTELayout from '~/layouts/TTELayout.astro';

const jsonLd = [
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Energy Solutions & Efficiency Upgrades',
    description:
      'Practical energy upgrades—LED, controls, and load planning—to improve comfort and reduce waste in West Michigan homes.',
    provider: { '@id': 'https://toptier-electrical.com/#electrician' },
    areaServed: { '@type': 'State', name: 'Michigan' },
    serviceType: 'Energy Efficiency Consulting',
    url: 'https://toptier-electrical.com/energy-solutions',
  }),
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toptier-electrical.com/' },
      { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://toptier-electrical.com/services' },
      {
        '@type': 'ListItem',
        position: 3,
        name: 'Energy Solutions',
        item: 'https://toptier-electrical.com/energy-solutions',
      },
    ],
  }),
];
---

<TTELayout
  title="Energy Solutions | West Michigan Electrician"
  description="Practical energy upgrades—LED, controls, and load planning—to improve comfort and reduce waste without overcomplicating your home."
  canonical="https://toptier-electrical.com/energy-solutions"
  jsonLd={jsonLd}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/services">Services</a></li>
        <li aria-current="page">Energy Solutions</li>
      </ol>
    </nav>
    <section class="hero">
      <div class="hero-content">
        <h1>Energy Solutions</h1>
        <p>Practical upgrades that reduce waste, improve comfort, and keep your home ready for modern loads.</p>
        <a href="/booking" class="btn btn-primary">Schedule a Walkthrough</a>
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#128274; Workmanship Guarantee</span>
          <span class="badge">Owner-Operated</span>
          <span class="badge">Clean, Respectful Jobsite Habits</span>
        </div>
      </div>
    </div>
    <section class="service-detail">
      <div class="container">
        <p>
          Energy upgrades should be practical: lower waste, improve comfort, and keep your home ready for modern
          loads—without making the system complicated.
        </p>
        <div class="proof-chips">
          <span>Priority-based planning</span>
          <span>Efficiency-focused upgrades</span>
          <span>Clean, code-aware installs</span>
        </div>
        <h2>What We Mean by "Energy Solutions"</h2>
        <ul>
          <li>LED lighting upgrades that improve light quality and lower usage</li>
          <li>Smart controls that reduce unnecessary run time</li>
          <li>Load planning for future EV charging, remodels, or generator readiness</li>
          <li>Reliability improvements that reduce nuisance issues and keep power steady</li>
        </ul>
        <h2>What You Can Expect</h2>
        <ul>
          <li>A walkthrough to understand goals and constraints</li>
          <li>A prioritized plan (what matters most first)</li>
          <li>Clear scope and straightforward options</li>
          <li>Code-compliant work with a clean finish</li>
        </ul>
        <h2>Pricing Factors</h2>
        <ul>
          <li>Number of fixtures or controls being upgraded</li>
          <li>Need for new circuits or load planning</li>
          <li>Scope of efficiency improvements</li>
          <li>Access and installation complexity</li>
        </ul>
        <h2>How We Work</h2>
        <ol>
          <li>Walkthrough — Identify where energy is being wasted and where comfort matters most.</li>
          <li>Plan — Prioritize upgrades by impact and disruption.</li>
          <li>Execute — Clean, organized installation.</li>
          <li>Verify — Confirm performance and explain what changed.</li>
        </ol>
        <h2>Energy Solutions FAQs</h2>
        <div class="faq-grid">
          <div class="faq-item">
            <h3>What kinds of upgrades reduce waste fastest?</h3>
            <p>Lighting, controls, and panel-level load management usually deliver quick efficiency wins.</p>
          </div>
          <div class="faq-item">
            <h3>Do you provide phased recommendations?</h3>
            <p>Yes. We can prioritize projects so you can stage upgrades by budget and timeline.</p>
          </div>
          <div class="faq-item">
            <h3>Will I get a clear scope before work starts?</h3>
            <p>Absolutely. We document recommendations, exclusions, and execution steps before installation.</p>
          </div>
        </div>
        <h2>Next Step</h2>
        <p>
          Request a walkthrough if you want clear, no-pressure guidance on the most practical upgrades for your home or
          project.
        </p>
      </div>
    </section>
    <section class="cta-section">
      <h2>Ready for Practical Upgrades?</h2>
      <p>
        Call us at <a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a> or email <a
          href="mailto:info@toptier-electrical.com">info@toptier-electrical.com</a
        > to discuss energy-focused improvements.
      </p>
      <a href="/booking" class="btn btn-primary">Schedule a Walkthrough</a>
    </section>
  </main>
</TTELayout>
