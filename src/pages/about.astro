---
import TTELayout from '~/layouts/TTELayout.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    {'@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://toptier-electrical.com/'},
    {'@type': 'ListItem', 'position': 2, 'name': 'About', 'item': 'https://toptier-electrical.com/about'},
  ],
});
---

<TTELayout
  title="About Top Tier Electrical | West Michigan"
  description="Meet Top Tier Electrical: owner-operated, licensed and insured electrical contracting in West Michigan with clear scope, clean execution, and future-proof planning."
  jsonLd={[breadcrumbLd]}
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Owner-Operated Electrical Contracting Built for Long-Term Reliability</h1>
        <p>
          I started Top Tier Electrical to deliver clear communication, clean code-correct work, and planning that helps
          clients avoid expensive rework later.
        </p>
      </div>
    </section>
    <section class="container card">
      <h2>My Story</h2>
      <p>
        I serve West Michigan homeowners and light commercial clients who want the job done right the first time. I
        focus on scope clarity, realistic timelines, and workmanship that respects your home or business.
      </p>
      <p>
        Every project is handled with the same standards: polite communication, honest recommendations, and thorough
        explanations so you can make confident decisions.
      </p>
    </section>
    <section class="container trust-section">
      <h2>What to Expect</h2>
      <div class="trust-grid">
        <article class="trust-item">
          <h3>Diagnose</h3>
          <p>We identify the root issue and gather the details that affect scope.</p>
        </article>
        <article class="trust-item">
          <h3>Explain</h3>
          <p>You get options explained clearly, including future-proof recommendations.</p>
        </article>
        <article class="trust-item">
          <h3>Scope</h3>
          <p>Clear scope before work begins, with permits and inspections discussed upfront.</p>
        </article>
        <article class="trust-item">
          <h3>Execute &amp; Verify</h3>
          <p>Clean, code-correct installation with walkthrough before closeout.</p>
        </article>
      </div>
    </section>
    <section class="container gallery-section">
      <h2>Real Work, Real Standards</h2>
      <p>See panels, EV chargers, lighting upgrades, and commercial service work completed across West Michigan.</p>
      <p><a class="btn btn-primary" href="/gallery">View Project Gallery</a></p>
    </section>
    <section class="cta-section">
      <h2>Ready to Work Together?</h2>
      <p>
        Call <a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a> or email <a
          href="mailto:info@toptier-electrical.com">info@toptier-electrical.com</a
        > to confirm scope and scheduling.
      </p>
      <a href="/booking" class="btn-primary">Request Scheduling</a>
    </section>
  </main>
</TTELayout>
