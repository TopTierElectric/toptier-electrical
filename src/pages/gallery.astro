---
import TTELayout from '~/layouts/TTELayout.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Our Work', item: 'https://toptier-electrical.com/gallery' },
  ],
});
---

<TTELayout
  title="Electrical Project Gallery | Top Tier Electrical"
  description="Browse completed electrical projects in West Michigan including panel upgrades, EV chargers, generators, commercial work, and lighting installations."
  canonical="https://toptier-electrical.com/gallery"
  jsonLd={[breadcrumbLd]}
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Our Work</h1>
        <p>Browse completed electrical projects across West Michigan.</p>
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127968; Owner-Operated</span>
        </div>
      </div>
    </div>
    <section class="container" class="section-pad">
