            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Allegan — industrial controls and field wiring.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Transformer"
            alt="Holland, MI commercial 75 kVA step-down transformer installation with primary and secondary terminations"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Holland — 75 kVA step-down transformer install.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Meter Socket Bank"
            alt="Byron Center, MI 4-meter multi-unit residential meter socket bank installation"
