            width={400}
            height={300}
          /><figcaption>Commercial 480V Eaton switchgear.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Counter Bar Lighting"
            alt="Grand Rapids commercial bar accent lighting under counter and back-bar LED install"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Grand Rapids — commercial bar accent lighting.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Light Fixture"
            alt="Ada, MI residential bedroom ceiling fan and lighting fixture installation"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Ada — bedroom ceiling fan and light fixture install.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Exterior Light Fixtures"
            alt="West Michigan residential exterior accent and architectural lighting installation"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Exterior accent lighting — residential.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Panel Work"
            alt="Eaton commercial buildout panel with labeled circuits and clean wire dress"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Eaton commercial buildout — panel wire prep.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="EMT Piping"
            alt="Zeeland, MI commercial remodel EMT conduit installation through finished ceiling"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Zeeland — commercial remodel EMT runs.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
