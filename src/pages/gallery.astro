---
import TTELayout from '~/layouts/TTELayout.astro';
import GalleryThumb from '~/components/GalleryThumb.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Our Work', item: 'https://toptier-electrical.com/gallery' },
  ],
});
---

<TTELayout
  title="Electrical Project Gallery | Top Tier Electrical"
  description="Browse completed electrical projects in West Michigan including panel upgrades, EV chargers, generators, commercial work, and lighting installations."
  canonical="https://toptier-electrical.com/gallery"
  ogImage="https://toptier-electrical.com/images/og/pages/gallery.png"
  jsonLd={[breadcrumbLd]}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li aria-current="page">Our Work</li>
      </ol>
    </nav>
    <section class="hero">
      <div class="container hero-content">
        <h1>Our Work</h1>
        <p>Browse completed electrical projects across West Michigan.</p>
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127968; Owner-Operated</span>
        </div>
      </div>
    </div>
    <section class="container section-pad">
      <h2>Project Gallery</h2>
      <p>Clean installs, organized routing, and code-correct workmanship across residential and commercial projects.</p>
      <div class="gallery-grid">
        <figure>
          <GalleryThumb
            name="Electrical Panels"
            alt="Electrical panel installation"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Panel installation with organized circuits.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Residential panel install"
            alt="Residential panel installation"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Residential panel installation.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Control Cabinet"
            alt="Commercial control cabinet"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Commercial control cabinet installation.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="backup Generator"
            alt="Backup generator installation"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Backup generator installation with transfer switch.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="LED HandRail"
            alt="LED handrail lighting"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Custom LED handrail lighting.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Interior LED lighitng"
