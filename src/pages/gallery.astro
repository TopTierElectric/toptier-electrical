---
import TTELayout from '~/layouts/TTELayout.astro';
import GalleryThumb from '~/components/GalleryThumb.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Our Work', item: 'https://www.toptier-electrical.com/gallery' },
  ],
});
---

<TTELayout
  title="Electrical Project Gallery | West MI Master Electrician"
  description="Browse completed electrical projects by a licensed master electrician in West Michigan: panel upgrades, EV chargers, generators, commercial, lighting."
  canonical="https://www.toptier-electrical.com/gallery"
  ogImage="https://www.toptier-electrical.com/images/og/pages/gallery.png"
  jsonLd={[breadcrumbLd]}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li aria-current="page">Our Work</li>
      </ol>
    </nav>
    <section class="hero">
      <div class="container hero-content">
        <h1>Our Work</h1>
        <p>Browse completed electrical projects across West Michigan.</p>
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127968; Owner-Operated</span>
        </div>
      </div>
    </div>
    <section class="container section-pad">
      <h2>Project Gallery</h2>
      <p>Clean installs, organized routing, and code-correct workmanship across residential and commercial projects.</p>
      <div class="gallery-grid">
        <figure>
          <GalleryThumb
            name="Electrical Panels"
            alt="Grand Rapids, MI residential 400 amp electrical service panel installation"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Grand Rapids — 400 amp residential service panel.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Residential panel install"
            alt="Dorr, MI new-build residential install with Square D Homeline 200 amp main panel"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Dorr, MI — Square D Homeline 200A new build.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Control Cabinet"
            alt="Grand Rapids manufacturing plant dust collection system control cabinet wiring"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Grand Rapids — manufacturing plant dust collection controls.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="backup Generator"
            alt="Zeeland, MI Generac 22 kW natural gas whole-home standby generator installation"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Zeeland — Generac 22 kW natural gas standby generator.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="LED HandRail"
            alt="Grandville, MI custom LED handrail lighting fabrication and install"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Grandville — custom LED handrail lighting.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Interior LED lighitng"
            alt="New Buffalo, MI dispensary new-build interior LED lighting and tenant electrical fit-out"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>New Buffalo — dispensary new-build LED interior lighting.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Multi panel Assembly"
            alt="West Michigan commercial build remodel multi-panel power distribution assembly"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Commercial build remodel — multi-panel distribution.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Conduit Piping"
            alt="Grand Rapids industrial EMT conduit run with clean parallel routing and bends"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Grand Rapids — industrial EMT conduit routing.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Motor Control"
            alt="West Michigan agricultural facility motor disconnect and starter installation"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Agricultural motor disconnect installation.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="SteelTech Conduit Room"
            alt="Commercial conduit room"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Commercial conduit room organization.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Switch Gear"
