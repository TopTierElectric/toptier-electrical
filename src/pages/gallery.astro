            width={400}
            height={300}
          /><figcaption>Byron Center — 4-meter multi-unit service.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Electrical panel replacement"
            alt="Rustline Towing in Zeeland, MI commercial panel replacement: Square D QO to Homeline upgrade"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Rustline Towing, Zeeland — Square D QO to Homeline replacement.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Barn"
            alt="Ada, MI horse stall boarding facility new construction electrical service and lighting"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Ada — horse boarding facility new construction.</figcaption>
        </figure>
        <figure>
          <GalleryThumb
            name="Gas Station Service Call "
            alt="Wyoming, MI Speedway service call — commercial contactor diagnostic and replacement"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 45vw, 30vw"
            width={400}
            height={300}
          /><figcaption>Wyoming — Speedway commercial contactor service call.</figcaption>
        </figure>
      </div>
    </section>
    <section class="cta-section">
      <h2>Ready to Start Your Project?</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to confirm scope and scheduling.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
