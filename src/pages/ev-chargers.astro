      { '@type': 'City', name: 'Jamestown, MI' },
      { '@type': 'City', name: 'Allegan, MI' },
      { '@type': 'City', name: 'Ada, MI' },
    ],
    serviceType: 'EV Charging Station Installation',
    url: 'https://www.toptier-electrical.com/ev-chargers',
    subjectOf: buildSubjectOfArticles('/ev-chargers'),
  }),
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    '@id': 'https://www.toptier-electrical.com/ev-chargers#howto',
    name: 'How a Level 2 EV charger installation works',
    description:
      'Our four-step process for installing a Level 2 EV charger at a West Michigan home or business: walkthrough, plan, execute, and verify.',
