  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': 'https://www.toptier-electrical.com/ev-chargers#service',
    name: 'EV Charger Installation',
    description:
      'Level 2 EV charger installs with capacity checks, clean wiring, and permit coordination for West Michigan homes and businesses.',
