---
import TTELayout from '~/layouts/TTELayout.astro';
import { fetchPosts } from '~/utils/blog';

const posts = (await fetchPosts())
  .filter((p) => !p.draft)
  .sort((a, b) => new Date(b.publishDate).getTime() - new Date(a.publishDate).getTime());
---

<TTELayout
  title="Electrical Insights Blog | Top Tier Electrical"
  description="Practical electrical tips, project guides, and service advice from Top Tier Electrical in West Michigan."
  canonical="https://toptier-electrical.com/blog"
  ogImage="https://toptier-electrical.com/images/og/pages/blog.png"
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Electrical Insights</h1>
        <p>
          Practical tips, project guides, and electrical service advice for West Michigan homeowners and businesses.
        </p>
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127968; Owner-Operated</span>
        </div>
      </div>
    </div>
    <section class="container section-pad">
      <h2>Recent Articles</h2>
      <div class="blog-grid">
        {
          posts.map((post) => (
            <article class="blog-card">
              <h3>
                <a href={`/blog/${post.slug}`}>{post.title}</a>
              </h3>
              {post.excerpt && <p>{post.excerpt}</p>}
              <a href={`/blog/${post.slug}`}>Read More →</a>
            </article>
          ))
        }
      </div>
    </section>
    <section class="cta-section">
      <h2>Have Electrical Questions?</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        >.
      </p>
      <a href="/faq">Visit Our FAQ</a>
    </section>
  </main>
</TTELayout>
