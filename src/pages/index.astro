---
import SiteRewriteLayout from '~/layouts/SiteRewriteLayout.astro';

const electricianLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Electrician',
  name: 'Top Tier Electrical',
  telephone: '+1-616-334-7159',
  email: 'info@toptier-electrical.com',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Holland',
    addressRegion: 'MI',
    addressCountry: 'US',
  },
  openingHours: 'Mo-Fr 08:00-18:00, Sa 09:00-13:00',
  areaServed: ['Holland, MI', 'Grand Rapids, MI', 'Zeeland, MI', 'Hudsonville, MI', 'Allegan, MI', 'Ada, MI'],
  license: 'MI License #6220430',
});
---

<SiteRewriteLayout
  title="Electrician in West Michigan | Top Tier Electrical"
  description="Owner-operated electrician serving West Michigan for panel upgrades, EV chargers, and troubleshooting."
  canonical="https://codex-task-title-n560vp.toptier-electrical.pages.dev/"
  jsonLd={electricianLd}
>
  <main class="container" role="main">
    <section class="hero" aria-labelledby="hero-heading">
      <div class="hero-main">
        <p class="eyebrow">Electrician in West Michigan</p>
        <h1 id="hero-heading">Licensed, owner‑operated electrical service you can actually trust.</h1>
        <p class="content">
          Top Tier Electrical handles residential and light commercial work across West Michigan — panel upgrades, EV
          chargers, troubleshooting, and more. Straight answers, clean work, and clear pricing.
        </p>
        <div class="hero-ctas">
          <a class="btn-primary" href="tel:+16163347159" aria-label="Call Top Tier Electrical">(616) 334‑7159</a>
          <a class="btn-secondary" href="/request-scheduling" aria-label="Request Scheduling">Request Scheduling</a>
        </div>
      </div>

      <aside class="hero-aside">
        <picture>
          <source
            type="image/webp"
            srcset="/images/gallery/Residential Panel.webp 400w, /images/gallery/Residential Panel.webp 800w, /images/gallery/Residential Panel.webp 1200w"
            sizes="(max-width:600px) 100vw, (max-width:900px) 60vw, 800px"
          />
          <img
            src="/images/gallery/Residential Panel.webp"
            srcset="/images/gallery/Residential Panel.webp 400w, /images/gallery/Residential Panel.webp 800w, /images/gallery/Residential Panel.webp 1200w"
            sizes="(max-width:600px) 100vw, (max-width:900px) 60vw, 800px"
            width="1200"
            height="675"
            alt="Top Tier Electrical technician working on a residential panel"
            loading="eager"
            decoding="async"
            style="width:100%;height:auto;display:block;object-fit:cover;aspect-ratio:1200/675;"
          />
        </picture>

        <div class="trust-badges">
          <p><strong>Licensed</strong> MI License #6220430</p>
          <p><strong>Service</strong> Residential &amp; light commercial</p>
          <p><strong>Hours</strong> Mon–Fri 8am–6pm</p>
        </div>
      </aside>
    </section>

    <section id="services" aria-labelledby="services-heading">
      <h2 id="services-heading">Services</h2>
      <div class="card-grid" role="list">
        <article class="card" role="listitem" aria-labelledby="svc-panel">
          <h3 id="svc-panel">Panel Upgrades</h3>
          <p>Replace outdated or overloaded panels with modern, code‑compliant equipment.</p>
        </article>
        <article class="card" role="listitem" aria-labelledby="svc-ev">
          <h3 id="svc-ev">EV Charger Installation</h3>
          <p>Dedicated circuits and EV charger installs for home and light commercial.</p>
        </article>
        <article class="card" role="listitem" aria-labelledby="svc-troubleshoot">
          <h3 id="svc-troubleshoot">Repairs &amp; Troubleshooting</h3>
          <p>Track down tripping breakers, dead outlets, and other electrical issues.</p>
        </article>
      </div>
    </section>

    <section class="two-column" aria-label="Why Top Tier and how scheduling works">
      <div>
        <h2>Why Top Tier Electrical</h2>
        <ul>
          <li>Owner‑operated — you talk to the person doing the work.</li>
          <li>Licensed and insured in Michigan.</li>
          <li>Clean, code‑compliant installs with labeled panels.</li>
          <li>Clear communication and realistic scheduling.</li>
        </ul>
      </div>
      <div>
        <h2>How scheduling works</h2>
        <ol>
          <li>You call or submit a request with basic project details.</li>
          <li>We confirm scope, timing, and ballpark pricing.</li>
          <li>We schedule a visit and complete the work.</li>
          <li>You get a clean, safe, documented result.</li>
        </ol>
      </div>
    </section>

    <section aria-labelledby="areas-heading">
      <h2 id="areas-heading">Service areas</h2>
      <p class="content">Serving West Michigan communities with residential and light commercial electrical work.</p>
      <ul class="service-areas-list">
        <li>Holland, MI</li>
        <li>Grand Rapids, MI</li>
        <li>Zeeland, MI</li>
        <li>Hudsonville, MI</li>
        <li>Allegan, MI</li>
        <li>Ada, MI</li>
      </ul>
    </section>

    <section aria-labelledby="faq-heading">
      <h2 id="faq-heading">Common questions</h2>
      <details>
        <summary>Do you handle both residential and light commercial work?</summary>
        <p>Yes — we handle both. Share your project details and we’ll confirm scope and timing.</p>
      </details>
      <details>
        <summary>Can you install customer‑supplied fixtures or EV chargers?</summary>
        <p>Yes — we can install customer‑supplied equipment as long as it’s compatible and safe.</p>
      </details>
      <details>
        <summary>How do I get on the schedule?</summary>
        <p>Call (616) 334‑7159 or use the Request Scheduling page. We’ll confirm details and lock in a time.</p>
      </details>
    </section>

    <section aria-labelledby="cta-heading">
      <h2 id="cta-heading">Ready to get started?</h2>
      <p class="content">If you’re in West Michigan and need electrical work done right, reach out today.</p>
      <div class="hero-ctas">
        <a class="btn-primary" href="tel:+16163347159">(616) 334‑7159</a>
        <a class="btn-secondary" href="/request-scheduling">Request Scheduling</a>
      </div>
    </section>
  </main>
</SiteRewriteLayout>
