---
import TTELayout from '~/layouts/TTELayout.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    {'@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://toptier-electrical.com/'},
    {'@type': 'ListItem', 'position': 2, 'name': 'Services', 'item': 'https://toptier-electrical.com/services'},
    {'@type': 'ListItem', 'position': 3, 'name': 'Financing', 'item': 'https://toptier-electrical.com/financing'},
  ],
});
---

<TTELayout
  title="Electrical Service Financing | Top Tier Electrical"
  description="Financing options for electrical services in West Michigan. Flexible payment options for panel upgrades, EV chargers, and more."
  canonical="https://toptier-electrical.com/financing"
  jsonLd={[breadcrumbLd]}
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Financing Options</h1>
        <p>Flexible payment options to help you get the electrical work done right.</p>
      </div>
    </section>
    <section class="container" class="py-12 px-4">
      <h2>Financing for Electrical Services</h2>
      <p>
        We understand that electrical projects can represent a significant investment. We offer financing options to
        help make necessary upgrades more accessible.
      </p>
      <h3>Services Available for Financing</h3>
      <ul>
        <li>Panel upgrades and service upgrades</li>
        <li>EV charger installation</li>
        <li>Generator installation</li>
        <li>Energy solutions and efficiency upgrades</li>
        <li>Larger lighting and wiring projects</li>
      </ul>
      <h3>How It Works</h3>
      <p>
        Contact us to discuss your project scope and we'll provide information on available financing options. We'll
        review your project and walk through payment options that work for your situation.
      </p>
      <p><strong>Contact us:</strong></p>
      <ul>
        <li>Phone/Text: <a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a></li>
        <li>Email: <a href="mailto:info@toptier-electrical.com">info@toptier-electrical.com</a></li>
      </ul>
    </section>
    <section class="cta-section">
      <h2>Discuss Your Project</h2>
      <p>
        Call <a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a> or request scheduling to discuss scope, timeline, and
        financing options.
      </p>
      <a href="/booking" class="btn-primary">Request Scheduling</a>
    </section>
  </main>
</TTELayout>
