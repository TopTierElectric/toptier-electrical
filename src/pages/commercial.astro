---
import TTELayout from '~/layouts/TTELayout.astro';
import GalleryThumb from '~/components/GalleryThumb.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Commercial', item: 'https://www.toptier-electrical.com/commercial' },
  ],
});

const faqLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Do you handle three-phase commercial work?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. We handle 480V three-phase distribution, motor controls, and dedicated circuits for industrial and light-manufacturing equipment. The Steeltech 1200A 480V shop addition is one example.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can you work around our operating hours?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. We schedule work to minimize downtime — after hours, weekends, or in phases for active operations. We confirm the schedule before the job starts.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do you handle permits and inspections?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Permit pulling, inspection coordination, and on-site coordination with other trades is part of the scope.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do you do new construction electrical?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes — additions, buildouts, and full new construction. We coordinate with framing, mechanical, and finish trades on the schedule.',
      },
    },
    {
      '@type': 'Question',
      name: 'What size projects do you take on?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'From single-circuit repairs up to multi-thousand square foot industrial buildouts. The Steeltech 80x120 shop addition is on the larger end of our typical range.',
      },
    },
  ],
});
---

<TTELayout
  title="Commercial Electrician in West Michigan | Top Tier Electrical"
  description="Light commercial electrical services across West Michigan. Panel work, LED retrofits, controls, and maintenance for businesses."
  canonical="https://www.toptier-electrical.com/commercial"
  ogImage="https://www.toptier-electrical.com/images/og/pages/commercial.png"
  jsonLd={[breadcrumbLd, faqLd]}
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Commercial Electrical Services</h1>
        <p>Electrical service work for businesses across West Michigan.</p>
        <a
          href="/booking"
          class="btn btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking">Get a Clear Estimate</a
        >
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127970; Commercial Experience</span>
          <span class="badge">Clean, Respectful Jobsite Habits</span>
        </div>
      </div>
    </div>
    <section class="services">
      <div class="container">
        <h2>Services for Businesses</h2>
        <ul>
          <li><a href="/panel-upgrades">Panel upgrades and service corrections</a></li>
          <li><a href="/lighting">LED lighting retrofits and commercial lighting</a></li>
          <li><a href="/ev-chargers">EV charger installation</a></li>
          <li><a href="/electrical-repairs">Electrical repairs and troubleshooting</a></li>
          <li><a href="/generators">Generator and backup power planning</a></li>
          <li><a href="/energy-consulting">Energy consulting and load planning</a></li>
        </ul>
        <h3>Industries We Serve</h3>
        <p>
          We work with retail, offices, light industrial, agricultural facilities, and small commercial construction
          across West Michigan.
        </p>
        <h3>What to Expect</h3>
        <p>
          Clear scope before work begins, minimal disruption to your operations, and a professional finish that holds
          up.
        </p>
      </div>
    </section>
    <section class="services">
      <div class="container">
        <h2>Recent Related Work</h2>
        <article class="service-card" style="display: block;">
          <GalleryThumb
            name="SteelTech Conduit Room"
            alt="Industrial conduit routing in commercial shop addition for Steeltech"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 50vw, 33vw"
            width={800}
            height={600}
            style="border-radius: 8px; margin-bottom: 1rem; max-width: 100%; height: auto;"
          />
          <h3>
            <a href="/projects/steeltech-shop-addition-dust-collection">
              Steeltech 80×120 Shop Addition With Donaldson Torit Dust Collection — Grand Rapids, MI
            </a>
          </h3>
          <p>
            9,600 sq ft fabrication shop addition. 1200A 480V three-phase branch circuit, switchgear, control cabinet,
            conduit, motor controls, dust collector blower and motor, and field controls. Completed 2025.
          </p>
          <p><a href="/projects/steeltech-shop-addition-dust-collection">View project →</a></p>
        </article>
        <p class="text-center mt-4">
          <a href="/projects" class="btn btn-ghost">View all projects</a>
        </p>
      </div>
    </section>
    <section class="container section-pad">
      <h2>Commercial Electrician FAQs</h2>
      <div class="faq-list">
        <details>
          <summary>Do you handle three-phase commercial work?</summary>
          <p>
            Yes. We handle 480V three-phase distribution, motor controls, and dedicated circuits for industrial and
            light-manufacturing equipment. The Steeltech 1200A 480V shop addition is one example.
          </p>
        </details>
        <details>
          <summary>Can you work around our operating hours?</summary>
          <p>
            Yes. We schedule work to minimize downtime — after hours, weekends, or in phases for active operations. We
            confirm the schedule before the job starts.
          </p>
        </details>
        <details>
          <summary>Do you handle permits and inspections?</summary>
          <p>
            Yes. Permit pulling, inspection coordination, and on-site coordination with other trades is part of the
            scope.
          </p>
        </details>
        <details>
          <summary>Do you do new construction electrical?</summary>
          <p>
            Yes — additions, buildouts, and full new construction. We coordinate with framing, mechanical, and finish
            trades on the schedule.
          </p>
        </details>
        <details>
          <summary>What size projects do you take on?</summary>
          <p>
            From single-circuit repairs up to multi-thousand square foot industrial buildouts. The Steeltech 80×120 shop
            addition is on the larger end of our typical range.
          </p>
        </details>
      </div>
    </section>
    <section class="cta-section">
      <h2>Ready to Discuss Your Project?</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to confirm scope and scheduling.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
