---
import TTELayout from '~/layouts/TTELayout.astro';

const jsonLd = [
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': 'https://toptier-electrical.com/commercial#service',
    name: 'Commercial Electrical Services in West Michigan',
    serviceType: 'Commercial electrical services',
    provider: { '@id': 'https://toptier-electrical.com/#localbusiness' },
    areaServed: [
      'Holland MI',
      'Grand Rapids MI',
      'Byron Center MI',
      'Zeeland MI',
      'Saugatuck MI',
      'Hudsonville MI',
      'Allegan MI',
    ],
    description:
      'Commercial electrical service for West Michigan shops, warehouses, offices, agricultural facilities, and light manufacturing spaces.',
    url: 'https://toptier-electrical.com/commercial',
  }),
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toptier-electrical.com/' },
      { '@type': 'ListItem', position: 2, name: 'Commercial', item: 'https://toptier-electrical.com/commercial' },
    ],
  }),
];
---

<TTELayout
  title="Commercial Electrical Services | Top Tier Electrical"
  description="Commercial electrical services in West Michigan for tenant improvements, warehouse lighting, controls, repairs, maintenance, upgrades, and emergency response."
  canonical="https://toptier-electrical.com/commercial"
  jsonLd={jsonLd}
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Commercial Electrical Services in West Michigan</h1>
        <p>Scope clarity, clean execution, and practical planning to reduce downtime for your business.</p>
        <a href="/booking" class="btn btn-primary">Get a Clear Estimate</a>
      </div>
    </section>

    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127970; Commercial Experience</span>
          <span class="badge">Clean, Respectful Jobsite Habits</span>
        </div>
      </div>
    </div>

    <section class="services">
      <div class="container">
        <h2>Commercial Electrical Work We Handle</h2>
        <ul>
          <li>Tenant improvements and remodel electrical scope</li>
          <li>Warehouse and high-bay lighting upgrades</li>
          <li>Control panels and low-voltage control integration</li>
          <li>3-phase distribution improvements and troubleshooting</li>
          <li>Maintenance and repair for recurring electrical issues</li>
          <li>Service upgrades and panel modernization</li>
          <li>Emergency response for urgent outages and unsafe conditions</li>
        </ul>

        <h2>Industries and Spaces Served</h2>
        <ul>
          <li>Shops and showrooms</li>
          <li>Warehouses and distribution spaces</li>
          <li>Offices and mixed-use buildings</li>
          <li>Small manufacturing and process spaces</li>
          <li>Restaurants and commercial kitchens</li>
          <li>Multi-tenant commercial units</li>
          <li>Agricultural and mixed-use properties</li>
        </ul>

        <h2>Pricing Factors</h2>
        <ul>
          <li>Site access and allowable working hours</li>
          <li>Existing wiring and panel condition</li>
          <li>Required shutdown windows and sequencing</li>
          <li>Equipment lead times and material availability</li>
          <li>Permit and inspection requirements</li>
          <li>Lift access or ceiling height constraints</li>
        </ul>

        <h2>How We Reduce Downtime</h2>
        <ol>
          <li>Walkthrough and constraints review with your team.</li>
          <li>Scope clarification and electrical sequencing plan.</li>
          <li>Material planning before outage windows.</li>
          <li>Scheduled execution during planned downtime.</li>
          <li>Verification, labeling, and handoff documentation.</li>
        </ol>

        <h2>Commercial Electrical FAQs</h2>
        <p>
          <strong>Can work be scheduled around business hours?</strong><br />Yes. We coordinate scope and timing to
          minimize operational disruption.
        </p>
        <p>
          <strong>Do you handle emergency service calls?</strong><br />Yes. If an outage or unsafe condition affects
          operations, call for urgent response.
        </p>
        <p>
          <strong>Do you support ongoing maintenance needs?</strong><br />Yes. We can support recurring maintenance and
          repair priorities for active facilities.
        </p>

        <h2>Related Commercial Services</h2>
        <ul>
          <li><a href="/commercial-electrical-maintenance">Commercial maintenance</a></li>
          <li><a href="/lighting">Warehouse and facility lighting upgrades</a></li>
          <li><a href="/electrical-repairs">Commercial troubleshooting and repairs</a></li>
          <li><a href="/energy-consulting">Energy and load planning</a></li>
          <li><a href="/contact">Contact Top Tier Electrical</a></li>
        </ul>
      </div>
    </section>

    <section class="cta-section">
      <h2>Ready to Discuss Your Project?</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to confirm scope and scheduling.
      </p>
      <a href="/booking" class="btn btn-primary">Get a Clear Estimate</a>
    </section>
  </main>
</TTELayout>
