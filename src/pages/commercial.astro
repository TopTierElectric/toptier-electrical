---
import TTELayout from '~/layouts/TTELayout.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Commercial', item: 'https://toptier-electrical.com/commercial' },
  ],
});
---

<TTELayout
  title="Commercial Electrician in West Michigan | Top Tier Electrical"
  description="Light commercial electrical services across West Michigan. Panel work, LED retrofits, controls, and maintenance for businesses."
  canonical="https://toptier-electrical.com/commercial"
  jsonLd={[breadcrumbLd]}
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Commercial Electrical Services</h1>
        <p>Electrical service work for businesses across West Michigan.</p>
        <a href="/booking" class="btn btn-primary" data-ga-event="clear_estimate_click" data-ga-label="Get a Clear Estimate" data-ga-destination="/booking">Get a Clear Estimate</a>
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127970; Commercial Experience</span>
          <span class="badge">Clean, Respectful Jobsite Habits</span>
        </div>
      </div>
    </div>
    <section class="services">
      <div class="container">
        <h2>Services for Businesses</h2>
        <ul>
          <li><a href="/panel-upgrades">Panel upgrades and service corrections</a></li>
          <li><a href="/lighting">LED lighting retrofits and commercial lighting</a></li>
          <li><a href="/ev-chargers">EV charger installation</a></li>
          <li><a href="/electrical-repairs">Electrical repairs and troubleshooting</a></li>
          <li><a href="/generators">Generator and backup power planning</a></li>
          <li><a href="/energy-consulting">Energy consulting and load planning</a></li>
        </ul>
        <h3>Industries We Serve</h3>
        <p>
          We work with retail, offices, light industrial, agricultural facilities, and small commercial construction
          across West Michigan.
        </p>
        <h3>What to Expect</h3>
        <p>
          Clear scope before work begins, minimal disruption to your operations, and a professional finish that holds
          up.
        </p>
      </div>
    </section>
    <section class="cta-section">
      <h2>Ready to Discuss Your Project?</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to confirm scope and scheduling.
      </p>
      <a href="/booking" class="btn btn-primary" data-ga-event="clear_estimate_click" data-ga-label="Get a Clear Estimate" data-ga-destination="/booking">Get a Clear Estimate</a>
    </section>
  </main>
</TTELayout>
