---
import ServiceCityPage from '~/components/pages/ServiceCityPage.astro';
import GalleryThumb from '~/components/GalleryThumb.astro';
import { services, cities } from '~/data/service-city-config';
---

<ServiceCityPage service={services['lighting']} city={cities['ada-mi']}>
  <section class="container section-pad-tight">
    <h2>Recent Lighting Work in Ada</h2>
    <div class="proof-grid">
      <figure class="proof-card">
        <GalleryThumb
          name="Chandelier Ada"
          alt="Ada, MI custom chandelier light fixture installation in a high-ceiling entry"
          sizes="(max-width: 600px) 95vw, 50vw"
          width={400}
          height={300}
        />
        <figcaption>Ada — custom chandelier installation.</figcaption>
      </figure>
    </div>
  </section>
</ServiceCityPage>
