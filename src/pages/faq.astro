---
import TTELayout from '~/layouts/TTELayout.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: 'https://www.toptier-electrical.com/faq' },
  ],
});
---

<TTELayout
  title="Electrical FAQ | West Michigan Electrician"
  description="Frequently asked questions about electrical services, panel upgrades, EV chargers and more."
  canonical="https://www.toptier-electrical.com/faq"
  ogImage="https://www.toptier-electrical.com/images/og/pages/faq.png"
  jsonLd={[breadcrumbLd]}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li aria-current="page">FAQ</li>
      </ol>
    </nav>
    <section class="hero">
      <div class="hero-content">
        <h1>Frequently Asked Questions</h1>
        <p>Find answers to common questions about our services and electrical systems.</p>
        <a href="/contact" class="btn btn-primary">Ask a Question</a>
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">&#128295; Code-aware workmanship</span>
          <span class="badge">&#128274; Clean, careful installations</span>
          <span class="badge">&#127968; Local West Michigan team</span>
        </div>
      </div>
    </div>
    <section class="cta-section">
      <h2>Have More Questions?</h2>
      <p>
        Our team is ready to help. Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a
          href="mailto:info@toptier-electrical.com">info@toptier-electrical.com</a
        > for personalized assistance.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
    <section class="info-section">
      <div class="container">
        <h2>FAQs</h2>
        <div class="faq-list">
          <details>
            <summary><span class="faq-icon">&#9889;</span> When should I upgrade my electrical panel?</summary>
            <p>
              If your panel is outdated, trips frequently, or lacks space for new circuits, an upgrade may be the safest
              option. <a href="/panel-upgrades">Learn more about panel upgrades</a>.
            </p>
          </details>
          <details>
            <summary><span class="faq-icon">&#128276;</span> How long does a panel upgrade take?</summary>
            <p>
              Timing depends on the panel layout and scope, but most upgrades are completed in a single day once the
              plan is confirmed. <a href="/contact">Request scope details</a>.
            </p>
          </details>
          <details>
            <summary><span class="faq-icon">&#128663;</span> Do you install EV chargers?</summary>
            <p>
              Yes. We install Level 2 EV chargers for homes and small businesses with safe routing and proper circuit
              sizing. <a href="/ev-chargers">Learn more about EV charger installation</a>.
            </p>
          </details>
          <details>
            <summary><span class="faq-icon">&#9201;</span> How long does an EV charger installation take?</summary>
            <p>
              Many installations are completed in one visit after the routing and electrical capacity are confirmed. <a
                href="/ev-chargers">View our EV charger services</a
              >.
            </p>
          </details>
          <details>
            <summary><span class="faq-icon">&#127758;</span> What areas do you serve?</summary>
            <p>
              We serve West Michigan including Holland, Grand Rapids, Byron Center, Zeeland, Saugatuck, Hudsonville, and
              Allegan. See our <a href="/service-areas">service areas page</a> for more information.
            </p>
          </details>
          <details>
            <summary><span class="faq-icon">&#128203;</span> Are you licensed and insured?</summary>
            <p>
              Yes. We are licensed and insured, and the site footer lists MI License #6220430. <a href="/contact"
                >Contact us for details</a
              >.
            </p>
          </details>
          <details>
            <summary><span class="faq-icon">&#128176;</span> Do you provide scope details before work begins?</summary>
            <p>
              Yes. We confirm the repair or installation scope before starting work so you know the plan. <a
                href="/contact">Get in touch</a
              >.
            </p>
          </details>
          <details>
            <summary><span class="faq-icon">&#128197;</span> Do you work on weekends?</summary>
            <p>Yes, we offer Saturday appointments from 9am to 1pm. <a href="/booking">Book your appointment</a>.</p>
          </details>
        </div>
        <p class="text-center mt-4">
          Don't see your question? <a href="/contact">Reach out</a> and we'll be happy to help.
        </p>
      </div>
    </section>
  </main>
</TTELayout>
