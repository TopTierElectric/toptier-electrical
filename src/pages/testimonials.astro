---
import TTELayout from '~/layouts/TTELayout.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Testimonials', item: 'https://toptier-electrical.com/testimonials' },
  ],
});
---

<TTELayout
  title="Customer Testimonials | Top Tier Electrical"
  description="Read testimonials from West Michigan homeowners and business clients who hired Top Tier Electrical for panel upgrades, EV chargers, lighting, and repairs."
  canonical="https://toptier-electrical.com/testimonials"
  jsonLd={[breadcrumbLd]}
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Customer Testimonials</h1>
        <p>What homeowners and businesses say about working with Top Tier Electrical.</p>
        <a href="/booking" class="btn btn-primary">Request Scheduling</a>
      </div>
    </section>

    <section class="services">
      <div class="container">
        <h2>Recent Feedback</h2>
        <blockquote>“Excellent communication, clean workmanship, and clear scope from start to finish.”</blockquote>
        <blockquote>“Panel work and troubleshooting were handled professionally and on schedule.”</blockquote>
        <blockquote>“EV charger install was straightforward and code-compliant. Highly recommended.”</blockquote>
        <p>
          Looking for more reviews? Visit our <a href="/reviews">reviews page</a> or
          <a href="https://share.google/pOgXH17fP6C0srCw9" target="_blank" rel="noopener noreferrer"
            >Google Business Profile</a
          >.
        </p>
      </div>
    </section>
  </main>
</TTELayout>
