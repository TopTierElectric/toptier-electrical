---
import TTELayout from '~/layouts/TTELayout.astro';
---

<TTELayout
  title="Electrical Design Consultation | Top Tier Electrical"
  description="Professional electrical design consultation for new construction, remodels, and commercial projects in West Michigan."
  canonical="https://toptier-electrical.com/electrical-design-consultation"
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Electrical Design Consultation</h1>
        <p>Professional electrical planning for new construction, remodels, and expansions across West Michigan.</p>
        <a
          href="/booking"
          class="btn btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking">Get a Clear Estimate</a
        >
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127968; Owner-Operated</span>
        </div>
      </div>
    </div>
    <section class="container section-pad">
      <h2>Design Consultation Services</h2>
      <p>
        Good electrical design reduces change orders, prevents future rework, and ensures your project meets code from
        day one.
      </p>
      <h3>When to Book a Consultation</h3>
      <ul>
        <li>New home construction or major remodel</li>
        <li>Commercial buildout or expansion</li>
        <li>Before adding EV charging, generators, or HVAC upgrades</li>
        <li>When you want a clear electrical plan before hiring any contractor</li>
      </ul>
      <h3>What You Get</h3>
      <ul>
        <li>A walkthrough of your project goals and constraints</li>
        <li>Load calculations and circuit planning</li>
        <li>Panel sizing recommendations</li>
        <li>Clear scope guidance for your electrical contractor</li>
      </ul>
    </section>
    <section class="cta-section">
      <h2>Schedule Your Consultation</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to schedule a design consultation.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
