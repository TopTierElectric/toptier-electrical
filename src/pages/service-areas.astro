---
import TTELayout from '~/layouts/TTELayout.astro';
---

<TTELayout
  title="Service Areas | Top Tier Electrical West Michigan"
  description="Top Tier Electrical serves Holland, Grand Rapids, Byron Center, Zeeland, Saugatuck, Douglas, Hudsonville, Jamestown, Allegan, and Ada in West Michigan."
  canonical="https://www.toptier-electrical.com/service-areas"
  ogImage="https://www.toptier-electrical.com/images/og/pages/service-areas.png"
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Service Areas</h1>
        <p>Serving West Michigan homeowners and businesses across the region.</p>
        <a href="/contact" class="btn btn-primary">Check Your Area</a>
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127968; Local West Michigan</span>
        </div>
      </div>
    </div>
    <section class="container section-pad">
      <h2>Cities We Serve</h2>
      <div class="service-cards">
        <div class="service-card">
          <h3><a href="/electrician-holland-mi">Holland, MI</a></h3><p>
            Residential and commercial electrical services in Holland and the surrounding area.
          </p>
        </div>
        <div class="service-card">
          <h3><a href="/electrician-grand-rapids-mi">Grand Rapids, MI</a></h3><p>
            Electrical service work throughout Grand Rapids and surrounding communities.
          </p>
        </div>
        <div class="service-card">
          <h3><a href="/electrician-byron-center-mi">Byron Center, MI</a></h3><p>
            Home electrical upgrades and troubleshooting across Byron Center.
          </p>
        </div>
        <div class="service-card">
          <h3><a href="/electrician-zeeland-mi">Zeeland, MI</a></h3><p>
            Panel upgrades, lighting, and electrical repairs in Zeeland.
          </p>
        </div>
        <div class="service-card">
          <h3><a href="/electrician-saugatuck-mi">Saugatuck, MI</a></h3><p>
            Electrical service and upgrades throughout Saugatuck.
          </p>
        </div>
        <div class="service-card">
          <h3><a href="/electrician-douglas-mi">Douglas, MI</a></h3><p>
            Electrical service and upgrades throughout Douglas.
          </p>
        </div>
        <div class="service-card">
          <h3><a href="/electrician-allegan-mi">Allegan, MI</a></h3><p>
            Residential and commercial electrical in Allegan County.
          </p>
        </div>
        <div class="service-card">
          <h3><a href="/electrician-hudsonville-mi">Hudsonville, MI</a></h3><p>
            Electrical service work in Hudsonville and nearby areas.
          </p>
        </div>
        <div class="service-card">
          <h3><a href="/electrician-ada-mi">Ada, MI</a></h3><p>
            Residential and commercial electrical services in Ada.
          </p>
        </div>
        <div class="service-card">
          <h3><a href="/electrician-jamestown-mi">Jamestown, MI</a></h3><p>
            Panel upgrades, EV chargers, and troubleshooting in Jamestown.
          </p>
        </div>
        <div class="service-card">
          <h3><a href="/electrician-grand-haven">Grand Haven, MI</a></h3><p>
            Residential and commercial electrical work along the Grand Haven lakeshore.
          </p>
        </div>
        <div class="service-card">
          <h3><a href="/electrician-muskegon">Muskegon, MI</a></h3><p>
            Panel upgrades, repairs, and commercial work for Muskegon-area homes and businesses.
          </p>
        </div>
      </div>
      <h2 class="mt-8">Full Coverage Area</h2>
      <p>
        We serve <strong
          >Holland, Grand Rapids, Byron Center, Zeeland, Saugatuck, Douglas, Hudsonville, Jamestown, Allegan, Ada, Grand
          Haven, Muskegon</strong
        >, and surrounding West Michigan communities.
      </p>
      <p>
        If you're not sure whether we cover your location, call or text us at <a href="tel:+16163347159"
          >(616) 334-7159</a
        > and we'll confirm quickly.
      </p>
    </section>
    <section class="cta-section">
      <h2>Confirm Your Area</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to confirm service availability.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
