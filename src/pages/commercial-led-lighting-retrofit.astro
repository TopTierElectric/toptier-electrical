---
import TTELayout from '~/layouts/TTELayout.astro';
---

<TTELayout
  title="Commercial LED Lighting Retrofit | Top Tier Electrical"
  description="Commercial LED lighting retrofit services in West Michigan. Reduce energy costs and improve lighting quality with professional LED retrofits."
  canonical="https://www.toptier-electrical.com/commercial-led-lighting-retrofit"
  ogImage="https://www.toptier-electrical.com/images/og/pages/commercial-led-lighting-retrofit.png"
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Commercial LED Lighting Retrofit</h1>
        <p>Upgrade commercial lighting to energy-efficient LED with minimal disruption to operations.</p>
        <a
          href="/booking"
          class="btn btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking">Get a Clear Estimate</a
        >
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127970; Commercial Experience</span>
        </div>
      </div>
    </div>
    <section class="container section-pad">
      <h2>Commercial LED Retrofit Benefits</h2>
      <p>
        LED lighting upgrades deliver better light quality, lower energy consumption, and reduced maintenance costs for
        commercial facilities across West Michigan.
      </p>
      <h3>What We Provide</h3>
      <ul>
        <li>Full facility lighting audit and retrofit planning</li>
        <li>LED fixture selection and specification</li>
        <li>Professional installation with minimal disruption</li>
        <li>Controls integration (occupancy sensors, dimmers)</li>
        <li>Code-compliant installation and documentation</li>
      </ul>
      <h3>Industries We Serve</h3>
      <p>Retail, office, warehouse, agricultural, and light industrial facilities across West Michigan.</p>
      <p>See our <a href="/lighting">lighting services page</a> for residential lighting options.</p>
    </section>
    <section class="cta-section">
      <h2>Discuss Your LED Retrofit</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to confirm scope and scheduling.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
