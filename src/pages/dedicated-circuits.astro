---
import TTELayout from '~/layouts/TTELayout.astro';

const jsonLd = [
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Dedicated Circuits',
    description:
      'Professional dedicated circuit installation in West Michigan. Safe, code-compliant circuits for appliances, workshops, EV chargers, and high-demand equipment.',
    provider: { '@id': 'https://toptier-electrical.com/#localbusiness' },
    areaServed: [
      { '@type': 'City', name: 'Holland, MI' },
      { '@type': 'City', name: 'Grand Rapids, MI' },
      { '@type': 'City', name: 'Byron Center, MI' },
      { '@type': 'City', name: 'Zeeland, MI' },
      { '@type': 'City', name: 'Saugatuck, MI' },
      { '@type': 'City', name: 'Douglas, MI' },
      { '@type': 'City', name: 'Hudsonville, MI' },
      { '@type': 'City', name: 'Jamestown, MI' },
      { '@type': 'City', name: 'Allegan, MI' },
      { '@type': 'City', name: 'Ada, MI' },
    ],
    serviceType: 'Dedicated Circuit Installation',
    url: 'https://toptier-electrical.com/dedicated-circuits',
  }),
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toptier-electrical.com/' },
      { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://toptier-electrical.com/services' },
      {
        '@type': 'ListItem',
        position: 3,
        name: 'Dedicated Circuits',
        item: 'https://toptier-electrical.com/dedicated-circuits',
      },
    ],
  }),
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How a West Michigan dedicated circuit install works',
    description:
      'Our four-step process for adding a properly sized dedicated circuit for high-load equipment: assess, plan, install, and verify.',
    step: [
      {
        '@type': 'HowToStep',
        position: 1,
        name: 'Assess',
        text: 'Review your panel capacity and the equipment requirements before quoting the work.',
      },
      {
        '@type': 'HowToStep',
        position: 2,
        name: 'Plan',
        text: 'Confirm the circuit size, conduit routing, and install scope so there are no surprises.',
      },
      {
        '@type': 'HowToStep',
        position: 3,
        name: 'Install',
        text: 'Run the dedicated circuit cleanly with correct breaker sizing and tidy finish work.',
      },
      {
        '@type': 'HowToStep',
        position: 4,
        name: 'Verify',
        text: 'Test under load to confirm the circuit holds up to real use before calling it done.',
      },
    ],
  }),
];
---

<TTELayout
  title="Dedicated Circuit Installation | West Michigan Electrician"
  description="Professional dedicated circuit installation in West Michigan for appliances, workshops, EV chargers, and high-demand equipment. Safe, code-compliant work."
  canonical="https://toptier-electrical.com/dedicated-circuits"
  jsonLd={jsonLd}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/services">Services</a></li>
        <li aria-current="page">Dedicated Circuits</li>
      </ol>
    </nav>
    <section class="hero">
      <div class="hero-content">
        <h1>Dedicated Circuit Installation</h1>
        <p>Properly sized, code-compliant circuits for appliances, workshops, EV chargers, and more.</p>
        <a
          href="/booking"
          class="btn btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking">Get a Clear Estimate</a
        >
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#128274; Workmanship Guarantee</span>
          <span class="badge">Owner-Operated</span>
        </div>
      </div>
    </div>
    <section class="service-detail">
      <div class="container">
        <p>
          High-demand equipment needs its own circuit. Sharing circuits with appliances, power tools, or EV chargers can
          cause nuisance tripping, overheating, and safety hazards. A dedicated circuit ensures your equipment gets
          clean, reliable power — and stays code-compliant.
        </p>
        <h2>Common Dedicated Circuit Applications</h2>
        <ul>
          <li>EV charger circuits (Level 2, 50A)</li>
          <li>Kitchen appliances — refrigerators, dishwashers, microwaves</li>
          <li>Laundry — washers and electric dryers</li>
          <li>Workshop equipment — table saws, air compressors, welders</li>
          <li>Home office and server equipment</li>
          <li>Hot tubs and spa equipment</li>
          <li>Air conditioners and HVAC units</li>
        </ul>
        <h2>What You Can Expect</h2>
        <ul>
          <li>Load assessment to verify panel capacity before installation</li>
          <li>Properly sized wire gauge and breaker for the equipment</li>
          <li>Code-compliant installation with clean finish</li>
          <li>Permit coordination when required</li>
          <li>Clear explanation of scope and cost before work begins</li>
        </ul>
        <h2>How We Work</h2>
        <ol>
          <li>Assess — Review your panel capacity and equipment requirements.</li>
          <li>Plan — Confirm the circuit size, routing, and scope.</li>
          <li>Install — Run the circuit cleanly and correctly.</li>
          <li>Verify — Test under load before calling the job done.</li>
        </ol>
        <h2>FAQ</h2>
        <p>
          <strong>Does my panel have capacity for a new circuit?</strong><br />We'll check your panel capacity before
          quoting the work. If an upgrade is needed, we'll explain your options.
        </p>
        <p>
          <strong>Do I need a permit for a dedicated circuit?</strong><br />Permit requirements vary by jurisdiction and
          scope. We'll clarify this upfront and handle coordination when needed.
        </p>
        <p>
          <strong>How long does installation take?</strong><br />Most dedicated circuit installations are completed in a
          few hours, depending on the run length and panel access.
        </p>
      </div>
    </section>
    <section class="container section-pad">
      <h2>Related reading</h2>
      <ul>
        <li>
          <a href="/blog/do-i-need-a-panel-upgrade-for-an-ev-charger">Do I need a panel upgrade for an EV charger?</a>
        </li>
        <li><a href="/blog/why-breakers-trip">Why does my breaker keep tripping?</a></li>
      </ul>
    </section>
    <section class="cta-section">
      <h2>Need a Dedicated Circuit?</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to confirm scope and scheduling.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
