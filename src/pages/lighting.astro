---
import TTELayout from '~/layouts/TTELayout.astro';

const jsonLd = [
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Lighting & Fixtures Installation',
    description:
      'Thoughtful lighting layouts, dimmers, smart controls, and clean installs for West Michigan homes and commercial spaces.',
    provider: { '@id': 'https://toptier-electrical.com/#localbusiness' },
    areaServed: [
      { '@type': 'City', name: 'Holland, MI' },
      { '@type': 'City', name: 'Grand Rapids, MI' },
      { '@type': 'City', name: 'Byron Center, MI' },
      { '@type': 'City', name: 'Zeeland, MI' },
      { '@type': 'City', name: 'Saugatuck, MI' },
      { '@type': 'City', name: 'Douglas, MI' },
      { '@type': 'City', name: 'Hudsonville, MI' },
      { '@type': 'City', name: 'Jamestown, MI' },
      { '@type': 'City', name: 'Allegan, MI' },
      { '@type': 'City', name: 'Ada, MI' },
    ],
    serviceType: 'Lighting Installation',
    url: 'https://toptier-electrical.com/lighting',
  }),
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How a West Michigan lighting and fixture install works',
    description:
      'Our four-step process for indoor and outdoor lighting upgrades and fixture installs: walkthrough, plan, execute, and verify.',
    step: [
      {
        '@type': 'HowToStep',
        position: 1,
        name: 'Walkthrough',
        text: 'Identify lighting goals: task, ambient, and accent needs across each space.',
      },
      {
        '@type': 'HowToStep',
        position: 2,
        name: 'Plan',
        text: 'Confirm fixture layout, switching logic, dimming, and the cleanest wiring approach.',
      },
      {
        '@type': 'HowToStep',
        position: 3,
        name: 'Execute',
        text: 'Run wiring cleanly, install fixtures, and complete careful trim work that looks finished.',
      },
      {
        '@type': 'HowToStep',
        position: 4,
        name: 'Verify',
        text: 'Test dimming, switching, and the final appearance with you before calling the job complete.',
      },
    ],
  }),
];
---

<TTELayout
  title="Lighting Installation in West Michigan | Top Tier Electrical"
  description="Thoughtful lighting layouts, dimmers, smart controls, and clean installs. Premium finish work for West Michigan homes and select commercial spaces."
  canonical="https://toptier-electrical.com/lighting"
  jsonLd={jsonLd}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/services">Services</a></li>
        <li aria-current="page">Lighting &amp; Fixtures</li>
      </ol>
    </nav>
    <section class="hero">
      <div class="hero-content">
        <h1>Lighting &amp; Fixtures</h1>
        <p>Thoughtful, code-compliant lighting that looks clean and works the way it should.</p>
        <a
          href="/booking"
          class="btn btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking">Get a Clear Estimate</a
        >
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#128274; Workmanship Guarantee</span>
          <span class="badge">Owner-Operated</span>
          <span class="badge">Clean, Respectful Jobsite Habits</span>
        </div>
      </div>
    </div>
    <section class="service-detail">
      <div class="container">
        <p>
          Lighting should look intentional and feel effortless. Whether it's a custom home, a remodel, or a targeted
          upgrade, we plan placement, switching, and dimming so the result is clean, functional, and reliable.
        </p>
        <div class="proof-chips">
          <span>Layout planning included</span>
          <span>Dimmer compatibility</span>
          <span>Clean finish work</span>
        </div>
        <h2>Common Projects We Handle</h2>
        <ul>
          <li>Recessed and decorative fixture installation</li>
          <li>Kitchen task lighting (including under-cabinet)</li>
          <li>Exterior lighting for safety and curb appeal</li>
          <li>LED upgrades and retrofits</li>
          <li>Dimmers and smart controls that work the way they should</li>
        </ul>
        <h2>What You Can Expect</h2>
        <ul>
          <li>A walkthrough focused on how you use the space</li>
          <li>Layout guidance (spacing, switch locations, and practical light levels)</li>
          <li>Compatibility planning (fixtures + dimmers + LEDs to reduce flicker)</li>
          <li>Clean installation: straight trims, tidy mounting, professional finish</li>
        </ul>
        <h2>Pricing Factors</h2>
        <ul>
          <li>Fixture count and ceiling access</li>
          <li>Switching/dimming complexity</li>
          <li>Need for new circuits or dedicated lighting loads</li>
          <li>Fixture type and mounting height</li>
        </ul>
        <h2>How We Work</h2>
        <ol>
          <li>Walkthrough — Identify goals: task, ambient, and accent needs.</li>
          <li>Plan — Layout + switching plan + fixture approach.</li>
          <li>Execute — Clean wiring and careful trim work.</li>
          <li>Verify — Test dimming, switching logic, and final appearance.</li>
        </ol>
        <h2>FAQ</h2>
        <p>
          <strong>Can you install customer-supplied fixtures?</strong><br />Yes, as long as the fixture is compatible
          with your wiring and rated for the location.
        </p>
        <p>
          <strong>Do I need new wiring for recessed lights?</strong><br />Sometimes. We review access, existing wiring,
          and fixture requirements before confirming.
        </p>
        <p>
          <strong>Can you add dimmers to existing switches?</strong><br />Yes, if the fixtures and wiring support
          dimming. We confirm compatibility first.
        </p>
        <h2>Next Step</h2>
        <p>
          If you want a custom home electrician in West Michigan who treats lighting like part of the craftsmanship,
          schedule a consultation. We'll help you build a plan that looks right and works right.
        </p>
      </div>
    </section>
    <section class="container section-pad">
      <h2>Related reading</h2>
      <ul>
        <li><a href="/blog/led-retrofit-vs-fixture-replacement">LED retrofit vs fixture replacement</a></li>
      </ul>
    </section>
    <section class="container section-pad">
      <h2>Lighting Installation by City</h2>
      <p>Find local electrical service for lighting installation in your West Michigan city:</p>
      <ul>
        <li><a href="/lighting-holland-mi">Lighting Installation in Holland, MI</a></li>
        <li><a href="/lighting-grand-rapids-mi">Lighting Installation in Grand Rapids, MI</a></li>
        <li><a href="/lighting-zeeland-mi">Lighting Installation in Zeeland, MI</a></li>
        <li><a href="/lighting-hudsonville-mi">Lighting Installation in Hudsonville, MI</a></li>
        <li><a href="/lighting-ada-mi">Lighting Installation in Ada, MI</a></li>
      </ul>
      <p>
        <a href="/service-areas">View all service areas</a>
      </p>
    </section>
    <section class="cta-section">
      <h2>Brighten Your Space</h2>
      <p>
        Call us at <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to discuss your lighting project.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
