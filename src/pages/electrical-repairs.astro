---
import TTELayout from '~/layouts/TTELayout.astro';

const jsonLd = [
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Electrical Repairs & Troubleshooting',
    description:
      'Professional electrical repairs and troubleshooting in West Michigan. We diagnose the root cause and explain the fix before starting work.',
    provider: { '@id': 'https://toptier-electrical.com/#localbusiness' },
    areaServed: { '@type': 'State', name: 'Michigan' },
    serviceType: 'Electrical Repair',
    url: 'https://toptier-electrical.com/electrical-repairs',
  }),
];
---

<TTELayout
  title="Electrical Repairs & Troubleshooting in West Michigan | Top Tier Electrical"
  description="Professional electrical repairs and troubleshooting in West Michigan. We diagnose the root cause and explain the fix before starting work."
  canonical="https://toptier-electrical.com/electrical-repairs"
  jsonLd={jsonLd}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/services">Services</a></li>
        <li aria-current="page">Electrical Repairs</li>
      </ol>
    </nav>
    <section class="hero">
      <div class="hero-content">
        <h1>Electrical Repairs &amp; Troubleshooting</h1>
        <p>We diagnose the root cause, explain the fix, and get it done right.</p>
        <a href="/booking" class="btn btn-primary" data-ga-event="clear_estimate_click" data-ga-label="Get a Clear Estimate" data-ga-destination="/booking">Schedule Repair</a>
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#128274; Workmanship Guarantee</span>
          <span class="badge">Owner-Operated</span>
        </div>
      </div>
    </div>
    <section class="service-detail">
      <div class="container">
        <p>
          Electrical problems can feel unpredictable. We start with systematic troubleshooting so you understand the
          root cause and your options before any work begins.
        </p>
        <h2>Common Repairs We Handle</h2>
        <ul>
          <li>Dead outlets, switches, and fixtures</li>
          <li>Tripping or warm breakers</li>
          <li>Flickering lights or unstable circuits</li>
          <li>GFCI faults and arc-fault issues</li>
          <li>Loose connections and aging wiring concerns</li>
          <li>Code corrections and safety improvements</li>
        </ul>
        <h2>What You Can Expect</h2>
        <ul>
          <li>Systematic testing and diagnosis</li>
          <li>Clear explanation of what was found</li>
          <li>Options presented before work begins</li>
          <li>Code-correct repair with clean finish</li>
        </ul>
        <h2>How We Work</h2>
        <ol>
          <li>Diagnose — Find the root cause, not just the symptom.</li>
          <li>Explain — Walk you through what we found and your options.</li>
          <li>Fix — Complete the repair correctly and safely.</li>
          <li>Verify — Test and confirm before calling it done.</li>
        </ol>
        <h2>FAQ</h2>
        <p>
          <strong>What if the problem is hard to find?</strong><br />We use systematic testing to narrow down
          intermittent or hidden faults. If additional investigation is needed, we'll explain why before proceeding.
        </p>
        <p>
          <strong>Will you tell me the cost before starting?</strong><br />Yes. We confirm the scope and approach before
          any repair work begins.
        </p>
      </div>
    </section>
    <section class="cta-section">
      <h2>Need a Repair?</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to schedule service.
      </p>
      <a href="/booking" class="btn btn-primary" data-ga-event="clear_estimate_click" data-ga-label="Get a Clear Estimate" data-ga-destination="/booking">Get a Clear Estimate</a>
    </section>
  </main>
</TTELayout>
