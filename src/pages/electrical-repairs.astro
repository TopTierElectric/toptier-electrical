---
import TTELayout from '~/layouts/TTELayout.astro';

const jsonLd = [
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': 'https://www.toptier-electrical.com/electrical-repairs#service',
    name: 'Electrical Repairs & Troubleshooting',
    description:
      'Professional electrical repairs and troubleshooting in West Michigan. We diagnose the root cause and explain the fix before starting work.',
    provider: { '@id': 'https://www.toptier-electrical.com/#localbusiness' },
    areaServed: [
      { '@type': 'City', name: 'Holland, MI' },
      { '@type': 'City', name: 'Grand Rapids, MI' },
      { '@type': 'City', name: 'Byron Center, MI' },
      { '@type': 'City', name: 'Zeeland, MI' },
      { '@type': 'City', name: 'Saugatuck, MI' },
      { '@type': 'City', name: 'Douglas, MI' },
      { '@type': 'City', name: 'Hudsonville, MI' },
      { '@type': 'City', name: 'Jamestown, MI' },
      { '@type': 'City', name: 'Allegan, MI' },
      { '@type': 'City', name: 'Ada, MI' },
    ],
    serviceType: 'Electrical Repair',
    url: 'https://www.toptier-electrical.com/electrical-repairs',
  }),
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    '@id': 'https://www.toptier-electrical.com/electrical-repairs#howto',
    name: 'How West Michigan electrical repairs work',
    description:
      'Our four-step process for diagnosing and fixing residential and light commercial electrical problems: diagnose, explain, fix, and verify.',
    step: [
      {
        '@type': 'HowToStep',
        position: 1,
        name: 'Diagnose',
        text: 'Investigate the root cause of the problem rather than just clearing the symptom.',
      },
      {
        '@type': 'HowToStep',
        position: 2,
        name: 'Explain',
        text: 'Walk you through what we found and the safest repair options before any work is done.',
      },
      {
        '@type': 'HowToStep',
        position: 3,
        name: 'Fix',
        text: 'Complete the repair correctly and safely with code-compliant parts and clean workmanship.',
      },
      {
        '@type': 'HowToStep',
        position: 4,
        name: 'Verify',
        text: 'Test the repaired circuit or device and confirm everything works before calling it done.',
      },
    ],
  }),
];
---

<TTELayout
  title="Electrical Repairs in West Michigan | Top Tier Electrical"
  description="Professional electrical repairs and troubleshooting in West Michigan. We diagnose the root cause and explain the fix before starting work."
  canonical="https://www.toptier-electrical.com/electrical-repairs"
  ogImage="https://www.toptier-electrical.com/images/og/electrical-repairs.png"
  jsonLd={jsonLd}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/services">Services</a></li>
        <li aria-current="page">Electrical Repairs</li>
      </ol>
    </nav>
    <section class="hero">
      <div class="hero-content">
        <h1>Electrical Repairs &amp; Troubleshooting</h1>
        <p>We diagnose the root cause, explain the fix, and get it done right.</p>
        <a
          href="/booking"
          class="btn btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking">Get a Clear Estimate</a
        >
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#128274; Workmanship Guarantee</span>
          <span class="badge">Owner-Operated</span>
        </div>
      </div>
    </div>
    <section class="service-detail">
      <div class="container">
        <p>
          Electrical problems can feel unpredictable. We start with systematic troubleshooting so you understand the
          root cause and your options before any work begins.
        </p>
        <h2>Common Repairs We Handle</h2>
        <ul>
          <li>Dead outlets, switches, and fixtures</li>
          <li>Tripping or warm breakers</li>
          <li>Flickering lights or unstable circuits</li>
          <li>GFCI faults and arc-fault issues</li>
          <li>Loose connections and aging wiring concerns</li>
          <li>Code corrections and safety improvements</li>
        </ul>
        <h2>What You Can Expect</h2>
        <ul>
          <li>Systematic testing and diagnosis</li>
          <li>Clear explanation of what was found</li>
          <li>Options presented before work begins</li>
          <li>Code-correct repair with clean finish</li>
        </ul>
        <h2>How We Work</h2>
        <ol>
          <li>Diagnose — Find the root cause, not just the symptom.</li>
          <li>Explain — Walk you through what we found and your options.</li>
          <li>Fix — Complete the repair correctly and safely.</li>
          <li>Verify — Test and confirm before calling it done.</li>
        </ol>
        <h2>FAQ</h2>
        <p>
          <strong>What if the problem is hard to find?</strong><br />We use systematic testing to narrow down
          intermittent or hidden faults. If additional investigation is needed, we'll explain why before proceeding.
        </p>
        <p>
          <strong>Will you tell me the cost before starting?</strong><br />Yes. We confirm the scope and approach before
          any repair work begins.
        </p>
      </div>
    </section>
    <section class="container section-pad">
      <h2>Related reading</h2>
      <ul>
        <li><a href="/blog/why-breakers-trip">Why does my breaker keep tripping?</a></li>
        <li><a href="/blog/gfci-vs-afci-vs-dual-function">GFCI vs AFCI vs dual-function breakers</a></li>
        <li><a href="/blog/aluminum-wiring-what-to-do">Aluminum wiring: what to do if you have it</a></li>
        <li><a href="/blog/blog-electrical-safety">Essential electrical safety tips for homeowners</a></li>
      </ul>
    </section>
    <section class="container section-pad">
      <h2>Electrical Repairs by City</h2>
      <p>Find local electrical service for electrical repairs and troubleshooting in your West Michigan city:</p>
      <ul>
        <li><a href="/electrical-repairs-holland-mi">Electrical Repairs in Holland, MI</a></li>
        <li><a href="/electrical-repairs-grand-rapids-mi">Electrical Repairs in Grand Rapids, MI</a></li>
        <li><a href="/electrical-repairs-zeeland-mi">Electrical Repairs in Zeeland, MI</a></li>
        <li><a href="/electrical-repairs-hudsonville-mi">Electrical Repairs in Hudsonville, MI</a></li>
        <li><a href="/electrical-repairs-ada-mi">Electrical Repairs in Ada, MI</a></li>
      </ul>
      <p>
        <a href="/service-areas">View all service areas</a>
      </p>
    </section>
    <section class="cta-section">
      <h2>Need a Repair?</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to schedule service.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
