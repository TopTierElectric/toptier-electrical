---
import TTELayout from '~/layouts/TTELayout.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Residential', item: 'https://toptier-electrical.com/residential' },
  ],
});
---

<TTELayout
  title="Residential Electrician Services | Top Tier Electrical"
  description="Residential electrical services across West Michigan. Panel upgrades, EV chargers, lighting, repairs, generators, and more."
  canonical="https://toptier-electrical.com/residential"
  jsonLd={[breadcrumbLd]}
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Residential Electrical Services</h1>
        <p>Electrical service work for homes across West Michigan.</p>
        <a href="/booking" class="btn btn-primary">Request Scheduling</a>
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127968; Owner-Operated</span>
          <span class="badge">Clean, Respectful Jobsite Habits</span>
        </div>
      </div>
    </div>
    <section class="services">
      <div class="container">
        <h2>Services for Homeowners</h2>
        <ul>
          <li><a href="/panel-upgrades">Panel upgrades</a></li>
          <li><a href="/ev-chargers">EV charger installation</a></li>
          <li><a href="/lighting">Kitchen and whole-home lighting</a></li>
          <li><a href="/electrical-repairs">Repairs and troubleshooting</a></li>
          <li><a href="/generators">Backup generator planning</a></li>
          <li><a href="/energy-solutions">Energy and load planning</a></li>
        </ul>
        <h3>What to Expect</h3>
        <p>Submit a request, receive a clear scope, and choose a confirmed scheduling window.</p>
        <div class="proof-grid">
          <figure class="proof-card">
            <img
              src="/images/gallery/Service after.webp"
              alt="Residential panel upgrade"
              loading="lazy"
              decoding="async"
              width="400"
              height="300"
            />
            <figcaption>Outdated service gear → upgraded panel → safer daily power.</figcaption>
          </figure>
          <figure class="proof-card">
            <img
              src="/images/gallery/7550693456474594645.webp"
              alt="Residential EV charging"
              loading="lazy"
              decoding="async"
              width="400"
              height="300"
            />
            <figcaption>
              No Level 2 charging at home → dedicated circuit install → reliable overnight charging.
            </figcaption>
          </figure>
        </div>
      </div>
    </section>
    <section class="cta-section">
      <h2>Ready to Schedule?</h2>
      <p>
        Call <a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a> or email <a
          href="mailto:info@toptier-electrical.com">info@toptier-electrical.com</a
        > to confirm scope and scheduling.
      </p>
      <a href="/booking" class="btn btn-primary">Request Scheduling</a>
    </section>
  </main>
</TTELayout>
