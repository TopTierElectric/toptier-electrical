---
import TTELayout from '~/layouts/TTELayout.astro';
import GalleryThumb from '~/components/GalleryThumb.astro';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Residential', item: 'https://www.toptier-electrical.com/residential' },
  ],
});

const faqLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Do you handle small jobs and big projects?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. We handle single-circuit repairs and full-home rewires alike. Small jobs get the same scope clarity and clean finish as big ones.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do you charge for an estimate?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'For most jobs, no — we provide clear estimates without upfront charges. For complex diagnostics where the work itself is the assessment, we discuss it before scheduling.',
      },
    },
    {
      '@type': 'Question',
      name: 'How quickly can you get out for a service call?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'For non-emergency work, usually within the same week. Urgent issues are prioritized. Holland and immediately surrounding cities are scheduled fastest.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do you work on older homes?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Older homes are a big part of what we do — panel upgrades, code corrections, aluminum branch wiring remediation, and bringing aging systems up to current code.',
      },
    },
    {
      '@type': 'Question',
      name: 'What payment do you accept?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'We accept standard payment methods. Specifics are confirmed in the quote and invoice.',
      },
    },
  ],
});
---

<TTELayout
  title="Residential Electrician West MI | Master Electrician"
  description="Licensed master electrician for West Michigan homes. Panel upgrades, EV chargers, lighting, repairs, generators. Call (616) 334-7159."
  canonical="https://www.toptier-electrical.com/residential"
  ogImage="https://www.toptier-electrical.com/images/og/pages/residential.png"
  jsonLd={[breadcrumbLd, faqLd]}
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Residential Electrical Services</h1>
        <p>Electrical service work for homes across West Michigan.</p>
        <a
          href="/booking"
          class="btn btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking">Get a Clear Estimate</a
        >
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127968; Owner-Operated</span>
          <span class="badge">Clean, Respectful Jobsite Habits</span>
        </div>
      </div>
    </div>
    <section class="services">
      <div class="container">
        <h2>Services for Homeowners</h2>
        <ul>
          <li><a href="/panel-upgrades">Panel upgrades</a></li>
          <li><a href="/ev-chargers">EV charger installation</a></li>
          <li><a href="/lighting">Kitchen and whole-home lighting</a></li>
          <li><a href="/electrical-repairs">Repairs and troubleshooting</a></li>
          <li><a href="/generators">Backup generator planning</a></li>
          <li><a href="/energy-solutions">Energy and load planning</a></li>
        </ul>
        <h3>What to Expect</h3>
        <p>Submit a request, receive a clear scope, and choose a confirmed scheduling window.</p>
        <div class="proof-grid">
          <figure class="proof-card">
            <GalleryThumb
              name="Service after"
              alt="Residential panel installation"
              sizes="(max-width: 600px) 95vw, 50vw"
              width={400}
              height={300}
            />
            <figcaption>Outdated service gear → upgraded panel → safer daily power.</figcaption>
          </figure>
          <figure class="proof-card">
            <GalleryThumb
              name="7550693456474594645"
              alt="Custom LED accent lighting"
              sizes="(max-width: 600px) 95vw, 50vw"
              width={400}
              height={300}
            />
            <figcaption>Custom LED accent lighting.</figcaption>
          </figure>
        </div>
      </div>
    </section>
    <section class="services">
      <div class="container">
        <h2>Recent Related Work</h2>
        <article class="service-card" style="display: block;">
          <GalleryThumb
            name="Light Fixture"
            alt="Custom home decorative lighting in Ada, MI"
            sizes="(max-width: 600px) 95vw, (max-width: 1024px) 50vw, 33vw"
            width={800}
            height={600}
            style="border-radius: 8px; margin-bottom: 1rem; max-width: 100%; height: auto;"
          />
          <h3>
            <a href="/projects/ada-mi-custom-home-and-horse-barn"> Ada Custom Home and Horse Barn — 400A Service </a>
          </h3>
          <p>
            Custom home and matching custom horse barn in Ada, MI on a single 400A service. Decorative lighting in the
            home, code-compliant stall lighting and barn power, and a clean finish across both buildings.
          </p>
          <p><a href="/projects/ada-mi-custom-home-and-horse-barn">View project →</a></p>
        </article>
        <p class="text-center mt-4">
          <a href="/projects" class="btn btn-ghost">View all projects</a>
        </p>
      </div>
    </section>
    <section class="container section-pad">
      <h2>Residential Electrician FAQs</h2>
      <div class="faq-list">
        <details>
          <summary>Do you handle small jobs and big projects?</summary>
          <p>
            Yes. We handle single-circuit repairs and full-home rewires alike. Small jobs get the same scope clarity and
            clean finish as big ones.
          </p>
        </details>
        <details>
          <summary>Do you charge for an estimate?</summary>
          <p>
            For most jobs, no — we provide clear estimates without upfront charges. For complex diagnostics where the
            work itself is the assessment, we discuss it before scheduling.
          </p>
        </details>
        <details>
          <summary>How quickly can you get out for a service call?</summary>
          <p>
            For non-emergency work, usually within the same week. Urgent issues are prioritized. Holland and immediately
            surrounding cities are scheduled fastest.
          </p>
        </details>
        <details>
          <summary>Do you work on older homes?</summary>
          <p>
            Yes. Older homes are a big part of what we do — panel upgrades, code corrections, aluminum branch wiring
            remediation, and bringing aging systems up to current code.
          </p>
        </details>
        <details>
          <summary>What payment do you accept?</summary>
          <p>We accept standard payment methods. Specifics are confirmed in the quote and invoice.</p>
        </details>
      </div>
    </section>
    <section class="cta-section">
      <h2>Ready to Schedule?</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to confirm scope and scheduling.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
