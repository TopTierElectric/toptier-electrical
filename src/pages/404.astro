---
import TTELayout from '~/layouts/TTELayout.astro';
---

<TTELayout
  title="Page Not Found | Top Tier Electrical"
  description="The page you're looking for couldn't be found. Return to the Top Tier Electrical homepage."
  robots="noindex, nofollow"
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>404 – Page Not Found</h1>
        <p>Sorry, the page you're looking for doesn't exist. It may have been moved or deleted.</p>
        <a href="/" class="btn-primary">Return to Homepage</a>
      </div>
    </section>
    <section class="container" class="py-12 px-4 text-center">
      <h2>Looking for Something?</h2>
      <p>Here are some helpful links:</p>
      <ul class="list-none p-0 flex flex-wrap gap-4 justify-center">
        <li><a href="/services">Services</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/gallery">Gallery</a></li>
        <li><a href="/booking">Book Service</a></li>
        <li><a href="/faq">FAQ</a></li>
      </ul>
    </section>
  </main>
</TTELayout>
