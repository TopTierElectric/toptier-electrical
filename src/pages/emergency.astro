---
import TTELayout from '~/layouts/TTELayout.astro';
---

<TTELayout
  title="Emergency Electrical Services | Top Tier Electrical"
  description="Urgent electrical service for Holland, Grand Rapids and West Michigan residents and businesses. Call to confirm next steps and safe shutdown guidance."
  canonical="https://toptier-electrical.com/emergency"
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <span class="emergency-hero-badge">URGENT HELP</span>
        <h1>Emergency Electrical Services</h1>
        <p>Fast, reliable emergency response and safe next-step guidance when you need help now.</p>
        <div class="hero-cta-row">
          <a href="tel:+16163347159" class="emergency-call-btn">Call Now: (616)&nbsp;334&#8209;7159</a>
          <a href="/booking" class="btn btn-primary">Schedule Non-Emergency</a>
        </div>
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">&#128295; Code-aware workmanship</span>
          <span class="badge">&#128274; Clean, careful installations</span>
          <span class="badge">&#127968; Local West Michigan team</span>
        </div>
      </div>
    </div>
    <section class="emergency-actions">
      <div class="container">
        <div class="emergency-grid">
          <div class="emergency-card do-this">
            <h3>&#10003; Do This Right Now</h3>
            <ul>
              <li>Leave the area if you smell burning</li>
              <li>Turn off the main breaker if safe to do so</li>
              <li>Keep everyone away from downed power lines</li>
              <li>Call us immediately: <a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a></li>
            </ul>
          </div>
          <div class="emergency-card do-not">
            <h3>&#10007; Do NOT Do This</h3>
            <ul>
              <li>Do not use water on electrical fires</li>
              <li>Do not touch exposed wires</li>
              <li>Do not reset tripped breakers repeatedly</li>
              <li>Do not attempt DIY repairs</li>
            </ul>
          </div>
        </div>
      </div>
    </section>
    <section class="info-section">
      <div class="container">
        <h2>What Counts as an Electrical Emergency?</h2>
        <p>Electrical problems can be dangerous. If you encounter any of the following, call for urgent assistance:</p>
        <ul>
          <li>The smell of burning wires or smoke coming from outlets</li>
          <li>Electric shocks when touching appliances or switches</li>
          <li>Frequent breaker trips or blown fuses</li>
          <li>Power outages affecting only your property</li>
          <li>Exposed wiring or sparking electrical panels</li>
        </ul>
        <h3>Call 911 First If</h3>
        <ul>
          <li>There is an active fire or heavy smoke</li>
          <li>Someone has been injured or shocked and needs medical attention</li>
          <li>You see downed power lines touching vehicles, water, or structures</li>
        </ul>
        <h3>Call an Electrician If</h3>
        <ul>
          <li>Breakers trip repeatedly after resetting once</li>
          <li>Outlets feel hot or emit a burning odor</li>
          <li>Lights flicker or dim when major appliances start</li>
        </ul>
        <p><strong>Emergency Hotline:</strong> <a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a></p>
        <p class="mt-4">Have questions? See our <a href="/faq">FAQ page</a> for more information.</p>
      </div>
    </section>
    <section class="cta-section">
      <h2>Need Help with an Emergency?</h2>
      <p>
        Call <a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a> for urgent assistance, or schedule non-emergency service
        online.
      </p>
      <a href="/booking" class="btn btn-primary">Schedule Non-Emergency</a>
    </section>
  </main>
</TTELayout>
