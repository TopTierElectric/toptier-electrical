---
import TTELayout from '~/layouts/TTELayout.astro';
---

<TTELayout
  title="Thank You | Top Tier Electrical"
  description="Thank you for contacting Top Tier Electrical. We'll be in touch within 1 business day."
  canonical="https://toptier-electrical.com/thank-you"
  robots="noindex, nofollow"
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Thank You!</h1>
        <p>We've received your request and will be in touch within 1 business day to confirm scope and scheduling.</p>
        <a href="/" class="btn btn-primary">Return Home</a>
      </div>
    </section>
    <section class="container section-pad text-center">
      <h2>What Happens Next</h2>
      <ol class="text-left max-w-[500px] mx-auto">
        <li>We review your request details.</li>
        <li>We confirm scope and scheduling options.</li>
        <li>We arrive on time and walk you through the completed work.</li>
      </ol>
      <p class="mt-8">
        Questions? Call <a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a> or email <a
          href="mailto:info@toptier-electrical.com">info@toptier-electrical.com</a
        >.
      </p>
    </section>
  </main>
</TTELayout>
