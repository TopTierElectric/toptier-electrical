---
import TTELayout from '~/layouts/TTELayout.astro';
---

<TTELayout
  title="Electrician Grand Rapids MI | Top Tier Electrical"
  description="Licensed electrician serving Grand Rapids, MI. Panel upgrades, EV charger installation, lighting, and repairs."
  canonical="https://toptier-electrical.com/electrician-grand-rapids"
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Electrician in Grand Rapids, MI</h1>
        <p>Licensed, insured electrical service for Grand Rapids homes and commercial spaces.</p>
        <a href="/booking" class="btn-primary">Request Scheduling</a>
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127968; Owner-Operated</span>
        </div>
      </div>
    </div>
    <section class="services">
      <div class="container">
        <h2>Grand Rapids Service Coverage</h2>
        <p>
          Electrical service throughout Grand Rapids and surrounding communities, including panel upgrades, EV chargers,
          lighting, repairs, and commercial work.
        </p>
        <h3>Services Available in Grand Rapids</h3>
        <ul>
          <li><a href="/panel-upgrades">Electrical panel upgrades</a></li>
          <li><a href="/ev-chargers">EV charger installation</a></li>
          <li><a href="/lighting">Lighting and fixtures</a></li>
          <li><a href="/electrical-repairs">Electrical repairs and troubleshooting</a></li>
          <li><a href="/generators">Generator installation</a></li>
          <li><a href="/energy-solutions">Energy solutions</a></li>
        </ul>
        <p><a href="/contact" class="btn-secondary">Confirm availability in Grand Rapids</a></p>
      </div>
    </section>
    <section class="cta-section">
      <h2>Schedule Service in Grand Rapids</h2>
      <p>
        Call <a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a> or email <a
          href="mailto:info@toptier-electrical.com">info@toptier-electrical.com</a
        > to confirm scope and scheduling.
      </p>
      <a href="/booking" class="btn-primary">Request Scheduling</a>
    </section>
  </main>
</TTELayout>
