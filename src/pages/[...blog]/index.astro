---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';
import TTELayout from '~/layouts/TTELayout.astro';
import { getCanonical, getPermalink } from '~/utils/permalinks';
import { getStaticPathsBlogPost } from '~/utils/blog';
import { blogRelatedServices } from '~/data/blog-related-services';

export const prerender = true;

export const getStaticPaths = (async () => {
  return await getStaticPathsBlogPost();
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { post } = Astro.props as Props;

const url = getCanonical(getPermalink(post.permalink, 'post'));
const canonical = String(url);
const ogImage = `https://www.toptier-electrical.com/images/og/blog/${post.slug}.png`;

const relatedServices = blogRelatedServices[post.slug] ?? [];

// Cluster taxonomy: map post.category → service hub URL + schema @id so each
// spoke explicitly belongs to a cluster in both the visible breadcrumb and
// the BreadcrumbList JSON-LD. This signals topical taxonomy to Google.
const CATEGORY_HUB: Record<string, { path: string; label: string; serviceId: string }> = {
  'Panel Upgrades': {
    path: '/panel-upgrades',
    label: 'Panel Upgrades',
    serviceId: 'https://www.toptier-electrical.com/panel-upgrades#service',
  },
  Generators: {
    path: '/generators',
    label: 'Generators',
    serviceId: 'https://www.toptier-electrical.com/generators#service',
  },
  'EV Charging': {
    path: '/ev-chargers',
    label: 'EV Chargers',
    serviceId: 'https://www.toptier-electrical.com/ev-chargers#service',
  },
  'Electrical Repairs': {
    path: '/electrical-repairs',
    label: 'Electrical Repairs',
    serviceId: 'https://www.toptier-electrical.com/electrical-repairs#service',
  },
  Lighting: { path: '/lighting', label: 'Lighting', serviceId: 'https://www.toptier-electrical.com/lighting#service' },
  Commercial: {
    path: '/commercial',
    label: 'Commercial',
    serviceId: 'https://www.toptier-electrical.com/commercial#service',
  },
  'Code Corrections': {
    path: '/code-corrections',
    label: 'Code Corrections',
    serviceId: 'https://www.toptier-electrical.com/code-corrections#service',
  },
  'Electrical Tips': {
    path: '/services',
    label: 'Electrical Services',
    serviceId: 'https://www.toptier-electrical.com/services#service',
  },
};
const categoryTitle = post.category?.title;
const cluster = categoryTitle ? CATEGORY_HUB[categoryTitle] : undefined;
const clusterUrl = cluster ? `https://www.toptier-electrical.com${cluster.path}` : undefined;

// E-E-A-T author signal: licensed electrician identity
const personLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://www.toptier-electrical.com/#owner',
  name: 'Carl, Top Tier Electrical',
  jobTitle: 'Licensed Electrician (Owner-Operator)',
  worksFor: { '@id': 'https://www.toptier-electrical.com/#localbusiness' },
  hasCredential: {
    '@type': 'EducationalOccupationalCredential',
    credentialCategory: 'Professional License',
    name: 'State of Michigan Electrical License #6220430',
    recognizedBy: { '@type': 'Organization', name: 'State of Michigan' },
  },
  url: 'https://www.toptier-electrical.com/about',
});

// Article schema for rich-result eligibility and AI/search snippets.
// `isPartOf` ties the article to its cluster Service entity, creating an
// explicit graph edge between spoke and hub that Google's knowledge graph
// reads as a topical hierarchy.
const articleLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${canonical}#article`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  headline: post.title,
  description: post.excerpt || '',
  image: ogImage,
  datePublished: post.publishDate ? new Date(post.publishDate).toISOString() : undefined,
  dateModified: post.updateDate
    ? new Date(post.updateDate).toISOString()
    : post.publishDate
      ? new Date(post.publishDate).toISOString()
      : undefined,
  author: { '@id': 'https://www.toptier-electrical.com/#owner' },
  publisher: { '@id': 'https://www.toptier-electrical.com/#organization' },
  url: canonical,
  articleSection: categoryTitle,
  ...(cluster
    ? {
        isPartOf: { '@type': 'Service', '@id': cluster.serviceId, name: cluster.label, url: clusterUrl },
        about: { '@type': 'Service', '@id': cluster.serviceId },
      }
    : {}),
  keywords: Array.isArray(post.tags)
    ? post.tags
        .map((t) => (typeof t === 'string' ? t : t?.title))
        .filter(Boolean)
        .join(', ')
    : undefined,
});

// Cluster breadcrumb: Home > [Cluster] > Post (vs. generic Home > Blog > Post).
// Falls back to Home > Blog > Post when category has no mapped hub.
// Passed via TTELayout's `breadcrumbItems` prop so the layout emits both the
// visible nav and the BreadcrumbList JSON-LD using these items. (The layout
// filters caller-provided BreadcrumbList JSON-LD out of `jsonLd` by design
// to prevent duplicates.)
const breadcrumbItems = cluster
  ? [
      { name: 'Home', item: 'https://www.toptier-electrical.com/' },
      { name: cluster.label, item: clusterUrl as string },
      { name: post.title, item: canonical },
    ]
  : [
      { name: 'Home', item: 'https://www.toptier-electrical.com/' },
      { name: 'Blog', item: 'https://www.toptier-electrical.com/blog' },
      { name: post.title, item: canonical },
    ];
---

<TTELayout
  title={`${post.title} | Top Tier Electrical`}
  description={post.excerpt || ''}
  canonical={canonical}
  ogType="article"
  ogImage={ogImage}
  jsonLd={[personLd, articleLd]}
  breadcrumbItems={breadcrumbItems}
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>{post.title}</h1>
        {post.excerpt && <p>{post.excerpt}</p>}
        {
          post.publishDate && (
            <p class="muted" style="font-size: 0.9rem; margin-top: 0.5rem;">
              By <a href="/about">Carl, Top Tier Electrical</a> — Licensed Electrician (MI #6220430)
              {' · '}
              <time datetime={new Date(post.publishDate).toISOString()}>
                {new Date(post.publishDate).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
            </p>
          )
        }
      </div>
    </section>
    <article class="blog-post">
      <div class="container">
        {post.Content ? <post.Content /> : <Fragment set:html={post.content || ''} />}
        <div class="mt-8">
          <a href="/blog" class="btn btn-secondary">← Back to Blog</a>
        </div>
      </div>
    </article>
    {
      relatedServices.length > 0 && (
        <section class="container section-pad">
          <h2>Related services</h2>
          <ul>
            {relatedServices.map((s) => (
              <li>
                <a href={s.href}>{s.label}</a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
    <section class="cta-section">
      <h2>Need Electrical Service?</h2>
      <p>
        Call us at <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to confirm scope and scheduling.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
