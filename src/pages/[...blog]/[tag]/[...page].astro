---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';
import { blogTagRobots, getStaticPathsBlogTag } from '~/utils/blog';

import TTELayout from '~/layouts/TTELayout.astro';
import BlogList from '~/components/blog/List.astro';
import Headline from '~/components/blog/Headline.astro';
import Pagination from '~/components/blog/Pagination.astro';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  return await getStaticPathsBlogTag({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page, tag } = Astro.props as Props;

const currentPage = page.currentPage ?? 1;
const shouldIndex = blogTagRobots?.index ?? false;
const shouldFollow = blogTagRobots?.follow ?? true;
const robots = `${shouldIndex ? 'index' : 'noindex'}, ${shouldFollow ? 'follow' : 'nofollow'}`;

const title = `Posts tagged '${tag.title}'${currentPage > 1 ? ` — Page ${currentPage}` : ''} | Top Tier Electrical Blog`;
const canonical = `https://www.toptier-electrical.com${Astro.url.pathname}`;
const description =
  currentPage > 1
    ? `Articles tagged with ${tag.title} — page ${currentPage}. Practical electrical guides from Top Tier Electrical for West Michigan homeowners and businesses.`
    : `Articles tagged with ${tag.title}. Practical electrical guides from Top Tier Electrical for West Michigan homeowners and businesses.`;
---

<TTELayout title={title} canonical={canonical} robots={robots} description={description}>
  <main id="main-content" class="container section-pad-tight section-pad-bottom">
    <Headline>Tag: {tag.title}</Headline>
    <BlogList posts={page.data} />
    <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
  </main>
</TTELayout>
