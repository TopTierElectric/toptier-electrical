---
import fs from 'node:fs';
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';
import { blogCategoryRobots, getStaticPathsBlogCategory } from '~/utils/blog';

import TTELayout from '~/layouts/TTELayout.astro';
import BlogList from '~/components/blog/List.astro';
import Headline from '~/components/blog/Headline.astro';
import Pagination from '~/components/blog/Pagination.astro';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  return await getStaticPathsBlogCategory({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths> & { category: Record<string, string> };

const { page, category } = Astro.props as Props;

const currentPage = page.currentPage ?? 1;
const shouldIndex = blogCategoryRobots?.index ?? false;
const shouldFollow = blogCategoryRobots?.follow ?? true;
const robots = `${shouldIndex ? 'index' : 'noindex'}, ${shouldFollow ? 'follow' : 'nofollow'}`;

const title = `Category '${category.title}'${currentPage > 1 ? ` — Page ${currentPage}` : ''} | Top Tier Electrical Blog`;
const canonical = `https://www.toptier-electrical.com${Astro.url.pathname}`;
// Only a subset of categories has a bespoke OG image. Fall back to the
// site's default OG logo for any category without one, so no category
// page ever emits a 404 og:image/twitter:image (checked at build time,
// so new categories degrade gracefully instead of breaking the preview).
const ogImage = fs.existsSync(`public/images/og/category/${category.slug}.png`)
  ? `https://www.toptier-electrical.com/images/og/category/${category.slug}.png`
  : 'https://www.toptier-electrical.com/images/logos/TopTierElectrical_Primary_FlatGold_512.png';
const description =
  currentPage > 1
    ? `Articles in the ${category.title} category — page ${currentPage}. Practical electrical guides from Top Tier Electrical for West Michigan homeowners and businesses.`
    : `Articles in the ${category.title} category. Practical electrical guides from Top Tier Electrical for West Michigan homeowners and businesses.`;
---

<TTELayout title={title} {canonical} {robots} {description} {ogImage}>
  <main id="main-content" class="container section-pad-tight section-pad-bottom">
    <Headline>{category.title}</Headline>
    <BlogList posts={page.data} />
    <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
  </main>
</TTELayout>
