---
import TTELayout from '~/layouts/TTELayout.astro';

const canonical = 'https://www.toptier-electrical.com/tools/panel-size-calculator';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://www.toptier-electrical.com/tools' },
    { '@type': 'ListItem', position: 3, name: 'Panel Size Calculator', item: canonical },
  ],
});

// WebApplication schema flags this as an interactive utility so search and
// AI assistants can surface it for "calculator" / "tool" queries.
const appLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${canonical}#app`,
  name: 'Residential Electrical Panel Size Calculator',
  description:
    'Recommends 100, 200, or 400 amp service for a home based on square footage and major appliance load, using the NEC Article 220 standard residential calculation.',
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'Any',
  isAccessibleForFree: true,
  creator: { '@id': 'https://www.toptier-electrical.com/#owner' },
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
});

// HowTo schema mirrors the steps the tool walks visually so rich results and
// AI search can extract the procedure.
const howToLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  '@id': `${canonical}#howto`,
  name: 'How to Size a Residential Electrical Panel',
  description:
    'The NEC Article 220 standard method used to determine whether a home needs 100, 200, or 400 amp service.',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Calculate general lighting and receptacle load',
      text: 'Multiply heated floor area in square feet by 3 watts per square foot (NEC 220.12).',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Add small appliance and laundry circuits',
      text: 'Two 1500 W kitchen small-appliance circuits plus a 1500 W laundry circuit (NEC 220.52).',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Add nameplate loads for fixed appliances',
      text: 'Range, dryer, water heater, HVAC, EV charger, well pump, and any other 240V or dedicated equipment at nameplate watts.',
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Apply NEC demand factors',
      text: 'First 10,000 W of general load at 100 percent; remainder at 40 percent (NEC 220.42 / Table 220.45).',
    },
    {
      '@type': 'HowToStep',
      position: 5,
      name: 'Convert to amps and round to next service size',
      text: 'Divide total demand watts by 240 V. Round up to the next standard service size — 100, 200, or 400 amp.',
    },
  ],
});
---

<TTELayout
  title="Panel Size Calculator (100/200/400 amp) | Top Tier Electrical"
  description="Free residential panel size calculator. Enter square footage and major appliances; get a 100, 200, or 400 amp recommendation using the NEC 220 standard method."
  canonical={canonical}
  ogImage="https://www.toptier-electrical.com/images/og/pages/tools-panel-size-calculator.png"
  jsonLd={[breadcrumbLd, appLd, howToLd]}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/tools">Tools</a></li>
        <li aria-current="page">Panel Size Calculator</li>
      </ol>
    </nav>

    <section class="hero">
      <div class="hero-content">
        <h1>Panel Size Calculator</h1>
        <p>
          Enter your home's heated square footage and check the boxes for the major appliances you have (or plan to
          add). The calculator runs the NEC Article 220 standard residential method and recommends 100, 200, or 400 amp
          service.
        </p>
      </div>
    </section>

    <section class="container section-pad">
      <form id="psc-form" data-tool="panel-size-calculator" autocomplete="off">
        <div class="psc-grid">
          <div class="psc-field">
            <label for="psc-sqft"><strong>Heated square footage</strong></label>
            <input
              id="psc-sqft"
              name="sqft"
              type="number"
              min="500"
              max="15000"
              step="50"
              value="2000"
              inputmode="numeric"
              required
            />
            <p class="psc-hint">Living area only — not garages or unfinished basements.</p>
          </div>

          <fieldset class="psc-field">
            <legend><strong>Major appliances and equipment</strong></legend>
            <p class="psc-hint">Check what you have or plan to add within the next 12 months.</p>
            <ul class="psc-checks">
              <li>
                <label
                  ><input type="checkbox" name="range" data-watts="8000" checked /> Electric range / cooktop (8 kW)</label
                >
              </li>
              <li>
                <label><input type="checkbox" name="dryer" data-watts="5000" checked /> Electric dryer (5 kW)</label>
              </li>
              <li>
                <label
                  ><input type="checkbox" name="waterheater" data-watts="4500" /> Electric water heater (4.5 kW)</label
                >
              </li>
              <li>
                <label><input type="checkbox" name="centralac" data-watts="3500" /> Central AC (3.5 kW, ~3 ton)</label>
              </li>
              <li><label><input type="checkbox" name="heatpump" data-watts="6000" /> Heat pump (6 kW)</label></li>
              <li>
                <label
                  ><input type="checkbox" name="furnaceblower" data-watts="1200" /> Gas furnace blower (1.2 kW)</label
                >
              </li>
              <li><label><input type="checkbox" name="wellpump" data-watts="1500" /> Well pump (1.5 kW)</label></li>
              <li>
                <label
                  ><input type="checkbox" name="ev" data-watts="9600" /> Level 2 EV charger (40A circuit, 9.6 kW continuous)</label
                >
              </li>
              <li><label><input type="checkbox" name="hottub" data-watts="6000" /> Hot tub / spa (6 kW)</label></li>
              <li><label><input type="checkbox" name="pool" data-watts="2000" /> Pool pump / heater (2 kW)</label></li>
              <li>
                <label
                  ><input type="checkbox" name="shop" data-watts="3000" /> Detached shop / outbuilding subpanel (3 kW)</label
                >
              </li>
              <li>
                <label
                  ><input type="checkbox" name="inductiontop" data-watts="7200" /> Induction cooktop (7.2 kW, in addition
                  to range)</label
                >
              </li>
            </ul>
          </fieldset>
        </div>

        <div class="psc-actions">
          <button
            type="submit"
            class="btn btn-primary"
            data-ga-event="tool_calculate"
            data-ga-label="panel-size-calculator"
          >
            Calculate Recommended Panel Size
          </button>
        </div>
      </form>

      <div id="psc-result" class="psc-result" hidden aria-live="polite"></div>
    </section>

    <section class="container section-pad-tight">
      <h2>How the Math Works</h2>
      <p>The standard residential calculation in NEC Article 220 walks five steps:</p>
      <ol>
        <li><strong>General lighting + receptacles:</strong> 3 W per heated sq ft (NEC 220.12).</li>
        <li><strong>Small appliances + laundry:</strong> two 1500 W kitchen circuits + 1500 W laundry (NEC 220.52).</li>
        <li><strong>Fixed appliance nameplate watts</strong> for everything 240 V or dedicated.</li>
        <li>
          <strong>Demand factor:</strong> first 10 000 W of general load at 100 %, remainder at 40 % (NEC 220.42).
        </li>
        <li>
          <strong>Convert to amps:</strong> total demand watts ÷ 240 V, then round to the next standard service size.
        </li>
      </ol>
      <p>
        This calculator uses representative nameplate values for residential equipment. A real load calculation uses the
        actual nameplates on your equipment and is the basis of any permitted scope.
      </p>
      <p>
        Related reading:
        <a href="/blog/100-amp-vs-200-amp-panel">100 amp vs 200 amp panel: which your home needs</a> ·
        <a href="/blog/200-amp-vs-400-amp-service">200 amp vs 400 amp service</a> ·
        <a href="/blog/do-i-need-a-panel-upgrade-for-an-ev-charger">Do I need a panel upgrade for an EV charger?</a>
      </p>
      <p>
        Glossary: <a href="/glossary/load-calculation">load calculation</a> · <a href="/glossary/ampacity">ampacity</a> ·
        <a href="/glossary/demand-factor">demand factor</a> · <a href="/glossary/service-disconnect"
          >service disconnect</a
        >.
      </p>
    </section>

    <section class="cta-section">
      <h2>Ready for a Real Walkthrough?</h2>
      <p>
        Call <a href="tel:+16163347159" data-ga-event="phone_click" data-ga-label="panel-size-calculator__phone"
          >(616) 334-7159</a
        > or get a clear estimate — we run the calc against your actual nameplates and confirm what the utility can deliver
        on your street.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="panel-size-calculator__cta_bottom"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>

<style>
  .psc-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 24px;
    margin: 0 auto;
    max-width: 760px;
  }
  @media (min-width: 720px) {
    .psc-grid {
      grid-template-columns: 280px minmax(0, 1fr);
    }
  }
  .psc-field {
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-left: 4px solid var(--brand-gold);
    background: #fff;
    border-radius: 6px;
    padding: 16px 20px;
  }
  .psc-field legend {
    padding: 0 8px;
  }
  .psc-field input[type='number'] {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 4px;
    font-size: 18px;
  }
  .psc-hint {
    color: var(--brand-slate);
    font-size: 14px;
    margin: 6px 0 0;
  }
  .psc-checks {
    list-style: none;
    padding: 0;
    margin: 12px 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }
  @media (min-width: 720px) {
    .psc-checks {
      grid-template-columns: 1fr 1fr;
    }
  }
  .psc-checks label {
    display: flex;
    gap: 8px;
    align-items: flex-start;
    cursor: pointer;
    font-size: 15px;
    line-height: 1.4;
  }
  .psc-actions {
    text-align: center;
    margin-top: 24px;
  }
  .psc-result {
    max-width: 760px;
    margin: 32px auto 0;
    padding: 24px;
    background: rgba(0, 0, 0, 0.025);
    border-left: 4px solid var(--brand-gold);
    border-radius: 6px;
  }
  .psc-result h2 {
    margin-top: 0;
  }
  .psc-result table {
    width: 100%;
    border-collapse: collapse;
    margin: 12px 0;
    font-size: 15px;
  }
  .psc-result th,
  .psc-result td {
    text-align: left;
    padding: 6px 8px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  .psc-result th {
    width: 65%;
  }
  .psc-result td {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .psc-result .psc-recommend {
    font-size: 22px;
    font-weight: 800;
    margin-top: 16px;
  }
</style>

<script is:inline>
  (function () {
    const form = document.getElementById('psc-form');
    const result = document.getElementById('psc-result');
    if (!form || !result) return;

    function fmt(n) {
      return n.toLocaleString('en-US');
    }

    function recommendService(amps) {
      if (amps <= 100) return { size: 100, label: '100-amp service' };
      if (amps <= 200) return { size: 200, label: '200-amp service' };
      if (amps <= 320) return { size: 320, label: '320 / 400-amp service' };
      return { size: 400, label: '400-amp service (and consider a sub-panel layout)' };
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      const sqftInput = form.querySelector('#psc-sqft');
      const sqft = Math.max(0, Number(sqftInput.value) || 0);

      // NEC 220.12: 3 W/sq ft general lighting & receptacles
      const generalLighting = sqft * 3;
      // NEC 220.52: 2 × 1500 W small-appliance + 1500 W laundry
      const smallAppliances = 1500 * 2 + 1500;
      const generalLoad = generalLighting + smallAppliances;

      // Fixed appliances (sum of nameplate watts from checked boxes)
      const checks = form.querySelectorAll('input[type="checkbox"]:checked');
      let fixedLoad = 0;
      const lineItems = [];
      checks.forEach(function (cb) {
        const w = Number(cb.dataset.watts) || 0;
        const labelText = (cb.closest('label')?.textContent || cb.name).trim();
        lineItems.push({ name: labelText, watts: w });
        fixedLoad += w;
      });

      // NEC 220.42: demand factor — first 10,000 W of general load at 100%, remainder at 40%
      const demandedGeneral = Math.min(generalLoad, 10000) + Math.max(0, generalLoad - 10000) * 0.4;

      // Largest motor at 125% — approximated by the largest single nameplate among
      // the checked items (covers AC, heat pump, well pump inrush per NEC 220.50).
      const largestMotor = lineItems.reduce(function (m, item) {
        return item.watts > m ? item.watts : m;
      }, 0);
      const motorAdder = largestMotor * 0.25;

      const totalWatts = demandedGeneral + fixedLoad + motorAdder;
      const totalAmps = totalWatts / 240;
      const rec = recommendService(totalAmps);

      // Track GA4 event with the computed bucket (no PII, just the result bucket).
      if (typeof gtag === 'function') {
        gtag('event', 'tool_result', {
          tool: 'panel-size-calculator',
          result_size: rec.size,
          result_amps: Math.round(totalAmps),
        });
      }

      const rows = lineItems
        .map(function (item) {
          return '<tr><th>' + item.name + '</th><td>' + fmt(item.watts) + ' W</td></tr>';
        })
        .join('');

      result.innerHTML =
        '<h2>Recommended: ' +
        rec.label +
        '</h2>' +
        '<p>Estimated total demand: <strong>' +
        fmt(Math.round(totalAmps)) +
        ' amps</strong> ' +
        '(' +
        fmt(Math.round(totalWatts)) +
        ' W ÷ 240 V).</p>' +
        '<table>' +
        '<tr><th>General lighting (' +
        fmt(sqft) +
        ' sq ft × 3 W)</th><td>' +
        fmt(generalLighting) +
        ' W</td></tr>' +
        '<tr><th>Small appliance + laundry (3 × 1500 W)</th><td>' +
        fmt(smallAppliances) +
        ' W</td></tr>' +
        '<tr><th>General load total</th><td>' +
        fmt(generalLoad) +
        ' W</td></tr>' +
        '<tr><th>General load after NEC 220.42 demand factor</th><td>' +
        fmt(Math.round(demandedGeneral)) +
        ' W</td></tr>' +
        rows +
        '<tr><th>Largest-motor adder (NEC 220.50, 25 %)</th><td>' +
        fmt(Math.round(motorAdder)) +
        ' W</td></tr>' +
        '<tr><th><strong>Total demand</strong></th><td><strong>' +
        fmt(Math.round(totalWatts)) +
        ' W</strong></td></tr>' +
        '</table>' +
        '<p class="psc-recommend">→ ' +
        rec.label +
        '</p>' +
        '<p>This is the standard-method estimate. A permitted scope confirms it against actual nameplates and what the ' +
        'utility can deliver to your service. <a href="/booking" data-ga-event="clear_estimate_click" data-ga-label="panel-size-calculator__result_cta">Get a clear estimate</a>.</p>';

      result.hidden = false;
      result.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  })();
</script>
