---
import TTELayout from '~/layouts/TTELayout.astro';

const canonical = 'https://www.toptier-electrical.com/tools/generator-sizer';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://www.toptier-electrical.com/tools' },
    { '@type': 'ListItem', position: 3, name: 'Generator Sizer', item: canonical },
  ],
});

const appLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${canonical}#app`,
  name: 'Whole-Home Standby Generator Sizer',
  description:
    'Estimates the kW size of a standby generator from a Michigan home load list, including motor inrush. Returns a whole-home recommendation and an essential-circuits alternative.',
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'Any',
  isAccessibleForFree: true,
  creator: { '@id': 'https://www.toptier-electrical.com/#owner' },
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
});

const howToLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  '@id': `${canonical}#howto`,
  name: 'How to Size a Whole-Home Standby Generator',
  description:
    'The load-list method an electrician uses to recommend a standby generator size for a Michigan home, accounting for motor inrush.',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'List loads that must stay on',
      text: 'Decide whether you want whole-home coverage or essential circuits only (heat, sump, fridge, well, key outlets).',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Sum the running watts',
      text: 'Add nameplate wattage for every load on the list. This is the steady-state demand the generator must support.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Account for motor inrush',
      text: 'The largest motor (AC compressor, heat pump, well pump) draws 2-3x running watts at startup. Add a 30 percent buffer over running total to cover it.',
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Round up to a standard size',
      text: 'Generators are sold in standard kW sizes (10, 14, 18, 20, 22, 24, 26 kW etc). Pick the next size above the calculated number.',
    },
    {
      '@type': 'HowToStep',
      position: 5,
      name: 'Verify gas-line capacity and the transfer-switch fit',
      text: 'A correctly sized generator needs a correctly sized gas line and a transfer switch matched to the service. Confirm both before purchase.',
    },
  ],
});
---

<TTELayout
  title="Whole-Home Generator Sizer (kW Calculator) | Top Tier Electrical"
  description="Free generator sizer. List your loads; get a recommended whole-home kW size plus an essential-circuits alternative. Accounts for motor inrush — the most common sizing miss."
  canonical={canonical}
  ogImage="https://www.toptier-electrical.com/images/og/pages/tools-generator-sizer.png"
  jsonLd={[breadcrumbLd, appLd, howToLd]}
>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/tools">Tools</a></li>
        <li aria-current="page">Generator Sizer</li>
      </ol>
    </nav>

    <section class="hero">
      <div class="hero-content">
        <h1>Whole-Home Generator Sizer</h1>
        <p>
          Check the loads you want covered during a Michigan outage. The sizer adds them up, applies a 30 % motor-inrush
          buffer, and returns a recommended generator size plus an essential-circuits alternative if a smaller unit will
          work.
        </p>
      </div>
    </section>

    <section class="container section-pad">
      <form id="gs-form" data-tool="generator-sizer" autocomplete="off">
        <fieldset class="gs-field">
          <legend><strong>What do you want powered during an outage?</strong></legend>
          <p class="gs-hint">Tick the loads that must stay on. The "essential only" subset is highlighted.</p>

          <h3 class="gs-group">Essentials (always-on during a Michigan outage)</h3>
          <ul class="gs-checks">
            <li>
              <label
                ><input type="checkbox" name="furnace" data-watts="1200" data-essential="1" checked /> Gas furnace blower
                (1.2 kW)</label
              >
            </li>
            <li>
              <label
                ><input type="checkbox" name="sump" data-watts="800" data-motor="1" data-essential="1" checked /> Sump pump
                (0.8 kW, motor)</label
              >
            </li>
            <li>
              <label
                ><input type="checkbox" name="fridge" data-watts="800" data-motor="1" data-essential="1" checked /> Refrigerator
                (0.8 kW, motor)</label
              >
            </li>
            <li>
              <label
                ><input type="checkbox" name="freezer" data-watts="500" data-motor="1" data-essential="1" /> Chest freezer
                (0.5 kW, motor)</label
              >
            </li>
            <li>
              <label
                ><input type="checkbox" name="well" data-watts="1500" data-motor="1" data-essential="1" checked /> Well pump
                (1.5 kW, motor)</label
              >
            </li>
            <li>
              <label
                ><input type="checkbox" name="lights" data-watts="800" data-essential="1" checked /> LED lighting throughout
                (0.8 kW)</label
              >
            </li>
            <li>
              <label
                ><input type="checkbox" name="outlets" data-watts="600" data-essential="1" checked /> Outlets for routers,
                chargers, small electronics (0.6 kW)</label
              >
            </li>
          </ul>

          <h3 class="gs-group">Larger loads (push you into whole-home territory)</h3>
          <ul class="gs-checks">
            <li>
              <label
                ><input type="checkbox" name="centralac" data-watts="3500" data-motor="1" /> Central AC compressor (3.5 kW,
                motor)</label
              >
            </li>
            <li>
              <label
                ><input type="checkbox" name="heatpump" data-watts="6000" data-motor="1" /> Heat pump (6 kW, motor)</label
              >
            </li>
            <li>
              <label
                ><input type="checkbox" name="elecrange" data-watts="6000" /> Electric range (6 kW typical use)</label
              >
            </li>
            <li><label><input type="checkbox" name="dryer" data-watts="5000" /> Electric dryer (5 kW)</label></li>
            <li>
              <label
                ><input type="checkbox" name="waterheater" data-watts="4500" /> Electric water heater (4.5 kW)</label
              >
            </li>
            <li><label><input type="checkbox" name="hottub" data-watts="6000" /> Hot tub / spa (6 kW)</label></li>
            <li>
              <label
                ><input type="checkbox" name="evcharger" data-watts="9600" /> Level 2 EV charger at full draw (9.6 kW)</label
              >
            </li>
            <li>
              <label><input type="checkbox" name="shop" data-watts="3000" /> Detached shop / outbuilding (3 kW)</label>
            </li>
          </ul>
        </fieldset>

        <div class="gs-actions">
          <button type="submit" class="btn btn-primary" data-ga-event="tool_calculate" data-ga-label="generator-sizer">
            Calculate Recommended Generator Size
          </button>
        </div>
      </form>

      <div id="gs-result" class="gs-result" hidden aria-live="polite"></div>
    </section>

    <section class="container section-pad-tight">
      <h2>How the Sizing Works</h2>
      <p>Generators are rated in kW of continuous output. The recommended size needs to cover:</p>
      <ol>
        <li><strong>Sum of running watts</strong> across every load you want on during the outage.</li>
        <li>
          <strong>Motor inrush.</strong> Compressors, well pumps, and sump pumps draw 2-3× their running watts at start.
          This calculator adds a 30 % buffer to the running total to cover the largest motor's inrush, which is the most
          common sizing miss.
        </li>
        <li>
          <strong>Rounding to a standard generator size</strong> (10, 14, 18, 20, 22, 24, 26 kW etc.) — the next size above
          the calculated demand.
        </li>
      </ol>
      <p>
        A correctly sized generator is only half of a working install. The gas line has to be sized for the generator,
        and the transfer switch has to match the service. Both are part of a permitted scope.
      </p>
      <p>
        Related reading:
        <a href="/blog/how-to-size-a-whole-home-generator">How to size a whole-home generator (MI)</a> ·
        <a href="/blog/whole-home-vs-portable-generator">Whole-home vs portable generator</a> ·
        <a href="/blog/automatic-transfer-switch-explained">Automatic transfer switch explained</a>.
      </p>
      <p>
        Glossary: <a href="/glossary/automatic-transfer-switch">automatic transfer switch</a> ·
        <a href="/glossary/back-feeding">back-feeding</a> · <a href="/glossary/load-calculation">load calculation</a> ·
        <a href="/glossary/kva-vs-kw">kVA vs kW</a>.
      </p>
    </section>

    <section class="cta-section">
      <h2>Want a Real Generator Walkthrough?</h2>
      <p>
        Call <a href="tel:+16163347159" data-ga-event="phone_click" data-ga-label="generator-sizer__phone"
          >(616) 334-7159</a
        > or get a clear estimate. We size against actual nameplates, check the gas line, and confirm the transfer-switch
        fit before quoting.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="generator-sizer__cta_bottom"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>

<style>
  .gs-field {
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-left: 4px solid var(--brand-gold);
    background: #fff;
    border-radius: 6px;
    padding: 16px 20px;
    max-width: 760px;
    margin: 0 auto;
  }
  .gs-field legend {
    padding: 0 8px;
  }
  .gs-hint {
    color: var(--brand-slate);
    font-size: 14px;
    margin: 6px 0 0;
  }
  .gs-group {
    margin: 18px 0 6px;
    font-size: 16px;
    color: var(--brand-slate);
  }
  .gs-checks {
    list-style: none;
    padding: 0;
    margin: 6px 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }
  @media (min-width: 720px) {
    .gs-checks {
      grid-template-columns: 1fr 1fr;
    }
  }
  .gs-checks label {
    display: flex;
    gap: 8px;
    align-items: flex-start;
    cursor: pointer;
    font-size: 15px;
    line-height: 1.4;
  }
  .gs-actions {
    text-align: center;
    margin-top: 24px;
  }
  .gs-result {
    max-width: 760px;
    margin: 32px auto 0;
    padding: 24px;
    background: rgba(0, 0, 0, 0.025);
    border-left: 4px solid var(--brand-gold);
    border-radius: 6px;
  }
  .gs-result h2 {
    margin-top: 0;
  }
  .gs-result table {
    width: 100%;
    border-collapse: collapse;
    margin: 12px 0;
    font-size: 15px;
  }
  .gs-result th,
  .gs-result td {
    text-align: left;
    padding: 6px 8px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  .gs-result td {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .gs-recommend {
    font-size: 22px;
    font-weight: 800;
    margin-top: 16px;
  }
  .gs-alt {
    font-size: 16px;
    color: var(--brand-slate);
    margin-top: 4px;
  }
</style>

<script is:inline>
  (function () {
    // Residential standby (Generac / Kohler / Cummins) tops out around 48 kW.
    // The 60-150 kW tier is light-commercial: different gas-line sizing,
    // different transfer-switch options, and a different conversation
    // about scope. Beyond 150 kW we round to the next 25 kW and flag the
    // result so the tool never silently under-recommends.
    const RESIDENTIAL_CEILING_KW = 48;
    const STANDARD_KW = [7, 10, 12, 14, 16, 18, 20, 22, 24, 26, 30, 36, 40, 48, 60, 80, 100, 125, 150];

    function roundUpToStandard(kw) {
      for (let i = 0; i < STANDARD_KW.length; i++) {
        if (STANDARD_KW[i] >= kw) return STANDARD_KW[i];
      }
      // Above the largest tracked standard size — round up to the next 25 kW
      // increment so the recommendation always covers the computed demand.
      return Math.ceil(kw / 25) * 25;
    }

    function fmt(n) {
      return n.toLocaleString('en-US');
    }

    function sumLoads(items) {
      let running = 0;
      let largestMotor = 0;
      items.forEach(function (it) {
        running += it.watts;
        if (it.motor && it.watts > largestMotor) largestMotor = it.watts;
      });
      // 30% headroom over running, plus a motor adder (largestMotor × 30% extra
      // on top of running for inrush — captures real-world startup behavior
      // without over-spec'ing for homes with no motors at all).
      const buffer = running * 0.3;
      const motorInrush = largestMotor * 0.3;
      const sized = running + buffer + motorInrush;
      return {
        running: running,
        sizedWatts: sized,
        sizedKW: sized / 1000,
        recommendedKW: roundUpToStandard(sized / 1000),
        largestMotor: largestMotor,
      };
    }

    const form = document.getElementById('gs-form');
    const result = document.getElementById('gs-result');
    if (!form || !result) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      const all = [];
      const essentialOnly = [];
      form.querySelectorAll('input[type="checkbox"]').forEach(function (cb) {
        if (!cb.checked) return;
        const watts = Number(cb.dataset.watts) || 0;
        const motor = cb.dataset.motor === '1';
        const essential = cb.dataset.essential === '1';
        const labelText = (cb.closest('label')?.textContent || cb.name).trim();
        const item = { name: labelText, watts: watts, motor: motor };
        all.push(item);
        if (essential) essentialOnly.push(item);
      });

      if (all.length === 0) {
        result.innerHTML =
          '<p>Pick at least one load to size against. Most homes start with the Essentials list checked above.</p>';
        result.hidden = false;
        return;
      }

      const whole = sumLoads(all);
      const ess = sumLoads(essentialOnly);

      if (typeof gtag === 'function') {
        gtag('event', 'tool_result', {
          tool: 'generator-sizer',
          result_kw_whole: whole.recommendedKW,
          result_kw_essential: ess.recommendedKW,
        });
      }

      const rows = all
        .map(function (item) {
          return (
            '<tr><th>' + item.name + (item.motor ? ' (motor)' : '') + '</th><td>' + fmt(item.watts) + ' W</td></tr>'
          );
        })
        .join('');

      let altLine = '';
      if (essentialOnly.length > 0 && ess.recommendedKW < whole.recommendedKW) {
        altLine =
          '<p class="gs-alt">Essential-circuits-only alternative: <strong>' +
          ess.recommendedKW +
          ' kW</strong> ' +
          '(covers heat, sump, fridge, well, lighting, and outlets but not the big 240 V loads).</p>';
      } else if (essentialOnly.length === 0) {
        altLine =
          '<p class="gs-alt">No essential-only items checked, so no smaller alternative is shown. Tick at least the furnace, sump, and well pump to see one.</p>';
      }

      // Above residential standby ceiling: be honest that the math now points
      // into light-commercial territory rather than silently returning a
      // residential-sized recommendation that does not cover the demand.
      let scaleAdvisory = '';
      if (whole.recommendedKW > RESIDENTIAL_CEILING_KW) {
        scaleAdvisory =
          '<p class="gs-alt"><strong>Heads up:</strong> this recommendation is above typical residential standby ' +
          '(≤ ' +
          RESIDENTIAL_CEILING_KW +
          ' kW). Generators in this range are light-commercial — they have different ' +
          'gas-line sizing, different transfer-switch options, and different permit requirements than residential ' +
          'standby. Most homes that land here are over-counting loads they want simultaneously on; the more common ' +
          'fix is to drop a few non-essential loads or split into a smaller generator plus a manual load-shed. ' +
          '<a href="tel:+16163347159" data-ga-event="phone_click" data-ga-label="generator-sizer__above-residential">Call ' +
          '(616) 334-7159</a> and we will walk the real list with you.</p>';
      }

      result.innerHTML =
        '<h2>Recommended whole-home: ' +
        whole.recommendedKW +
        ' kW</h2>' +
        scaleAdvisory +
        '<p>Sum of running watts: <strong>' +
        fmt(Math.round(whole.running)) +
        ' W</strong>. ' +
        'After a 30 % buffer plus motor-inrush adder (largest motor ' +
        fmt(whole.largestMotor) +
        ' W × 30 %): ' +
        '<strong>' +
        fmt(Math.round(whole.sizedWatts)) +
        ' W ≈ ' +
        whole.sizedKW.toFixed(1) +
        ' kW</strong>. ' +
        'Rounded up to next standard size.</p>' +
        '<table>' +
        rows +
        '</table>' +
        '<p class="gs-recommend">→ ' +
        whole.recommendedKW +
        ' kW standby generator</p>' +
        altLine +
        '<p>This is a sizing estimate. A real install verifies the loads against actual nameplates and confirms the gas line and transfer switch. <a href="/booking" data-ga-event="clear_estimate_click" data-ga-label="generator-sizer__result_cta">Get a clear estimate</a>.</p>';

      result.hidden = false;
      result.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  })();
</script>
