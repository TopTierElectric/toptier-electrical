---
import '@fontsource-variable/inter';
import '~/assets/styles/tte-site.css';
import Favicons from '~/components/Favicons.astro';
import { SITE } from '~/config/site';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  robots?: string;
  jsonLd?: string | string[];
  breadcrumbItems?: Array<{ name: string; item: string }>;
}

const {
  title,
  description = 'Licensed & insured electrician serving West Michigan. Panel upgrades, EV chargers, lighting, and reliable troubleshooting. Get a clear estimate—call (616)\u00a0334\u2011\u20097159.',
  canonical,
  ogTitle,
  ogDescription,
  ogImage = 'https://toptier-electrical.com/images/logos/TopTierElectrical_Primary_FlatGold_512.png',
  ogType = 'website',
  robots = 'index, follow',
  jsonLd,
  breadcrumbItems,
} = Astro.props;

const canonicalPath = Astro.url.pathname === '/' ? '/' : Astro.url.pathname.replace(/\/$/, '');
const canonicalUrl = canonical || `${SITE.url}${canonicalPath}`;
const resolvedOgTitle = ogTitle || title;
const resolvedOgDescription = ogDescription || description;

const jsonLdScripts = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const siteUrl = SITE.url;
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const autoBreadcrumbItems = [
  { name: 'Home', item: `${siteUrl}/` },
  ...pathSegments.map((segment, index) => ({
    name: segment
      .split('-')
      .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
      .join(' '),
    item: `${siteUrl}/${pathSegments.slice(0, index + 1).join('/')}`,
  })),
];
const resolvedBreadcrumbs = breadcrumbItems ?? autoBreadcrumbItems;

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: resolvedBreadcrumbs.map((entry, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: entry.name,
    item: entry.item,
  })),
});

const organizationLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Electrician',
  '@id': `${siteUrl}/#localbusiness`,
  name: SITE.name,
  url: siteUrl,
  email: SITE.email,
  telephone: SITE.phone,
  description:
    'Licensed and insured West Michigan electrician providing panel upgrades, EV charger installation, lighting, troubleshooting, generator readiness, and light commercial electrical work.',
  image: `${siteUrl}/images/logos/TopTierElectrical_Primary_FlatGold_512.png`,
  logo: `${siteUrl}/images/logos/TopTierElectrical_Primary_FlatGold_512.png`,
  priceRange: '$$-$$$',
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'MI',
    addressCountry: 'US',
  },
  areaServed: SITE.areaServed.map((city) => ({ '@type': 'City', name: city })),
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00',
      closes: '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '09:00',
      closes: '13:00',
    },
  ],
  makesOffer: [
    {
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: 'Electrical Panel Upgrades' },
    },
    {
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: 'EV Charger Installation' },
    },
    {
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: 'Electrical Troubleshooting and Repairs' },
    },
    {
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: 'Lighting Installation' },
    },
  ],
  sameAs: ['https://www.facebook.com/profile.php?id=61573826170938', 'https://share.google/pOgXH17fP6C0srCw9'],
});

const websiteLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  name: SITE.name,
  url: siteUrl,
  inLanguage: 'en-US',
  publisher: {
    '@id': `${siteUrl}/#localbusiness`,
  },
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1a1a2e" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="robots" content={robots} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.name} />
    <!-- Open Graph -->
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="en_US" />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDescription} />
    <meta name="twitter:image" content={ogImage} />
    <!-- Geo -->
    <meta name="geo.region" content="US-MI" />
    <meta name="geo.placename" content="West Michigan" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <Favicons />
    <link rel="manifest" href="/manifest.webmanifest" />
    <!-- JSON-LD Structured Data -->
    {
      [breadcrumbLd, organizationLd, websiteLd, ...jsonLdScripts].map((ld) => (
        <script type="application/ld+json" is:inline set:html={ld} />
      ))
    }
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "SiteNavigationElement",
        "name": [
          "Home",
          "Services",
          "Residential",
          "Commercial",
          "Service Areas",
          "Blog",
          "Our Work",
          "About",
          "Contact"
        ],
        "url": [
          "https://toptier-electrical.com/",
          "https://toptier-electrical.com/services",
          "https://toptier-electrical.com/residential",
          "https://toptier-electrical.com/commercial",
          "https://toptier-electrical.com/service-areas",
          "https://toptier-electrical.com/blog",
          "https://toptier-electrical.com/gallery",
          "https://toptier-electrical.com/about",
          "https://toptier-electrical.com/contact"
        ]
      }
    </script>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-FTQKB78PLE"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        // eslint-disable-next-line prefer-rest-params
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-FTQKB78PLE');
    </script>
    <!-- Cloudflare Insights -->
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token":"f3a4c2b1d9e54a6b8c1f7e2d3a4b5c6d"}'></script>
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header class="site-header">
      <div class="container header-inner">
        <a class="logo" href="/" aria-label="Top Tier Electrical home">
          <picture>
            <source srcset="/images/logos/TopTierElectrical_Logo_Web_600w.webp" type="image/webp" />
            <img
              src="/images/logos/TopTierElectrical_Logo_Web_600w.webp"
              alt="Top Tier Electrical logo"
              width="200"
              height="64"
              decoding="async"
            />
          </picture>
        </a>
        <button
          type="button"
          class="menu-toggle"
          aria-label="Toggle navigation"
          aria-controls="main-nav"
          aria-expanded="false"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
        <nav id="main-nav" aria-label="Main navigation">
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/services">Services</a></li>
            <li><a href="/residential">Residential</a></li>
            <li><a href="/commercial">Commercial</a></li>
            <li><a href="/service-areas">Service&nbsp;Areas</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/gallery">Our&nbsp;Work</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
          <div class="nav-cta">
            <a href="tel:+16163347159" class="btn btn-ghost">Call / Text (616)&nbsp;334&#8209;7159</a>
            <a href="/booking" class="btn btn-primary">Request Scheduling</a>
          </div>
        </nav>
      </div>
    </header>

    <slot />

    <nav class="sticky-bar" aria-label="Mobile quick actions">
      <a href="tel:+16163347159" aria-label="Call or text Top Tier Electrical">Call / Text</a>
      <a href="/booking" class="btn" aria-label="Request electrical service scheduling">Request Scheduling</a>
    </nav>

    <!-- Pre-footer -->
    <section class="pre-footer" aria-label="Footer quick links">
      <div class="container">
        <div class="pre-footer-content">
          <div class="footer-col">
            <h4>Quick Links</h4>
            <ul aria-label="Quick links navigation">
              <li><a href="/services">Services</a></li>
              <li><a href="/booking">Request Scheduling</a></li>
              <li><a href="/about">About</a></li>
              <li><a href="/blog">Blog</a></li>
              <li><a href="/faq">FAQ</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Contact</h4>
            <p><a href="tel:+16163347159">(616)&nbsp;334&#8209;7159</a></p>
            <p><a href="mailto:info@toptier-electrical.com">info@toptier-electrical.com</a></p>
            <p>Mon–Fri 8am–6pm · Sat 9am–1pm</p>
          </div>
          <div class="footer-col">
            <h4>Service Areas</h4>
            <ul aria-label="Service area links">
              <li><a href="/electrician-holland-mi">Holland, MI</a></li>
              <li><a href="/electrician-grand-rapids-mi">Grand Rapids, MI</a></li>
              <li><a href="/electrician-zeeland-mi">Zeeland, MI</a></li>
              <li><a href="/electrician-hudsonville-mi">Hudsonville, MI</a></li>
              <li><a href="/electrician-allegan-mi">Allegan, MI</a></li>
              <li><a href="/electrician-ada">Ada, MI</a></li>
              <li><a href="/service-areas">All Areas →</a></li>
            </ul>
          </div>
        </div>
      </div>
    </section>
    <footer class="site-footer">
      <div class="footer-logo">
        <picture>
          <source srcset="/images/logos/TopTierElectrical_Logo_Web_600w.webp" type="image/webp" />
          <img
            src="/images/logos/TopTierElectrical_Logo_Web_600w.webp"
            alt="Top Tier Electrical logo"
            width="200"
            height="64"
            decoding="async"
          />
        </picture>
      </div>
      <p>MI License #6220430</p>
      <p>
        <a
          href="https://share.google/pOgXH17fP6C0srCw9"
          rel="noopener noreferrer"
          target="_blank"
          aria-label="Google Business Profile"
        >
          Google Business Profile
        </a>
      </p>
      <p>&copy; {new Date().getFullYear()} Top Tier Electrical. All rights reserved.</p>
    </footer>

    <script src="/script.js" defer></script>
  </body>
</html>
