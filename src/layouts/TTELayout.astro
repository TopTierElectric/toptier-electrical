---
import '~/assets/styles/tte-site.css';
import Favicons from '~/components/Favicons.astro';
import siteData from '~/data/site.json';
import { toApexCanonical } from '~/utils/canonical';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  robots?: string;
  jsonLd?: string | string[];
  breadcrumbItems?: Array<{ name: string; item: string }>;
}

const {
  title,
  description = 'Licensed master electrician serving West Michigan. Panel upgrades, EV chargers, lighting, and reliable troubleshooting. Get a clear estimate—call (616) 334‑ 7159.',
  canonical,
  ogTitle,
  ogDescription,
  ogImage = 'https://www.toptier-electrical.com/images/logos/TopTierElectrical_Primary_FlatGold_512.png',
  ogType = 'website',
  robots = 'index, follow',
  jsonLd,
  breadcrumbItems,
} = Astro.props;

const siteUrl = siteData.site.origin;
const gaMeasurementId = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID || siteData.seo?.analytics?.ga4MeasurementId || '';
const gtmId = import.meta.env.PUBLIC_GTM_ID || siteData.seo?.analytics?.gtmId || '';

// Analytics loads via a deferred-but-eager-on-interaction pattern.
// gtag.js parse + execute is ~150 ms on the main thread — enough to
// regress LCP if it runs during initial render. Solution:
//   1. Queue gtag events synchronously (so we never miss one).
//   2. Defer the actual gtag.js script load. Whichever fires first
//      among (a) requestIdleCallback with a 1500 ms ceiling,
//      (b) first user interaction (scroll/click/touch/key), or
//      (c) 1500 ms setTimeout fallback — triggers the load.
// Result: engaged users get gtag.js the instant they touch the page;
// passive users get it within 1.5 s; almost no bounce session is too
// short to capture the pageview hit. LCP stays clean because the
// load happens after first paint in every realistic scenario.
const analyticsHeadHtml = [
  gtmId
    ? `<script>(function(){window.dataLayer=window.dataLayer||[];window.dataLayer.push({'gtm.start':new Date().getTime(),event:'gtm.js'});var loaded=false;function load(){if(loaded)return;loaded=true;var f=document.getElementsByTagName('script')[0],j=document.createElement('script');j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id=${gtmId}';f.parentNode.insertBefore(j,f);}if('requestIdleCallback' in window){requestIdleCallback(load,{timeout:1500});}else{setTimeout(load,1500);}['scroll','click','keydown','touchstart','pointerdown'].forEach(function(ev){window.addEventListener(ev,load,{once:true,passive:true,capture:true});});})();</script>`
    : '',
  gaMeasurementId
    ? `<script>(function(){window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}window.gtag=gtag;gtag('js',new Date());gtag('config','${gaMeasurementId}');var loaded=false;function loadGA(){if(loaded)return;loaded=true;var s=document.createElement('script');s.async=true;s.src='https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}';document.head.appendChild(s);}if('requestIdleCallback' in window){requestIdleCallback(loadGA,{timeout:1500});}else{setTimeout(loadGA,1500);}['scroll','click','keydown','touchstart','pointerdown'].forEach(function(ev){window.addEventListener(ev,loadGA,{once:true,passive:true,capture:true});});})();</script>`
    : '',
]
  .filter(Boolean)
  .join('');

const normalizePath = (path: string) => {
  if (!path || path === '/') return '/';
  return path.endsWith('/') ? path.slice(0, -1) : path;
};

const resolvedPath = normalizePath(Astro.url.pathname);
const canonicalUrl = toApexCanonical(canonical || `${siteUrl}${resolvedPath}`, resolvedPath);
const resolvedOgTitle = ogTitle || title;
const resolvedOgDescription = ogDescription || description;

const pathSegments = resolvedPath.split('/').filter(Boolean);
const autoBreadcrumbItems = [
  { name: 'Home', item: `${siteUrl}/` },
  ...pathSegments.map((segment, index) => ({
    name: segment
      .split('-')
      .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
      .join(' '),
    item: `${siteUrl}/${pathSegments.slice(0, index + 1).join('/')}`,
  })),
];
const resolvedBreadcrumbs = breadcrumbItems ?? autoBreadcrumbItems;
// Only render the visible breadcrumb nav when the caller explicitly
// passes `breadcrumbItems`. Most pages render their own inline
// `<nav class="breadcrumb">` block (the established pattern), so
// auto-rendering here would create duplicate breadcrumb landmarks.
// BreadcrumbList JSON-LD below still uses the auto-generated path
// as a fallback, which is what we want for SEO regardless.
const hasBreadcrumbs = !!breadcrumbItems && breadcrumbItems.length > 1;

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: resolvedBreadcrumbs.map((entry, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: entry.name,
    item: entry.item,
  })),
});

const electricianLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Electrician',
  '@id': `${siteUrl}/#localbusiness`,
  name: siteData.business.name,
  alternateName: siteData.business.alternateName,
  legalName: siteData.business.legalName,
  url: siteUrl,
  telephone: siteData.business.phoneE164,
  email: siteData.business.email,
  image: `${siteUrl}/images/logos/TopTierElectrical_Primary_FlatGold_512.png`,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'MI',
    addressCountry: 'US',
  },
  areaServed: siteData.serviceAreas.map((area) => ({ '@type': 'Place', name: area })),
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: siteData.seo.googleReviewAverage,
    reviewCount: siteData.seo.googleReviewCount,
    bestRating: 5,
    worstRating: 1,
  },
  hasCredential: {
    '@type': 'EducationalOccupationalCredential',
    credentialCategory: 'license',
    name: 'Michigan Master Electrician License',
    identifier: '6220430',
    recognizedBy: {
      '@type': 'GovernmentOrganization',
      name: 'Michigan Department of Licensing and Regulatory Affairs (LARA)',
      url: 'https://www.michigan.gov/lara',
    },
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00',
      closes: '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '09:00',
      closes: '13:00',
    },
  ],
  sameAs: siteData.seo.socialProfiles,
});

const organizationLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteUrl}/#organization`,
  name: siteData.business.legalName,
  alternateName: [siteData.business.name, siteData.business.alternateName],
  url: siteUrl,
  logo: `${siteUrl}/images/logos/TopTierElectrical_Primary_FlatGold_512.png`,
  contactPoint: [
    {
      '@type': 'ContactPoint',
      telephone: siteData.business.phoneE164,
      contactType: 'customer service',
      email: siteData.business.email,
      areaServed: 'US-MI',
      availableLanguage: 'en',
    },
  ],
  sameAs: siteData.seo.socialProfiles,
});

const websiteLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  name: siteData.business.name,
  url: `${siteUrl}/`,
});

const webPageLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonicalUrl}#webpage`,
  url: canonicalUrl,
  name: title,
  description,
  inLanguage: 'en-US',
  isPartOf: { '@id': `${siteUrl}/#website` },
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['h1', 'main p:first-of-type'],
  },
});

const parseSchemaType = (schema: string) => {
  try {
    const parsed = JSON.parse(schema);
    if (!parsed || typeof parsed !== 'object') return null;
    return typeof parsed['@type'] === 'string' ? parsed['@type'] : null;
  } catch {
    return null;
  }
};

const protectedTypes = new Set(['BreadcrumbList', 'LocalBusiness', 'Electrician', 'Organization', 'WebSite']);
const rawJsonLdScripts = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const jsonLdScripts = rawJsonLdScripts.filter((schema) => {
  const schemaType = parseSchemaType(schema);
  return schemaType ? !protectedTypes.has(schemaType) : true;
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1a1a2e" />
    <meta name="robots" content={robots} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Top Tier Electrical" />
    <!-- Open Graph -->
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Top Tier Electrical" />
    <meta property="og:locale" content="en_US" />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDescription} />
    <meta name="twitter:image" content={ogImage} />
    <!-- Geo -->
    <meta name="geo.region" content="US-MI" />
    <meta name="geo.placename" content="West Michigan" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin-wght-normal.woff2" crossorigin />
    {
      gaMeasurementId && (
        <Fragment>
          <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
          <link rel="preconnect" href="https://www.google-analytics.com" crossorigin />
        </Fragment>
      )
    }
    <Favicons />
    <link rel="manifest" href="/manifest.webmanifest" />
    <!-- JSON-LD Structured Data -->
    {
      [breadcrumbLd, organizationLd, websiteLd, webPageLd, electricianLd, ...jsonLdScripts].map((ld) => (
        <script type="application/ld+json" is:inline set:html={ld} />
      ))
    }
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "SiteNavigationElement",
        "name": [
          "Home",
          "Services",
          "Residential",
          "Commercial",
          "Service Areas",
          "Blog",
          "Our Work",
          "About",
          "Contact"
        ],
        "url": [
          "https://www.toptier-electrical.com/",
          "https://www.toptier-electrical.com/services",
          "https://www.toptier-electrical.com/residential",
          "https://www.toptier-electrical.com/commercial",
          "https://www.toptier-electrical.com/service-areas",
          "https://www.toptier-electrical.com/blog",
          "https://www.toptier-electrical.com/gallery",
          "https://www.toptier-electrical.com/about",
          "https://www.toptier-electrical.com/contact"
        ]
      }
    </script>
    {analyticsHeadHtml && <Fragment set:html={analyticsHeadHtml} />}
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header class="site-header">
      <div class="container header-inner">
        <a class="logo" href="/">
          <picture>
            <source
              srcset="/images/logos/TopTierElectrical_Logo_Web_180w.webp 180w, /images/logos/TopTierElectrical_Logo_Web_300w.webp 300w"
              sizes="52px"
              type="image/webp"
            />
            <img
              src="/images/logos/TopTierElectrical_Logo_Web_180w.webp"
              alt="Top Tier Electrical logo"
              width="180"
              height="172"
              decoding="async"
              fetchpriority="high"
            />
          </picture>
        </a>
        <button
          type="button"
          class="menu-toggle"
          aria-label="Toggle navigation"
          aria-controls="main-nav"
          aria-expanded="false"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
        <nav id="main-nav" aria-label="Main navigation">
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/services">Services</a></li>
            <li><a href="/residential">Residential</a></li>
            <li><a href="/commercial">Commercial</a></li>
            <li><a href="/service-areas">Service&nbsp;Areas</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/gallery">Our&nbsp;Work</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
          <div class="nav-cta">
            <a
              href="tel:+16163347159"
              class="btn btn-ghost"
              data-ga-event="phone_click"
              data-ga-label="Header Call"
              data-ga-destination="tel:+16163347159"
            >
              Call (616) 334-7159
            </a>
            <a
              href="/booking"
              class="btn btn-primary"
              data-ga-event="clear_estimate_click"
              data-ga-label="Get a Clear Estimate"
              data-ga-destination="/booking"
            >
              Get a Clear Estimate
            </a>
          </div>
        </nav>
      </div>
    </header>
    {
      hasBreadcrumbs && (
        <nav class="container mt-4" aria-label="Breadcrumb">
          <ol class="flex flex-wrap gap-2 text-sm text-muted">
            {resolvedBreadcrumbs.map((entry, index) => (
              <li class="inline-flex items-center gap-2">
                {index > 0 && <span aria-hidden="true">/</span>}
                {index === resolvedBreadcrumbs.length - 1 ? (
                  <span aria-current="page">{entry.name}</span>
                ) : (
                  <a href={entry.item} class="underline-offset-4 hover:underline">
                    {entry.name}
                  </a>
                )}
              </li>
            ))}
          </ol>
        </nav>
      )
    }

    <slot />

    <nav class="sticky-bar" aria-label="Mobile quick actions">
      <a
        href="tel:+16163347159"
        data-ga-event="phone_click"
        data-ga-label="Sticky Call"
        data-ga-destination="tel:+16163347159"
      >
        Call (616) 334-7159
      </a>
      <a
        href="/booking"
        class="btn"
        data-ga-event="clear_estimate_click"
        data-ga-label="Sticky Get a Clear Estimate"
        data-ga-destination="/booking"
      >
        Get a Clear Estimate
      </a>
    </nav>

    <!-- Pre-footer -->
    <section class="pre-footer" aria-label="Footer quick links">
      <div class="container">
        <div class="pre-footer-content">
          <div class="footer-col">
            <h3>Quick Links</h3>
            <ul aria-label="Quick links navigation">
              <li><a href="/services">Services</a></li>
              <li><a href="/booking">Get a Clear Estimate</a></li>
              <li><a href="/about">About</a></li>
              <li><a href="/blog">Blog</a></li>
              <li><a href="/faq">FAQ</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h3>Contact</h3>
            <p><a href="tel:+16163347159">(616) 334-7159</a></p>
            <p><a href="mailto:info@toptier-electrical.com">info@toptier-electrical.com</a></p>
            <p>Mon–Fri 8am–6pm · Sat 9am–1pm</p>
          </div>
          <div class="footer-col">
            <h3>Service Areas</h3>
            <ul aria-label="Service area links">
              <li><a href="/electrician-holland-mi">Holland, MI</a></li>
              <li><a href="/electrician-grand-rapids-mi">Grand Rapids, MI</a></li>
              <li><a href="/electrician-zeeland-mi">Zeeland, MI</a></li>
              <li><a href="/electrician-hudsonville-mi">Hudsonville, MI</a></li>
              <li><a href="/electrician-allegan-mi">Allegan, MI</a></li>
              <li><a href="/electrician-ada-mi">Ada, MI</a></li>
              <li><a href="/service-areas">All Areas →</a></li>
            </ul>
          </div>
        </div>
      </div>
    </section>
    <footer class="site-footer">
      <div class="footer-logo">
        <picture>
          <source
            srcset="/images/logos/TopTierElectrical_Logo_Web_180w.webp 180w, /images/logos/TopTierElectrical_Logo_Web_300w.webp 300w"
            sizes="120px"
            type="image/webp"
          />
          <img
            src="/images/logos/TopTierElectrical_Logo_Web_180w.webp"
            alt="Top Tier Electrical logo"
            width="180"
            height="172"
            decoding="async"
          />
        </picture>
      </div>
      <p>
        <a
          href="https://aca-prod.accela.com/lara/"
          rel="noopener noreferrer"
          target="_blank"
          aria-label="Verify Michigan electrical license #6220430 on the LARA Accela portal"
          >Master Electrician · MI License #6220430 (verify on LARA →)</a
        >
      </p>
      <p>
        <a
          href={siteData.seo.googleBusinessProfileUrl}
          rel="noopener noreferrer"
          target="_blank"
          aria-label="Google Business Profile"
        >
          Google Business Profile
        </a>
      </p>
      <p>
        <a href="/privacy">Privacy Policy</a> ·
        <a href="/terms">Terms &amp; Conditions</a>
      </p>
      <p>&copy; {new Date().getFullYear()} Top Tier Electrical LLC. All rights reserved.</p>
    </footer>

    <script is:inline src="/script.js" defer></script>
  </body>
</html>
