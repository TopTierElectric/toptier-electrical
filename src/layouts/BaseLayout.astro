---
import '@fontsource-variable/inter';
import '~/assets/styles/tte-site.css';
import { toApexCanonical } from '~/utils/canonical';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Top Tier Electrical', description = 'Licensed electrician serving West Michigan.' } = Astro.props;
const canonical = toApexCanonical(String(Astro.url.pathname), String(Astro.url.pathname));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Top Tier Electrical" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
