---
export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Base Layout', description = 'A base layout for Astrowind projects' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="TopTierElectric" />
    <link rel="stylesheet" href="/styles.css" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <h1>Welcome to the Base Layout</h1>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; 2026 TopTierElectric. All rights reserved.</p>
    </footer>
  </body>
</html>
