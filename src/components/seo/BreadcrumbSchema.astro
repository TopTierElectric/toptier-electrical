---
interface Crumb {
  name: string;
  url: string;
}

const { crumbs } = Astro.props as { crumbs: Crumb[] };

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((crumb, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: crumb.name,
    item: crumb.url,
  })),
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
