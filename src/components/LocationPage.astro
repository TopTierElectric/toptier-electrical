---
import TTELayout from '~/layouts/TTELayout.astro';

export interface Props {
  city: string;
  county?: string;
  title: string;
  description: string;
  canonical: string;
  coverageParagraph?: string;
}

const { city, county, title, description, canonical, coverageParagraph } = Astro.props;

const displayLocation = county ? `${city} County, MI` : `${city}, MI`;
const coverageText =
  coverageParagraph ??
  `Panel upgrades, EV charger installations, lighting projects, and electrical repairs for ${displayLocation} and surrounding areas.`;

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.toptier-electrical.com/' },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Service Areas',
      item: 'https://www.toptier-electrical.com/service-areas',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: `Electrician in ${city}, MI`,
      item: canonical,
    },
  ],
});
---

<TTELayout {title} {description} {canonical} jsonLd={[breadcrumbLd]}>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Electrician in {city}, MI</h1>
        <p>Licensed, insured electrical service for {city} homes and commercial spaces.</p>
        <a
          href="/booking"
          class="btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking">Get a Clear Estimate</a
        >
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127968; Owner-Operated</span>
        </div>
      </div>
    </div>
    <section class="services">
      <div class="container">
        <h2>{city} Service Coverage</h2>
        <p>{coverageText}</p>
        <h3>Services Available in {city}</h3>
        <ul>
          <li><a href="/panel-upgrades">Electrical panel upgrades</a></li>
          <li><a href="/ev-chargers">EV charger installation</a></li>
          <li><a href="/lighting">Lighting and fixtures</a></li>
          <li><a href="/electrical-repairs">Electrical repairs and troubleshooting</a></li>
          <li><a href="/generators">Generator installation</a></li>
          <li><a href="/energy-solutions">Energy solutions</a></li>
        </ul>
        <p><a href="/contact" class="btn-secondary">Confirm availability in {city}</a></p>
      </div>
    </section>
    <slot />
    <section class="cta-section">
      <h2>Schedule Service in {city}</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to confirm scope and scheduling.
      </p>
      <a
        href="/booking"
        class="btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
