---
import TTELayout from '~/layouts/TTELayout.astro';

export interface Props {
  service: {
    slug: string; // e.g., 'panel-upgrades'
    name: string; // e.g., 'Panel Upgrades'
    nameLower: string; // e.g., 'panel upgrades'
    serviceType: string; // schema.org Service serviceType, e.g., 'Electrical Panel Upgrade'
    h1Action: string; // e.g., 'Electrical Panel Upgrades'
    intro: string; // 1-2 sentence service description
    pricingFactors: string[];
    relatedServices: Array<{ slug: string; name: string }>;
    faqs: Array<{ q: string; a: string }>;
  };
  city: {
    slug: string; // e.g., 'grand-rapids-mi'
    name: string; // e.g., 'Grand Rapids'
    citySlug: string; // e.g., 'electrician-grand-rapids-mi'
    county?: string; // e.g., 'Kent County'
    localContext: string; // unique local hook (1-2 sentences)
  };
}

const { service, city } = Astro.props;

// Per-service curated spoke crosswalk: the 3 most-relevant blog deep dives
// for each service hub. Wired into every <service>-<city> page so local
// landing pages also distribute equity to the spoke corpus (move 4 of the
// hub-spoke architecture plan).
const SERVICE_GUIDES: Record<string, Array<{ slug: string; title: string }>> = {
  'panel-upgrades': [
    { slug: '100-amp-vs-200-amp-panel', title: '100 amp vs 200 amp panel: which does your home need?' },
    { slug: 'zinsco-fpe-panel-replacement', title: 'Zinsco and Federal Pacific panels: why they need to go' },
    { slug: 'electrical-panel-upgrade-cost', title: 'Electrical panel upgrade cost: what determines the price?' },
  ],
  'ev-chargers': [
    { slug: 'level-1-vs-level-2-ev-charger', title: 'Level 1 vs Level 2 EV charger: which should you install?' },
    { slug: 'michigan-ev-charger-rebates', title: 'Michigan EV charger rebates & utility programs (2026)' },
    { slug: 'where-to-install-ev-charger', title: 'Where to install your EV charger: garage layout tips' },
  ],
  'electrical-repairs': [
    { slug: 'burning-smell-from-outlet', title: 'Burning smell from an outlet: what to do in the next 5 minutes' },
    {
      slug: 'flickering-lights-when-to-worry',
      title: "Flickering lights: when it's annoying vs when it's an emergency",
    },
    { slug: 'why-breakers-trip', title: 'Why does my breaker keep tripping?' },
  ],
  lighting: [
    {
      slug: 'smart-lighting-controls-explained',
      title: 'Smart lighting controls: dimmers, scenes, and occupancy sensors',
    },
    { slug: 'outdoor-security-lighting-guide', title: 'Outdoor security lighting: placement, wattage, and code' },
    { slug: 'led-retrofit-vs-fixture-replacement', title: 'LED retrofit vs full fixture replacement' },
  ],
  generators: [
    { slug: 'how-to-size-a-whole-home-generator', title: 'How to size a whole-home generator for a Michigan home' },
    { slug: 'whole-home-vs-portable-generator', title: 'Whole-home vs portable generator: which makes sense?' },
    {
      slug: 'automatic-transfer-switch-explained',
      title: 'What an automatic transfer switch does (and why you need one)',
    },
  ],
  'code-corrections': [
    { slug: 'knob-and-tube-wiring-what-to-do', title: 'Knob-and-tube wiring: what to do if you still have it' },
    { slug: 'aluminum-wiring-what-to-do', title: 'Aluminum wiring: what to do if you have it' },
    { slug: 'gfci-vs-afci-vs-dual-function', title: 'GFCI vs AFCI vs dual-function breakers' },
  ],
};
const relatedGuides = SERVICE_GUIDES[service.slug] ?? [];

const slug = `${service.slug}-${city.slug}`;
const canonical = `https://www.toptier-electrical.com/${slug}`;
const title = `${service.name} in ${city.name}, MI | Top Tier Electrical`;
const description = `${service.name} for ${city.name}, MI homes and businesses. ${service.intro}`.slice(0, 158);

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.toptier-electrical.com/' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://www.toptier-electrical.com/services' },
    {
      '@type': 'ListItem',
      position: 3,
      name: service.name,
      item: `https://www.toptier-electrical.com/${service.slug}`,
    },
    {
      '@type': 'ListItem',
      position: 4,
      name: `${service.name} in ${city.name}, MI`,
      item: canonical,
    },
  ],
});

const serviceLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${service.name} in ${city.name}, MI`,
  description: `${service.name} for ${city.name}, MI homes and businesses. ${service.intro}`,
  provider: { '@id': 'https://www.toptier-electrical.com/#localbusiness' },
  areaServed: { '@type': 'City', name: `${city.name}, MI` },
  serviceType: service.serviceType,
  url: canonical,
});

const faqLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: service.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
});

const otherServices = service.relatedServices.map((s) => ({
  href: `/${s.slug}-${city.slug}`,
  name: `${s.name} in ${city.name}, MI`,
}));

const ogImage = `https://www.toptier-electrical.com/images/og/service-city/${slug}.png`;
---

<TTELayout {title} {description} {canonical} {ogImage} jsonLd={[breadcrumbLd, serviceLd, faqLd]}>
  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href={`/${service.slug}`}>{service.name}</a></li>
        <li aria-current="page">{city.name}, MI</li>
      </ol>
    </nav>

    <section class="hero">
      <div class="hero-content">
        <h1>{service.h1Action} in {city.name}, MI</h1>
        <p>
          Licensed, insured {service.nameLower} for {city.name} homes and businesses. {service.intro}
        </p>
        <a
          href="/booking"
          class="btn btn-primary"
          data-ga-event="clear_estimate_click"
          data-ga-label="Get a Clear Estimate"
          data-ga-destination="/booking">Get a Clear Estimate</a
        >
      </div>
    </section>

    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127968; Owner-Operated</span>
          <span class="badge">Local to West Michigan</span>
        </div>
      </div>
    </div>

    <section class="container section-pad">
      <h2>{service.name} for {city.name}, MI</h2>
      <p>{city.localContext}</p>
      <p>
        We approach every {service.nameLower} project the same way: clear scope before work begins, code-correct installation,
        and a clean finish. Every job is licensed work that passes inspection.
      </p>

      <h3>Pricing Factors for {city.name} {service.name}</h3>
      <ul>
        {service.pricingFactors.map((f) => <li>{f}</li>)}
      </ul>

      <h3>Frequently Asked Questions</h3>
      <div class="faq-list">
        {
          service.faqs.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))
        }
      </div>

      <h3>Related Guides</h3>
      <p>Deeper reading on the questions {city.name} homeowners ask before this kind of project:</p>
      <ul>
        {
          relatedGuides.map((g) => (
            <li>
              <a href={`/blog/${g.slug}`}>{g.title}</a>
            </li>
          ))
        }
      </ul>

      <h3>Other Services in {city.name}</h3>
      <ul>
        {
          otherServices.map((s) => (
            <li>
              <a href={s.href}>{s.name}</a>
            </li>
          ))
        }
        <li>
          <a href={`/${city.citySlug}`}>All electrical services in {city.name}</a>
        </li>
      </ul>

      <p>
        See the full <a href={`/${service.slug}`}>{service.name} service page</a> for the complete scope, or browse
        <a href="/projects">recent projects</a> for examples of what we've delivered.
      </p>
    </section>

    <section class="cta-section">
      <h2>Schedule {service.name} in {city.name}</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email
        <a href="mailto:info@toptier-electrical.com">info@toptier-electrical.com</a> to confirm scope and scheduling.
      </p>
      <a
        href="/booking"
        class="btn btn-primary"
        data-ga-event="clear_estimate_click"
        data-ga-label="Get a Clear Estimate"
        data-ga-destination="/booking">Get a Clear Estimate</a
      >
    </section>
  </main>
</TTELayout>
