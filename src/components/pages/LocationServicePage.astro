---
import TTELayout from '~/layouts/TTELayout.astro';

export interface Props {
  city: string;
  slug: string;
  county?: string;
}

const { city, slug, county = `${city}, MI` } = Astro.props;
const canonical = `https://toptier-electrical.com/${slug}`;
const nearbyAreas = [
  { city: 'Holland', href: '/electrician-holland-mi' },
  { city: 'Grand Rapids', href: '/electrician-grand-rapids-mi' },
  { city: 'Zeeland', href: '/electrician-zeeland-mi' },
  { city: 'Hudsonville', href: '/electrician-hudsonville-mi' },
  { city: 'Allegan', href: '/electrician-allegan-mi' },
  { city: 'Ada', href: '/electrician-ada-mi' },
].filter((area) => area.city !== city);
---

<TTELayout
  title={`Electrician ${city} MI | Top Tier Electrical`}
  description={`Licensed electrician serving ${county}. Panel upgrades, EV charger installation, lighting, and electrical repairs.`}
  canonical={canonical}
>
  <main id="main-content">
    <section class="hero">
      <div class="hero-content">
        <h1>Electrician in {city}, MI</h1>
        <p>Licensed, insured electrical service for {city} homes and commercial spaces.</p>
        <a href="/booking" class="btn btn-primary">Get a Clear Estimate</a>
      </div>
    </section>
    <div class="trust-strip">
      <div class="container">
        <div class="trust-badges">
          <span class="badge">&#10004; Licensed &amp; Insured</span>
          <span class="badge">MI License #6220430</span>
          <span class="badge">&#127968; Owner-Operated</span>
        </div>
      </div>
    </div>
    <section class="services">
      <div class="container">
        <h2>{city} Service Coverage</h2>
        <p>
          Panel upgrades, EV charger installations, lighting projects, and electrical repairs for {county} and surrounding
          areas.
        </p>
        <h3>Services Available in {city}</h3>
        <ul>
          <li><a href="/panel-upgrades">Electrical panel upgrades</a></li>
          <li><a href="/ev-chargers">EV charger installation</a></li>
          <li><a href="/lighting">Lighting and fixtures</a></li>
          <li><a href="/electrical-repairs">Electrical repairs and troubleshooting</a></li>
          <li><a href="/generators">Generator installation</a></li>
          <li><a href="/energy-solutions">Energy solutions</a></li>
        </ul>
        <p><a href="/contact" class="btn btn-secondary">Confirm availability in {city}</a></p>
      </div>
    </section>
    <section class="services">
      <div class="container">
        <h2>Nearby Service Areas</h2>
        <p>
          Looking for electrical help in a nearby city? Explore nearby service area pages or view our full West Michigan
          coverage map.
        </p>
        <ul>
          {
            nearbyAreas.slice(0, 4).map((area) => (
              <li>
                <a href={area.href}>Electrician in {area.city}, MI</a>
              </li>
            ))
          }
          <li><a href="/service-areas">View all service areas</a></li>
        </ul>
      </div>
    </section>
    <section class="cta-section">
      <h2>Schedule Service in {city}</h2>
      <p>
        Call <a href="tel:+16163347159">(616) 334-7159</a> or email <a href="mailto:info@toptier-electrical.com"
          >info@toptier-electrical.com</a
        > to confirm scope and scheduling.
      </p>
      <a href="/booking" class="btn btn-primary">Get a Clear Estimate</a>
    </section>
  </main>
</TTELayout>
