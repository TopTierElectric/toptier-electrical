{
  "name": "toptier-electrical",
  "version": "1.0.0-beta.52",
  "description": "Business website for Top Tier Electrical — Licensed & insured electrician serving West Michigan. Built with Astro + Tailwind CSS.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "prebuild": "node scripts/generate-blog-og.mjs",
    "og:generate": "node scripts/generate-blog-og.mjs",
    "og:regenerate": "node scripts/generate-blog-og.mjs --force",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "wrangler pages deploy ./dist --project-name=toptier-electrical",
    "deploy:preview": "wrangler pages deploy ./dist --project-name=toptier-electrical --branch=preview",
    "check": "npm run check:astro && npm run check:eslint && npm run check:prettier",
    "check:astro": "astro check",
    "check:eslint": "eslint .",
    "check:prettier": "prettier --check .",
    "fix": "npm run fix:eslint && npm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier -w .",
    "verify:lockfile": "node scripts/verify-lockfile.mjs",
    "verify:monitoring-config": "node scripts/validate-monitoring-config.mjs",
    "verify": "npm run verify:lockfile && npm run verify:monitoring-config && npm run verify:site-config && npm run check",
    "monitor:uptime": "node scripts/run-monitoring.mjs full",
    "monitor:smoke": "node scripts/run-monitoring.mjs smoke",
    "security:audit": "npm audit --audit-level=high",
    "verify:site-config": "node scripts/validate-site-config.mjs",
    "check:workflows": "node scripts/check-workflows.mjs",
    "check:redirects-cloudflare": "node scripts/check-redirects-cloudflare.mjs",
    "check:navigation-sim": "node scripts/check-navigation-sim.mjs",
    "check:performance-budgets": "node scripts/check-performance-budgets.mjs",
    "localseo:ci": "node scripts/local-seo-audit.mjs",
    "check:seo-render": "node scripts/check-seo-render.mjs",
    "check:audit": "node scripts/check-audit.mjs",
    "check:integrations": "node scripts/check-integrations.mjs",
    "crawl:preview": "node scripts/crawl-site-audit.mjs",
    "crawl:dist": "node scripts/crawl-dist-all.mjs",
    "check:review-schema-policy": "node scripts/check-review-schema-policy.mjs",
    "check:schema-graph": "node scripts/check-schema-graph-integrity.mjs",
    "check:route-governance": "node scripts/check-route-governance.mjs",
    "check:image-markup": "node scripts/check-image-markup.mjs",
    "check:canonical-tags": "node scripts/check-canonical-tags.mjs",
    "check:sitemap-robots": "node scripts/check-sitemap-robots.mjs",
    "check:phone-normalization": "node scripts/check-phone-normalization.mjs",
    "check:identity-drift": "node scripts/check-identity-drift.mjs",
    "test": "node scripts/run-unit-tests.mjs",
    "test:e2e": "node scripts/run-e2e-smoke.mjs",
    "test:e2e:smoke": "node scripts/run-e2e-smoke.mjs",
    "qa": "npm run verify && npm run test && npm run build && npm run check:seo-render && npm run test:e2e:smoke"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/inter": "^5.2.6",
    "astro": "^7.1.3",
    "astro-icon": "^1.1.5",
    "limax": "4.1.0",
    "lodash.merge": "^4.6.2",
    "unpic": "^4.1.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.3",
    "@eslint/js": "^9.33.0",
    "@iconify-json/flat-color-icons": "^1.2.1",
    "@iconify-json/tabler": "^1.2.20",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.3",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/mdx": "^2.0.13",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "astro-compress": "2.4.1",
    "astro-eslint-parser": "^1.2.2",
    "eslint": "^9.33.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^16.3.0",
    "js-yaml": "^4.1.0",
    "mdast-util-to-string": "^4.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "reading-time": "^1.5.0",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.39.0",
    "unist-util-visit": "^5.0.0"
  },
  "overrides": {
    "fast-uri": "^3.1.4",
    "fast-xml-parser": "^5.7.2",
    "picomatch": "^4.0.4",
    "sharp": "^0.35.3",
    "svgo": "^4.0.2",
    "undici": "^7.28.0",
    "yaml": "^2.8.3",
    "astro-compress": {
      "sharp": "^0.35.3",
      "svgo": "^4.0.2"
    }
  }
}
