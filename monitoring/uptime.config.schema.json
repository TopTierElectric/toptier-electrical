{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["baseUrl", "checks", "thirdParty", "maintenance"],
  "properties": {
    "baseUrl": { "type": "string", "pattern": "^https?://" },
    "maintenance": {
      "type": "object",
      "required": ["enabled", "expectedStatus", "allowedContentMarkers"],
      "properties": {
        "enabled": { "type": "boolean" },
        "expectedStatus": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 1
        },
        "allowedContentMarkers": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path", "expectedStatus", "markers", "fallbackMarkers"],
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "expectedStatus": { "type": "array", "items": { "type": "integer" }, "minItems": 1 },
          "markers": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "fallbackMarkers": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "asset": { "type": "boolean" },
          "expectsFormAction": { "type": "string" }
        }
      }
    },
    "thirdParty": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "url", "expectedStatus"],
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string", "pattern": "^https?://" },
          "expectedStatus": { "type": "array", "items": { "type": "integer" }, "minItems": 1 }
        }
      }
    }
  }
}
